<div
	class="card">
	<!-- Cover image -->
	<div class="h-200px rounded-top" style="background-image:url({{ asset('assetsfront/images/bg/05.jpg') }}); background-position: center; background-size: cover; background-repeat: no-repeat;"></div>
	<!-- Card body START -->
	<div class="card-body py-0">
		<div class="d-sm-flex align-items-start text-center text-sm-start">
			<div>
				<!-- Avatar -->
				<div class="avatar avatar-xxl mt-n5 mb-3">
					<img class="avatar-img rounded-circle border border-white border-3" src="{{ app.user.avatarPath is defined and app.user.avatarPath ? asset(app.user.avatarPath) : asset('assetsfront/images/avatar/07.jpg') }}" alt="Avatar">
				</div>
			</div>
			<div
				class="ms-sm-4 mt-sm-3">
				<!-- Info -->
				<h1 class="mb-0 h5">{{ app.user.prenom ~ ' ' ~ app.user.nom }}
					<i class="bi bi-patch-check-fill text-success small"></i>
				</h1>
				<p>{{ app.user.connections is defined ? app.user.connections ~ ' connections' : '' }}</p>
			</div>
			<!-- Button -->
			<div class="d-flex mt-3 justify-content-center ms-sm-auto">
				<button class="btn btn-danger-soft me-2" type="button">
					<i class="bi bi-pencil-fill pe-1"></i>
					Edit profile
				</button>

			</div>
		</div>
		<!-- List profile -->
		<ul class="list-inline mb-0 text-center text-sm-start mt-3 mt-sm-0">
			<li class="list-inline-item">
				<i class="bi bi-briefcase me-1"></i>
				{{ app.user.specialite is defined and app.user.specialite ? app.user.specialite.value : 'Artiste' }}
			</li>
			<li class="list-inline-item">
				<i class="bi bi-geo-alt me-1"></i>
				{{ app.user.ville }}
			</li>
			<li class="list-inline-item">
				<i class="bi bi-calendar2-plus me-1"></i>
				Joined on
				{{ app.user.dateInscription is defined and app.user.dateInscription ? app.user.dateInscription|date('M d, Y') : '' }}
			</li>
		</ul>
	</div>
	<!-- Card body END -->
	<div
		class="card-footer mt-3 pt-2 pb-0">
		<!-- Nav profile pages -->
		{% set current_route = app.request.attributes.get('_route') %}
		<ul class="nav nav-bottom-line align-items-center justify-content-center justify-content-md-start mb-0 border-0 profile-nav">
			{% set specialite = app.user.specialite is defined and app.user.specialite ? app.user.specialite.value|lower : '' %}
		{% if specialite == 'musicien' %}
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_musiqueartiste' ? 'active' : '' }}" href="{{ path('app_musiqueartiste') }}">
					Musiques
				</a>
			</li>
		{% elseif specialite == 'auteur' %}
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_collections_front' ? 'active' : '' }}" href="{{ path('app_collections_front') }}">
					Collections
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_bibliothequeartiste' ? 'active' : '' }}" href="{{ path('app_bibliothequeartiste') }}">
					Biobliothèque
				</a>
			</li>
		{% elseif specialite in ['peintre', 'sculpteur', 'photographe'] %}
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_collections_front' ? 'active' : '' }}" href="{{ path('app_collections_front') }}">
					Collections
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_oeuvre_front' ? 'active' : '' }}" href="{{ path('app_oeuvre_front') }}">
					Mes Oeuvres
				</a>
			</li>
		{% endif %}
		<li class="nav-item">
			<a class="nav-link {{ current_route == 'app_eventsartiste' ? 'active' : '' }}" href="{{ path('app_eventsartiste') }}">
				Evenements
			</a>
		</li>
		<li class="nav-item">
			<a class="nav-link {{ current_route == 'app_reclamationsartiste' ? 'active' : '' }}" href="{{ path('app_reclamationsartiste') }}">
				Réclamations
			</a>
		</li>
	</ul>
</div></div><!-- My profile END -->

