{% extends 'base_admin.html.twig' %}

{%block title %}{{ 'Music Management'|trans }}{% endblock %}

{% block admin_content %}
<div class="card">
  <div class="card-header d-sm-flex align-items-center text-center justify-content-sm-between border-0 pb-0">
    <h1 class="h4 card-title">All Music</h1>
  </div>
  
  <div class="card-body">
    <!-- Search and Filter Bar START -->
    <div class="row mb-4 g-2 align-items-end">
      <div class="col-md-6">
        <div class="d-flex gap-2">
          <div class="flex-grow-1">
            <label for="searchInput" class="form-label small mb-2">Search by name or description</label>
            <input type="text" class="form-control" id="searchInput" placeholder="Search songs..." value="{{ searchTerm }}">
          </div>
          <button type="button" class="btn btn-outline-primary align-self-end" id="searchBtn">
            <i class="bi bi-search"></i> Search
          </button>
          {% if searchTerm %}
            <button type="button" class="btn btn-outline-secondary align-self-end" id="clearSearchBtn">
              <i class="bi bi-x-circle"></i> Clear
            </button>
          {% endif %}
        </div>
      </div>
      
      <div class="col-md-6">
        <div class="d-flex gap-2">
          <div class="flex-grow-1">
            <label for="sortBy" class="form-label small mb-2">Sort by</label>
            <select class="form-select" id="sortBy">
              <option value="date" {% if sortBy == 'date' %}selected{% endif %}>Date Added</option>
              <option value="titre" {% if sortBy == 'titre' %}selected{% endif %}>Title (A-Z)</option>
              <option value="genre" {% if sortBy == 'genre' %}selected{% endif %}>Genre</option>
            </select>
          </div>
          
          <div>
            <label class="form-label small mb-2">&nbsp;</label>
            <button type="button" class="btn btn-outline-primary w-100" id="toggleSortBtn">
              <i class="bi {% if sortOrder == 'DESC' %}bi-sort-down{% else %}bi-sort-up{% endif %}"></i>
              <span id="sortOrderText">{{ sortOrder == 'DESC' ? 'Descending' : 'Ascending' }}</span>
            </button>
          </div>
        </div>
      </div>
    </div>
    <!-- Search and Filter Bar END -->
    
    <!-- Results info START -->
    <div class="mb-3" id="resultsInfo">
      {% if searchTerm %}
        <p class="text-muted small">
          <i class="bi bi-info-circle"></i> 
          Found <strong>{{ musiques|length }}</strong> song(s) matching "{{ searchTerm }}"
          <a href="#" onclick="clearSearch(); return false;" class="ms-2">View all songs</a>
        </p>
      {% endif %}
    </div>
    <!-- Results info END -->
    
    {% if musiques is empty %}
      <!-- No music message START -->
      <div class="text-center py-5" id="emptyMessage">
        <i class="bi bi-music-note-beamed display-1 text-muted"></i>
        <h5 class="mt-3">No music found</h5>
        <p class="text-muted">{% if searchTerm %}No songs match your search. Try a different keyword.{% else %}No music uploaded yet.{% endif %}</p>
      </div>
      <!-- No music message END -->
    {% else %}
      <!-- Music grid START -->
      <div class="row g-4" id="musicGrid">
        {% for musique in musiques %}
          <!-- Music item START -->
          <div class="col-sm-6 col-xl-4">
            <div class="card h-100 music-card" 
                 data-music-id="{{ musique.id }}" 
                 data-audio-src="{{ path('app_musiqueartiste_audio', {'id': musique.id}) }}">
              <!-- Image with genre badge -->
              <div class="position-relative">
                <img class="img-fluid rounded-top" 
                     src="{{ path('app_musiqueartiste_image', {'id': musique.id}) }}" 
                     alt="{{ musique.titre }}"
                     style="background-color: #f0f0f0; min-height: 200px; object-fit: cover;">
                <div class="badge bg-primary text-white mt-2 me-2 position-absolute top-0 end-0">
                  {{ musique.genre }}
                </div>
              </div>
              
              <!-- Card body START -->
              <div class="card-body position-relative pt-0">
                <!-- Genre tag -->
                <a class="btn btn-xs btn-primary mt-n3" href="#">{{ musique.genre }}</a>
                
                <!-- Music title -->
                <h6 class="mt-3"> 
                  <a href="#!"> {{ musique.titre }} </a> 
                </h6>
                
                <!-- Description -->
                <p class="mb-2 small text-muted">
                  {{ musique.description|length > 50 ? musique.description|slice(0, 50) ~ '...' : musique.description }}
                </p>
                
                <!-- Date -->
                <p class="small"> 
                  <i class="bi bi-calendar pe-1"></i> 
                  {{ musique.date_creation|date('Y-m-d') }} 
                </p>
                
                <!-- Like and action buttons -->
                <div class="d-flex mt-3 gap-2">
                  <button class="btn btn-sm btn-primary flex-grow-1 play-btn">
                    <i class="bi bi-play-fill pe-1"></i> Play
                  </button>
                  <button class="btn btn-sm btn-outline-primary" title="Add to favorites">
                    <i class="bi bi-heart"></i>
                  </button>
                  <!-- More options dropdown -->
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-primary" type="button" id="dropdownMenu{{ musique.id }}" data-bs-toggle="dropdown" aria-expanded="false">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenu{{ musique.id }}">
                      <li>
                        <button type="button" class="dropdown-item text-danger delete-music-btn" data-music-id="{{ musique.id }}" style="border: none; background: none; cursor: pointer; width: 100%; text-align: left;">
                          <i class="bi bi-trash pe-2"></i>Delete
                        </button>
                      </li>
                      <li><a class="dropdown-item" href="#"> <i class="bi bi-share pe-2"></i>Share</a></li>
                    </ul>
                  </div>
                </div>
                
                <!-- Progress bar -->
                <div class="mt-3">
                  <div class="progress music-progress-container" style="height: 5px; cursor: pointer;" role="button" tabindex="0">
                    <div class="progress-bar bg-primary music-progress" role="progressbar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                  <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                    <span class="current-time">0:00</span>
                    <span class="total-time">0:00</span>
                  </div>
                </div>
                
                <!-- Stats -->
                <div class="d-flex justify-content-between align-items-center mt-3 small text-muted">
                  <span><i class="bi bi-hand-thumbs-up pe-1"></i>0</span>
                  <span><i class="bi bi-chat-dots pe-1"></i>0</span>
                  <span><i class="bi bi-collection-play pe-1"></i>0</span>
                </div>
              </div>
              <!-- Card body END -->
            </div>
          </div>
          <!-- Music item END -->
        {% endfor %}
      </div>
      <!-- Music grid END -->
    {% endif %}
  </div>
</div>

<script>
(function() {
  // Global audio player object
  const MusicPlayer = {
    audio: new Audio(),
    currentCard: null,
    currentMusicId: null,
    
    // Get all elements within a card
    getCardElements(card) {
      return {
        playBtn: card.querySelector('.play-btn'),
        icon: card.querySelector('.play-btn i'),
        progressBar: card.querySelector('.music-progress'),
        currentTime: card.querySelector('.current-time'),
        totalTime: card.querySelector('.total-time')
      };
    },
    
    // Reset card to default state
    resetCard(card) {
      if (!card) return;
      const elements = this.getCardElements(card);
      elements.icon.className = 'bi bi-play-fill pe-1';
      elements.progressBar.style.width = '0%';
      elements.currentTime.textContent = '0:00';
    },
    
    // Format time in MM:SS
    formatTime(seconds) {
      if (!isFinite(seconds)) return '0:00';
      const minutes = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${minutes}:${secs.toString().padStart(2, '0')}`;
    },
    
    // Seek to a specific percentage of the song
    seekTo(card, percent) {
      if (this.audio.duration && isFinite(this.audio.duration)) {
        this.audio.currentTime = percent * this.audio.duration;
      }
    },
    
    // Toggle play/pause
    togglePlayPause(card) {
      const musicId = card.dataset.musicId;
      const audioSrc = card.dataset.audioSrc;
      
      // If another song is playing, stop it
      if (this.currentCard && this.currentCard !== card) {
        this.resetCard(this.currentCard);
        this.audio.pause();
        this.audio.src = '';
      }
      
      // If clicking the same song, toggle play/pause
      if (musicId === this.currentMusicId) {
        if (this.audio.paused) {
          this.audio.play();
          const elements = this.getCardElements(card);
          elements.icon.className = 'bi bi-pause-fill pe-1';
        } else {
          this.audio.pause();
          const elements = this.getCardElements(card);
          elements.icon.className = 'bi bi-play-fill pe-1';
        }
      } else {
        // Playing a new song
        this.currentMusicId = musicId;
        this.currentCard = card;
        this.audio.src = audioSrc;
        this.audio.play();
        
        const elements = this.getCardElements(card);
        elements.icon.className = 'bi bi-pause-fill pe-1';
      }
    },
    
    // Initialize audio events
    initAudioEvents() {
      // Load metadata
      this.audio.addEventListener('loadedmetadata', () => {
        if (this.currentCard) {
          const elements = this.getCardElements(this.currentCard);
          if (this.audio.duration && isFinite(this.audio.duration)) {
            elements.totalTime.textContent = this.formatTime(this.audio.duration);
          }
        }
      });
      
      // Update progress bar
      this.audio.addEventListener('timeupdate', () => {
        if (this.currentCard && this.audio.duration && isFinite(this.audio.duration)) {
          const elements = this.getCardElements(this.currentCard);
          const percentage = (this.audio.currentTime / this.audio.duration) * 100;
          elements.progressBar.style.width = percentage + '%';
          elements.progressBar.setAttribute('aria-valuenow', Math.round(percentage));
          elements.currentTime.textContent = this.formatTime(this.audio.currentTime);
        }
      });
      
      // Reset when song ends
      this.audio.addEventListener('ended', () => {
        if (this.currentCard) {
          this.resetCard(this.currentCard);
          this.currentCard = null;
        }
      });
    },
    
    // Initialize event delegation for all music cards
    initCardEvents() {
      document.addEventListener('click', (e) => {
        // Handle play button clicks
        const playBtn = e.target.closest('.play-btn');
        if (playBtn) {
          const card = playBtn.closest('.music-card');
          if (card) {
            e.preventDefault();
            this.togglePlayPause(card);
          }
          return;
        }
        
        // Handle progress bar clicks for seeking
        const progressContainer = e.target.closest('.music-progress-container');
        if (progressContainer) {
          const card = progressContainer.closest('.music-card');
          if (card) {
            const rect = progressContainer.getBoundingClientRect();
            const percent = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            this.seekTo(card, percent);
          }
        }
        
        // Handle delete button clicks
        const deleteBtn = e.target.closest('.delete-music-btn');
        if (deleteBtn) {
          e.preventDefault();
          const musicId = deleteBtn.dataset.musicId;
          deleteMusic(musicId);
        }
      });
      
      // Keyboard accessibility for progress bars
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          const progressContainer = e.target.closest('.music-progress-container');
          if (progressContainer) {
            e.preventDefault();
            const card = progressContainer.closest('.music-card');
            if (card) {
              this.seekTo(card, 0.5); // Seek to middle
            }
          }
        }
      });
    },
    
    // Images load eagerly now, no lazy loading needed
    initLazyLoading() {
      // Placeholder for future use
    },
    
    // Initialize everything
    init() {
      this.initAudioEvents();
      this.initCardEvents();
      this.initLazyLoading();
    }
  };
  
  // Start the music player when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      MusicPlayer.init();
      updateSortButton();
    });
  } else {
    MusicPlayer.init();
    updateSortButton();
  }
})();

// AJAX Delete Music
function deleteMusic(musicId) {
  if (!confirm('Are you sure you want to delete this music?')) {
    return;
  }
  
  fetch('{{ path('app_musiqueartiste_delete', {'id': '__ID__'}) }}'.replace('__ID__', musicId), {
    method: 'POST',
    headers: {
      'X-Requested-With': 'XMLHttpRequest'
    }
  })
  .then(response => {
    if (response.ok) {
      // Find and remove the card from the grid
      const card = document.querySelector(`.music-card[data-music-id="${musicId}"]`);
      if (card) {
        const col = card.closest('.col-sm-6');
        if (col) {
          col.remove();
        }
      }
      
      // Show success message
      showAlert('success', 'Music deleted successfully!');
    } else {
      showAlert('error', 'Error deleting music');
    }
  })
  .catch(error => {
    console.error('Error:', error);
    showAlert('error', 'Error deleting music');
  });
}

function showAlert(type, message) {
  const alertDiv = document.createElement('div');
  alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
  alertDiv.role = 'alert';
  alertDiv.innerHTML = `
    ${message}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  `;
  
  // Insert after the search/filter section
  const cardBody = document.querySelector('.card-body');
  if (cardBody) {
    cardBody.insertBefore(alertDiv, cardBody.firstChild);
  }
}

// AJAX Search and Sort System
let currentSortOrder = '{{ sortOrder }}';

function loadMusicResults() {
  const search = document.getElementById('searchInput').value;
  const sort = document.getElementById('sortBy').value;
  
  const params = new URLSearchParams();
  if (search) params.append('search', search);
  params.append('sort', sort);
  params.append('order', currentSortOrder);
  
  // Show loading spinner
  const grid = document.getElementById('musicGrid');
  const emptyMsg = document.getElementById('emptyMessage');
  if (grid) grid.innerHTML = '<div class="col-12 text-center"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';
  if (emptyMsg) emptyMsg.style.display = 'none';
  
  // Fetch results
  fetch(`{{ path('app_admin_musique') }}?${params.toString()}`, {
    headers: {
      'X-Requested-With': 'XMLHttpRequest'
    }
  })
  .then(response => response.text())
  .then(html => {
    // Parse the HTML and extract just the music grid
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    
    // Try to get the grid
    const newGrid = doc.querySelector('#musicGrid');
    const newEmpty = doc.querySelector('#emptyMessage');
    const newResults = doc.querySelector('#resultsInfo');
    
    // Update grid
    if (grid && newGrid) {
      grid.innerHTML = newGrid.innerHTML;
      emptyMsg.style.display = 'none';
    } else if (emptyMsg && newEmpty) {
      grid.style.display = 'none';
      emptyMsg.innerHTML = newEmpty.innerHTML;
      emptyMsg.style.display = 'block';
    }
    
    // Update results info
    if (newResults) {
      document.getElementById('resultsInfo').innerHTML = newResults.innerHTML;
    }
    
    // Update sort order button icon
    updateSortButton();
  })
  .catch(error => console.error('Error loading results:', error));
}

function updateSortButton() {
  const btn = document.getElementById('toggleSortBtn');
  const icon = btn.querySelector('i');
  const text = document.getElementById('sortOrderText');
  
  if (currentSortOrder === 'DESC') {
    icon.className = 'bi bi-sort-down';
    text.textContent = 'Descending';
  } else {
    icon.className = 'bi bi-sort-up';
    text.textContent = 'Ascending';
  }
}

function clearSearch() {
  document.getElementById('searchInput').value = '';
  currentSortOrder = 'DESC';
  document.getElementById('sortBy').value = 'date';
  loadMusicResults();
}

// Event listeners
document.getElementById('searchBtn').addEventListener('click', () => {
  currentSortOrder = 'DESC';
  document.getElementById('sortBy').value = 'date';
  loadMusicResults();
});

document.getElementById('searchInput').addEventListener('keypress', (e) => {
  if (e.key === 'Enter') {
    currentSortOrder = 'DESC';
    document.getElementById('sortBy').value = 'date';
    loadMusicResults();
  }
});

document.getElementById('sortBy').addEventListener('change', () => {
  currentSortOrder = 'DESC';
  loadMusicResults();
});

document.getElementById('toggleSortBtn').addEventListener('click', () => {
  currentSortOrder = currentSortOrder === 'DESC' ? 'ASC' : 'DESC';
  updateSortButton();  // Update button UI immediately
  loadMusicResults();
});

// Handle clear button if it exists
const clearBtn = document.getElementById('clearSearchBtn');
if (clearBtn) {
  clearBtn.addEventListener('click', clearSearch);
}
</script>
{% endblock %}
