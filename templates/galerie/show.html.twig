<!DOCTYPE html>

<title>Galerie</title>

{% block body %}
    <h1>Galerie</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ galerie.id }}</td>
            </tr>
            <tr>
                <th>Nom</th>
                <td>{{ galerie.nom }}</td>
            </tr>
            <tr>
                <th>Adresse</th>
                <td>{{ galerie.adresse }}</td>
            </tr>
            <tr>
                <th>Localisation</th>
                <td>{{ galerie.localisation }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ galerie.description }}</td>
            </tr>
            <tr>
                <th>Capacite_max</th>
                <td>{{ galerie.capaciteMax }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('galeries') }}">back to list</a>

    <a href="{{ path('app_galerie_edit', {'id': galerie.id}) }}">edit</a>

    {{ include('galerie/_delete_form.html.twig') }}
{% endblock %}
