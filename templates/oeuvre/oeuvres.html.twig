{% extends 'base_admin.html.twig' %}

{%block title %}{{ 'Oeuvres'|trans }}{% endblock %}

{% block admin_content %}
          <div class="row">
            <!-- Page Header -->
            <div class="col-lg-12 col-md-12 col-12">
              <div class="border-bottom pb-3 mb-3 d-flex align-items-center justify-content-between">
                <div class="d-flex flex-column gap-1">
                  <h1 class="mb-0 h1 fw-bold">Tous les Oeuvres</h1>
                  <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item">
                        <a href="{{ path('app_admin') }}">Tableau de Bord</a>
                      </li>
                      <li class="breadcrumb-item active" aria-current="page">Tous les Oeuvres</li>
                    </ol>
                  </nav>
                </div>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-12 col-md-12 col-12">
              <!-- Card -->
              <div class="card rounded-3">
                <!-- Card Header -->
                <div class="card-header p-0">
                  <ul class="nav nav-lb-tab border-bottom-0" id="tab" role="tablist">
                    <li class="nav-item">
                      <a class="nav-link active" id="all-post-tab" data-bs-toggle="pill" href="#all-post" role="tab" aria-controls="all-post" aria-selected="true">Tout</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="published-tab" data-bs-toggle="pill" href="#published" role="tab" aria-controls="published" aria-selected="false">Peinture</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="scheduled-tab" data-bs-toggle="pill" href="#scheduled" role="tab" aria-controls="scheduled" aria-selected="false">Sculpture</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="draft-tab" data-bs-toggle="pill" href="#draft" role="tab" aria-controls="draft" aria-selected="false">Photohgraphie</a>
                    </li>
                  </ul>
                </div>
                <div class="p-4">
                  <div class="d-flex align-items-center gap-3">
                    <!-- Search Form -->
                    <form class="d-flex align-items-center flex-grow-1" method="get" action="{{ path('oeuvres') }}" id="searchForm" style="max-width: 300px;">
                      <span class="position-absolute ps-3 search-icon">
                        <i class="fe fe-search"></i>
                      </span>
                      <input type="search" name="q" class="form-control ps-6" placeholder="Rechercher Oeuvre" value="{{ currentQuery }}" />
                      <input type="hidden" name="sort" id="sortInput" value="{{ sortBy }}" />
                      <input type="hidden" name="order" id="orderInput" value="{{ sortOrder }}" />
                      <input type="hidden" name="tab" id="tabInput" value="{{ activeTab|default('all-post') }}" />
                    </form>

                    <!-- Sort Dropdown and Order Button -->
                    <div class="d-flex align-items-center gap-2">
                      <select id="sortSelect" class="form-select" style="width: 200px;">
                        <option value="" disabled selected>Trier par...</option>
                        <option value="favoris" {{ sortBy == 'favoris' ? 'selected' : '' }}>Favoris</option>
                        <option value="commentaires" {{ sortBy == 'commentaires' ? 'selected' : '' }}>Commentaires</option>
                        <option value="likes" {{ sortBy == 'likes' ? 'selected' : '' }}>J'aimes</option>
                      </select>
                      <button type="button" class="btn btn-outline-primary" id="orderToggle" onclick="toggleOrder()">
                        {{ sortOrder == 'ASC' ? '↑ ASC' : '↓ DESC' }}
                      </button>
                    </div>

                    <!-- Delete All Button -->
                    <div class="ms-auto">
                      <button type="button" class="btn btn-primary" id="deleteAllBtn" onclick="bulkDeleteOeuvres()">Supprimer tout</button>
                    </div>
                  </div>
                </div>

                <!-- Hidden bulk delete form -->
                <form id="bulkDeleteForm" method="post" action="{{ path('oeuvre_bulk_delete') }}" style="display:none;">
                  <input type="hidden" name="_token" value="{{ csrf_token('bulk_delete_oeuvre') }}">
                  <div id="bulkIds"></div>
                </form>

                <script>
                  // Initialize checkAll listener on page load
                  document.addEventListener('DOMContentLoaded', function() {
                    setupCheckboxListeners();
                  });

                  function setupCheckboxListeners() {
                    // Get all checkAll checkboxes (one per tab)
                    const checkAllBoxes = document.querySelectorAll('#checkAll');
                    checkAllBoxes.forEach(checkbox => {
                      checkbox.addEventListener('change', function() {
                        toggleAllInTab(this);
                      });
                    });
                  }

                  function toggleAllInTab(checkAllBox) {
                    // Find the closest table and toggle all checkboxes in that table
                    const table = checkAllBox.closest('table');
                    if (table) {
                      const checkboxes = table.querySelectorAll('input[type="checkbox"][id^="post"]');
                      checkboxes.forEach(checkbox => {
                        checkbox.checked = checkAllBox.checked;
                      });
                    }
                  }

                  function bulkDeleteOeuvres() {
                    // Collect all checked checkboxes across all tabs
                    const checkedBoxes = document.querySelectorAll('input[type="checkbox"][id^="post"]:checked');
                    
                    if (checkedBoxes.length === 0) {
                      alert('Veuillez sélectionner au moins une œuvre à supprimer.');
                      return;
                    }

                    if (!confirm('Êtes-vous sûr de vouloir supprimer ' + checkedBoxes.length + ' œuvre(s) ?')) {
                      return;
                    }

                    // Collect IDs and add to form
                    const bulkIdsContainer = document.getElementById('bulkIds');
                    bulkIdsContainer.innerHTML = '';
                    
                    checkedBoxes.forEach(checkbox => {
                      const id = checkbox.id.replace('post', '');
                      const input = document.createElement('input');
                      input.type = 'hidden';
                      input.name = 'ids[]';
                      input.value = id;
                      bulkIdsContainer.appendChild(input);
                    });

                    // Submit the form
                    document.getElementById('bulkDeleteForm').submit();
                  }

                  // Track active tab on change
                  document.querySelectorAll('.nav-lb-tab .nav-link').forEach(function(tab) {
                    tab.addEventListener('shown.bs.tab', function(e) {
                      const targetId = e.target.getAttribute('href').substring(1);
                      document.getElementById('tabInput').value = targetId;
                    });
                  });

                  // Restore active tab on page load
                  document.addEventListener('DOMContentLoaded', function() {
                    const activeTabId = new URLSearchParams(window.location.search).get('tab') || 'all-post';
                    const tabElement = document.querySelector('[href="#' + activeTabId + '"]');
                    if (tabElement) {
                      const tab = new bootstrap.Tab(tabElement);
                      tab.show();
                    }
                  });

                  document.getElementById('sortSelect').addEventListener('change', function() {
                    if (this.value) {
                      document.getElementById('sortInput').value = this.value;
                      document.getElementById('searchForm').submit();
                    }
                  });

                  function toggleOrder() {
                    const currentOrder = document.getElementById('orderInput').value;
                    document.getElementById('orderInput').value = currentOrder === 'ASC' ? 'DESC' : 'ASC';
                    document.getElementById('searchForm').submit();
                  }
                </script>

