<nav class="navbar-default navbar navbar-expand-lg">
        <a id="nav-toggle" href="#">
            <i class="fe fe-menu"></i>
        </a>
        <!--Navbar nav -->
        <div class="ms-auto d-flex">
            <div class="dropdown">
                <button class="btn btn-light btn-icon rounded-circle d-flex align-items-center" type="button" aria-expanded="false" data-bs-toggle="dropdown" aria-label="Toggle theme (auto)">
                    <i class="bi theme-icon-active"></i>
                    <span class="visually-hidden bs-theme-text">Toggle theme</span>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="bs-theme-text">
                    <li>
                        <button type="button" class="dropdown-item d-flex align-items-center" data-bs-theme-value="light" aria-pressed="false">
                            <i class="bi theme-icon bi-sun-fill"></i>
                            <span class="ms-2">Clair</span>
                        </button>
                    </li>
                    <li>
                        <button type="button" class="dropdown-item d-flex align-items-center" data-bs-theme-value="dark" aria-pressed="false">
                            <i class="bi theme-icon bi-moon-stars-fill"></i>
                            <span class="ms-2">Sombre</span>
                        </button>
                    </li>
                </ul>
            </div>
            <ul class="navbar-nav navbar-right-wrap ms-2 d-flex nav-top-wrap">
                <li class="dropdown stopevent">
                    <a
                        class="btn btn-light btn-icon rounded-circle indicator indicator-primary"
                        href="#"
                        role="button"
                        id="dropdownNotification"
                        data-bs-toggle="dropdown"
                        aria-haspopup="true"
                        aria-expanded="false">
                        <i class="fe fe-bell"></i>
                        {% set recent_count = recent_reclamations_count() %}
                        {% if recent_count > 0 %}
                            <span class="badge-dot bg-danger" style="position: absolute; top: 2px; right: 2px; width: 10px; height: 10px;"></span>
                        {% endif %}
                    </a>
                    <div class="dropdown-menu dropdown-menu-end dropdown-menu-lg" aria-labelledby="dropdownNotification">
                        <div>
                            <div class="border-bottom px-3 pb-3 d-flex justify-content-between align-items-center">
                                <span class="h4 mb-0">Réclamations récentes</span>
                                <button class="btn btn-sm btn-ghost" type="button" onclick="clearNotifications(event)" title="Vider les notifications">
                                    <i class="fe fe-trash"></i>
                                </button>
                            </div>
                            <!-- List group -->
                            <ul class="list-group list-group-flush" data-simplebar style="max-height: 350px">
                                {% set reclamations = recent_reclamations(5) %}
                                {% if reclamations|length > 0 %}
                                    {% for reclamation in reclamations %}
                                        <li class="list-group-item">
                                            <div class="row">
                                                <div class="col">
                                                    <a class="text-body" href="{{ path('app_reclamation_admin_index') }}">
                                                        <div class="d-flex">
                                                            <div class="me-2">
                                                                {% if reclamation.type and reclamation.type.value == 'Paiement' %}
                                                                    <i class="fe fe-credit-card text-warning" style="font-size: 1.5rem;"></i>
                                                                {% elseif reclamation.type and reclamation.type.value == 'Oeuvre' %}
                                                                    <i class="fe fe-image text-info" style="font-size: 1.5rem;"></i>
                                                                {% elseif reclamation.type and reclamation.type.value == 'Evènement' %}
                                                                    <i class="fe fe-calendar text-success" style="font-size: 1.5rem;"></i>
                                                                {% else %}
                                                                    <i class="fe fe-user text-primary" style="font-size: 1.5rem;"></i>
                                                                {% endif %}
                                                            </div>
                                                            <div class="flex-grow-1">
                                                                <h6 class="fw-bold mb-1">{{ reclamation.user ? reclamation.user.prenom ~ ' ' ~ reclamation.user.nom : 'Utilisateur' }}</h6>
                                                                <p class="mb-2 small text-muted">{{ reclamation.texte|slice(0, 50) }}{% if reclamation.texte|length > 50 %}...{% endif %}</p>
                                                                <span class="fs-7 text-muted">
                                                                    <i class="fe fe-calendar me-1"></i>
                                                                    {{ reclamation.dateCreation ? reclamation.dateCreation|date('d/m/Y H:i') : '-' }}
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </a>
                                                </div>
                                                <div class="col-auto text-center me-2">
                                                    <span class="badge 
                                                        {% if reclamation.statut and reclamation.statut.value == 'Traitée' %}
                                                            bg-success
                                                        {% elseif reclamation.statut and reclamation.statut.value == 'En cours' %}
                                                            bg-info
                                                        {% else %}
                                                            bg-warning
                                                        {% endif %}
                                                    ">
                                                        {{ reclamation.statut ? reclamation.statut.value : '-' }}
                                                    </span>
                                                </div>
                                            </div>
                                        </li>
                                    {% endfor %}
                                {% else %}
                                    <li class="list-group-item text-center py-4 text-muted">
                                        <i class="fe fe-inbox mb-2" style="font-size: 2rem; display: block;"></i>
                                        <span>Aucune réclamation récente</span>
                                    </li>
                                {% endif %}
                            </ul>
                        </div>
         
                    </div>
                </li>
                <!-- List -->
                <li class="dropdown ms-2">
                    <a class="rounded-circle" href="#" role="button" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="avatar avatar-md avatar-indicators avatar-online">
                            {% if app.user.photoProfilUrl %}
                                <img alt="avatar" src="{{ app.user.photoProfilUrl }}" class="rounded-circle" />
                            {% else %}
                                <span class="avatar-img rounded-circle d-flex align-items-center justify-content-center bg-light text-secondary-emphasis position-relative" style="width:48px;height:48px;">
                                    <i class="bi bi-person fs-3 position-absolute top-50 start-50 translate-middle" style="opacity:0.5;"></i>
                                </span>
                            {% endif %}
                        </div>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownUser">
                        <div class="dropdown-item">
                            <div class="d-flex">
                                <div class="avatar avatar-md avatar-indicators avatar-online">
                                    {% if app.user.photoProfilUrl %}
                                        <img alt="avatar" src="{{ app.user.photoProfilUrl }}" class="rounded-circle" />
                                    {% else %}
                                        <span class="avatar-img rounded-circle d-flex align-items-center justify-content-center bg-light text-secondary-emphasis position-relative" style="width:48px;height:48px;">
                                            <i class="bi bi-person fs-3 position-absolute top-50 start-50 translate-middle" style="opacity:0.5;"></i>
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="ms-3 lh-1">
                                    <h5 class="mb-1">{{ app.user.nom }} {{ app.user.prenom }}</h5>
                                    <p class="mb-0">{{ app.user.email }}</p>
                                </div>
                            </div>
                        </div>
                        <div class="dropdown-divider"></div>
                        <ul class="list-unstyled">
                            <li>
                                <a class="dropdown-item" href="{{ path('app_user_show', {'id': app.user.id}) }}">
                                    <i class="fe fe-user me-2"></i>
                                    Profil
                                </a>
                            </li>   
                        </ul>
                        <div class="dropdown-divider"></div>
                        <ul class="list-unstyled">
                            <li>
                                <a class="dropdown-item" href="{{ path('app_logout') }}">
                                    <i class="fe fe-power me-2"></i>
                                    Se déconnecter
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>
            </ul>
        </div>
    </nav>

    <script>
        function clearNotifications(event) {
            event.preventDefault();
            event.stopPropagation();
            
            // Vider le contenu de la liste
            const listGroup = document.querySelector('.dropdown-menu-lg .list-group');
            if (listGroup) {
                listGroup.innerHTML = `
                    <li class="list-group-item text-center py-4 text-muted">
                        <i class="fe fe-inbox mb-2" style="font-size: 2rem; display: block;"></i>
                        <span>Aucune réclamation récente</span>
                    </li>
                `;
            }
            
            // Enlever le badge de notification
            const badgeDot = document.querySelector('.btn-icon.indicator .badge-dot');
            if (badgeDot) {
                badgeDot.remove();
            }
        }
    </script>