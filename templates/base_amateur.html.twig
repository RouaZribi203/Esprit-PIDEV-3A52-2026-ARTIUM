	<script src="{{ asset('assetsfront/vendor/dropzone/dist/min/dropzone.min.js') }}"></script>
	<script src="{{ asset('assetsfront/vendor/zuck.js/dist/zuck.min.js') }}"></script>
	<script src="{{ asset('assetsfront/js/zuck-stories.js') }}"></script>

	<script src="{{ asset('assetsfront/js/functions.js') }}"></script>
	<script src="{{ asset('js/confirm-modal.js') }}"></script>
	{{ importmap() }}


</body>

</html>