{% extends 'base_admin.html.twig' %}

{%block title %}{{ 'Réclamations'|trans }}{% endblock %}

{% import _self as ui %}

{% macro statut_badge(statut) %}
  {% set badge_class = statut == 'Traitée' ? 'bg-success' : (statut == 'En cours' ? 'bg-info' : 'bg-warning') %}
  <span class="badge-dot {{ badge_class }} me-1 d-inline-block align-middle"></span>
  {{ statut }}
{% endmacro %}

{% macro reclamations_table(reclamations, typeFilter) %}
  <div class="table-responsive">
    <table class="table mb-0 text-nowrap table-centered table-hover table-with-checkbox">
      <thead class="table-light">
        <tr>
          <th>
            <div class="form-check">
              <input type="checkbox" class="form-check-input" />
              <label class="form-check-label"></label>
            </div>
          </th>
          <th>Texte</th>
          <th>Date envoi</th>
          <th>Utilisateur</th>
          <th>Type</th>
          <th>Statut</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% set hasRows = false %}
        {% for reclamation in reclamations %}
          {% if typeFilter is null or (reclamation.type and reclamation.type.value == typeFilter) %}
            {% set hasRows = true %}
            <tr>
              <td>
                <div class="form-check">
                  <input type="checkbox" class="form-check-input" id="reclam-{{ reclamation.id }}" />
                  <label class="form-check-label" for="reclam-{{ reclamation.id }}"></label>
                </div>
              </td>
              <td>
                {% if reclamation.texte|length > 60 %}
                  {{ reclamation.texte|slice(0, 60) ~ '...' }}
                {% else %}
                  {{ reclamation.texte }}
                {% endif %}
              </td>
              <td>{{ reclamation.dateCreation ? reclamation.dateCreation|date('d/m/Y') : '-' }}</td>
              <td>
                {% if reclamation.user %}
                  <div class="d-flex flex-column">
                    <span class="fw-semibold">{{ reclamation.user.prenom }} {{ reclamation.user.nom }}</span>
                    <span class="text-muted small">{{ reclamation.user.email }}</span>
                  </div>
                {% else %}
                  <span class="text-muted">Utilisateur inconnu</span>
                {% endif %}
              </td>
              <td>{{ reclamation.type ? reclamation.type.value : '-' }}</td>
              <td>
                {% if reclamation.statut %}
                  {{ ui.statut_badge(reclamation.statut.value) }}
                {% else %}
                  <span class="text-muted">-</span>
                {% endif %}
              </td>
              <td>
                <span class="dropdown dropstart">
                  <a
                    class="btn-icon btn btn-ghost btn-sm rounded-circle"
                    href="#"
                    role="button"
                    id="reclamDropdown{{ reclamation.id }}"
                    data-bs-toggle="dropdown"
                    data-bs-offset="-20,20"
                    aria-expanded="false">
                    <i class="fe fe-more-vertical"></i>
                  </a>
                  <span class="dropdown-menu" aria-labelledby="reclamDropdown{{ reclamation.id }}">
                    <span class="dropdown-header">Actions</span>
                    <button
                      type="button"
                      class="dropdown-item"
                      data-bs-toggle="offcanvas"
                      data-bs-target="#offcanvasResponse-{{ reclamation.id }}"
                      aria-controls="offcanvasResponse-{{ reclamation.id }}">
                      <i class="fe fe-message-circle dropdown-item-icon"></i>
                      Repondre
                    </button>
                    <form method="post" action="{{ path('app_reclamation_delete', {'id': reclamation.id}) }}" onsubmit="return confirm('Supprimer cette reclamation ?');" style="display: inline;">
                      <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
                      <button class="dropdown-item text-danger" type="submit">
                        <i class="fe fe-trash dropdown-item-icon"></i>
                        Supprimer
                      </button>
                    </form>
                  </span>
                </span>
              </td>
            </tr>
            <tr>
              <td colspan="8" class="bg-light">
                {% if reclamation.reponses|length > 0 %}
                  <div class="d-flex flex-column gap-2">
                    {% for reponse in reclamation.reponses %}
                      <div class="border rounded p-2 bg-white">
                        <div class="d-flex justify-content-between align-items-start">
                          <div class="fw-semibold">
                            {{ reponse.userAdmin ? reponse.userAdmin.prenom ~ ' ' ~ reponse.userAdmin.nom : 'Admin' }}
                          </div>
                          <div class="text-muted small">
                            {{ reponse.dateReponse ? reponse.dateReponse|date('d/m/Y H:i') : '-' }}
                          </div>
                        </div>
                        <div class="mt-2">
                          {{ reponse.contenu }}
                        </div>
                      </div>
                    {% endfor %}
                  </div>
                {% else %}
                  <span class="text-muted">Aucune reponse.</span>
                {% endif %}
              </td>
            </tr>
          {% endif %}
        {% endfor %}
        {% if not hasRows %}
          <tr>
            <td colspan="7" class="text-center py-5">
              <i class="fe fe-inbox" style="font-size: 3rem; color: #ccc;"></i>
              <p class="text-muted mt-3 mb-0">Aucune réclamation trouvée</p>
            </td>
          </tr>
        {% endif %}
      </tbody>
    </table>
  </div>
{% endmacro %}

{% block admin_content %}
    <div class="row">
            <!-- Page Header -->
    <div class="col-lg-12 col-md-12 col-12">
              <div class="border-bottom pb-3 mb-3 d-flex align-items-center justify-content-between">
                <div class="d-flex flex-column gap-1">
                  <h1 class="mb-0 h1 fw-bold">Liste des réclamations</h1>
                  <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item">
                        <a href="{{ path('app_admin') }}">Tableau de Bord</a>
                      </li>
                      <li class="breadcrumb-item active" aria-current="page">Réclamations</li>
                    </ol>
                  </nav>
                </div>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-12 col-md-12 col-12">
              <!-- Card -->
              <div class="card rounded-3">
                <!-- Card Header -->
                <div class="card-header p-0">

                  <ul class="nav nav-lb-tab border-bottom-0" id="tab" role="tablist">
                    <li class="nav-item">
                      <a class="nav-link active" id="all-post-tab" data-bs-toggle="pill" href="#all-post" role="tab" aria-controls="all-post" aria-selected="true">Tous les types</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="published-tab" data-bs-toggle="pill" href="#published" role="tab" aria-controls="published" aria-selected="false">Paiement</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="scheduled-tab" data-bs-toggle="pill" href="#scheduled" role="tab" aria-controls="scheduled" aria-selected="false">Oeuvre</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="draft-tab" data-bs-toggle="pill" href="#draft" role="tab" aria-controls="draft" aria-selected="false">Evènement</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="deleted-tab" data-bs-toggle="pill" href="#deleted" role="tab" aria-controls="deleted" aria-selected="false">Compte</a>
                    </li>
                  </ul>
                </div>
                <div class="p-4 row">
                  <!-- Form -->
                <div class ="formbtn">
                  <form class="d-flex align-items-center col-12 col-md-8 col-lg-3" method="get" id="searchForm">
                    <span class="position-absolute ps-3 search-icon">
                      <i class="fe fe-search"></i>
                    </span>
                    <input type="search" name="q" id="searchInput" class="form-control ps-6" placeholder="Rechercher réclamation" value="{{ search_query|default('') }}" />
                  </form>
                  <div class="bouton_delete">
                  <a href="#" class="btn btn-primary">Supprimer tout</a>
                </div>
                </div>
                </div>
                
                <script>
                  (function() {
                    const searchForm = document.getElementById('searchForm');
                    const searchInput = document.getElementById('searchInput');
                    
                    if (searchForm && searchInput) {
                      let searchTimeout;
                      searchInput.addEventListener('input', function() {
                        clearTimeout(searchTimeout);
                        searchTimeout = setTimeout(function() {
                          searchForm.submit();
                        }, 500);
                      });
                    }
                  })();
                </script>
                
                <div>
                  <div class="tab-content" id="tabContent">
                    <div class="tab-pane fade show active" id="all-post" role="tabpanel" aria-labelledby="all-post-tab">
                      {{ ui.reclamations_table(reclamations, null) }}
                    </div>
                    <div class="tab-pane fade" id="published" role="tabpanel" aria-labelledby="published-tab">
                      {{ ui.reclamations_table(reclamations, 'Paiement') }}
                    </div>
                    <div class="tab-pane fade" id="scheduled" role="tabpanel" aria-labelledby="scheduled-tab">
                      {{ ui.reclamations_table(reclamations, 'Oeuvre') }}
                    </div>
                    <div class="tab-pane fade" id="draft" role="tabpanel" aria-labelledby="draft-tab">
                      {{ ui.reclamations_table(reclamations, 'Evènement') }}
                    </div>
                    <div class="tab-pane fade" id="deleted" role="tabpanel" aria-labelledby="deleted-tab">
                      {{ ui.reclamations_table(reclamations, 'Compte') }}
                    </div>
                  </div>
                </div>
                {% for reclamation in reclamations %}
                  <div
                    class="offcanvas offcanvas-end"
                    tabindex="-1"
                    id="offcanvasResponse-{{ reclamation.id }}"
                    data-bs-backdrop="false"
                    data-bs-scroll="true"
                    style="width: 600px; z-index: 2000;">
                    <div class="offcanvas-body" data-simplebar>
                      <div class="offcanvas-header px-2 pt-0">
                        <h3 class="offcanvas-title">Repondre a la reclamation #{{ reclamation.id }}</h3>
                        <button
                          type="button"
                          class="btn-close text-reset"
                          data-bs-dismiss="offcanvas"
                          aria-label="Close"></button>
                      </div>
                      <div class="container">
                        {% if responseCreateForms[reclamation.id] is defined %}
                          {{ form_start(responseCreateForms[reclamation.id], {
                            attr: { class: 'row g-3', 'data-turbo': 'false' },
                            action: path('app_reponse_admin_create', { id: reclamation.id }),
                            method: 'POST'
                          }) }}
                          <div class="col-12">
                            {{ form_errors(responseCreateForms[reclamation.id]) }}
                          </div>
                          <div class="col-12">
                            {{ form_row(responseCreateForms[reclamation.id].contenu) }}
                          </div>
                          <div class="col-12">
                            <div class="alert alert-info mb-0">
                              <i class="fe fe-info me-2"></i>
                              <small>Le statut de la reclamation passera automatiquement à "Traitée" après votre réponse.</small>
                            </div>
                          </div>
                          <div class="col-12 d-flex gap-2">
                            <button class="btn btn-primary" type="submit">Enregistrer</button>
                            <button
                              type="button"
                              class="btn btn-outline-primary"
                              data-bs-dismiss="offcanvas"
                              aria-label="Close">Fermer</button>
                          </div>
                          {{ form_end(responseCreateForms[reclamation.id]) }}
                        {% else %}
                          <p class="text-muted">Formulaire indisponible.</p>
                        {% endif %}

                        <div class="mt-4">
                          <h5 class="mb-3">Reponses existantes</h5>
                          {% if reclamation.reponses|length > 0 %}
                            {% for reponse in reclamation.reponses %}
                              <div class="border rounded p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start">
                                  <div>
                                    <div class="fw-semibold">
                                      {{ reponse.userAdmin ? reponse.userAdmin.prenom ~ ' ' ~ reponse.userAdmin.nom : 'Admin' }}
                                    </div>
                                    <div class="text-muted small">
                                      {{ reponse.dateReponse ? reponse.dateReponse|date('d/m/Y H:i') : '-' }}
                                    </div>
                                  </div>
                                  <form
                                    method="post"
                                    action="{{ path('app_reponse_admin_delete', {id: reponse.id}) }}"
                                    onsubmit="return confirm('Supprimer cette reponse ?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_response' ~ reponse.id) }}" />
                                    <button class="btn btn-sm btn-outline-danger" type="submit">Supprimer</button>
                                  </form>
                                </div>
                                <div class="mt-3">
                                  {% if responseEditForms[reponse.id] is defined %}
                                    {{ form_start(responseEditForms[reponse.id], {
                                      attr: { class: 'row g-3', 'data-turbo': 'false' },
                                      action: path('app_reponse_admin_edit', { id: reponse.id }),
                                      method: 'POST'
                                    }) }}
                                    <div class="col-12">
                                      {{ form_errors(responseEditForms[reponse.id]) }}
                                    </div>
                                    <div class="col-12">
                                      {{ form_row(responseEditForms[reponse.id].contenu) }}
                                    </div>
                                    <div class="col-12 d-flex gap-2">
                                      <button class="btn btn-outline-primary" type="submit">Mettre a jour</button>
                                    </div>
                                    {{ form_end(responseEditForms[reponse.id]) }}
                                  {% else %}
                                    <p class="text-muted mb-0">Formulaire indisponible.</p>
                                  {% endif %}
                                </div>
                              </div>
                            {% endfor %}
                          {% else %}
                            <p class="text-muted">Aucune reponse pour le moment.</p>
                          {% endif %}
                        </div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
                <!-- Card Footer -->
                <div class="card-footer">
                  <nav>
                    <ul class="pagination justify-content-center mb-0">
                      <li class="page-item disabled">
                        <a class="page-link mx-1 rounded" href="#" tabindex="-1" aria-disabled="true">
                          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" class="bi bi-chevron-left" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z"></path>
                          </svg>
                        </a>
                      </li>
                      <li class="page-item active">
                        <a class="page-link mx-1 rounded" href="#">1</a>
                      </li>
                      <li class="page-item">
                        <a class="page-link mx-1 rounded" href="#">2</a>
                      </li>
                      <li class="page-item">
                        <a class="page-link mx-1 rounded" href="#">3</a>
                      </li>
                      <li class="page-item">
                        <a class="page-link mx-1 rounded" href="#">
                          <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" class="bi bi-chevron-right" viewBox="0 0 16 16">
                            <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z"></path>
                          </svg>
                        </a>
                      </li>
                    </ul>
                  </nav>
                </div>
              </div>
            </div>
          </div>
    </div>
    
{% endblock %}