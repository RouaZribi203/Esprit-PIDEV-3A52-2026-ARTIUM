{% extends 'base_artiste.html.twig' %}

{% block title %}{{ 'Musiques'|trans }}{% endblock %}

{% block artiste_content %}
<!-- Flash messages -->
{% for message in app.flashes('success') %}
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ message }}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
{% endfor %}

{% for message in app.flashes('error') %}
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ message }}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
{% endfor %}

<!-- Header with title and upload button START -->
<div class="card">
  <div class="card-header d-sm-flex align-items-center text-center justify-content-sm-between border-0 pb-0">
    <h1 class="h4 card-title">My Music</h1>
    <button type="button" class="btn btn-primary-soft" data-bs-toggle="offcanvas" data-bs-target="#offcanvasAddMusic">
      <i class="bi bi-plus-circle pe-2"></i>Add Music
    </button>
  </div>
  <!-- Card body START -->
  <div class="card-body">
    {% if musiques is empty %}
      <!-- No music message START -->
      <div class="text-center py-5">
        <i class="bi bi-music-note-beamed display-1 text-muted"></i>
        <h5 class="mt-3">No music yet</h5>
        <p class="text-muted">Start by uploading your first music piece!</p>
      </div>
      <!-- No music message END -->
    {% else %}
      <!-- Music grid START -->
      <div class="row g-4">
        {% for musique in musiques %}
          <!-- Music item START -->
          <div class="col-sm-6 col-xl-4">
            <div class="card h-100 music-card" 
                 data-music-id="{{ musique.id }}" 
                 data-audio-src="{{ path('app_musiqueartiste_audio', {'id': musique.id}) }}">
              <!-- Image with genre badge -->
              <div class="position-relative">
                <img class="img-fluid rounded-top lazy-image" 
                     data-src="{{ path('app_musiqueartiste_image', {'id': musique.id}) }}" 
                     src="{{ asset('assetsfront/images/avatar/04.jpg') }}" 
                     alt="{{ musique.titre }}">
                <div class="badge bg-primary text-white mt-2 me-2 position-absolute top-0 end-0">
                  {{ musique.genre }}
                </div>
              </div>
              
              <!-- Card body START -->
              <div class="card-body position-relative pt-0">
                <!-- Genre tag -->
                <a class="btn btn-xs btn-primary mt-n3" href="#">{{ musique.genre }}</a>
                
                <!-- Music title -->
                <h6 class="mt-3"> 
                  <a href="#!"> {{ musique.titre }} </a> 
                </h6>
                
                <!-- Description -->
                <p class="mb-2 small text-muted">
                  {{ musique.description|length > 50 ? musique.description|slice(0, 50) ~ '...' : musique.description }}
                </p>
                
                <!-- Date -->
                <p class="small"> 
                  <i class="bi bi-calendar pe-1"></i> 
                  {{ musique.date_creation|date('Y-m-d') }} 
                </p>
                
                <!-- Like and action buttons -->
                <div class="d-flex mt-3 gap-2">
                  <button class="btn btn-sm btn-primary flex-grow-1 play-btn">
                    <i class="bi bi-play-fill pe-1"></i> Play
                  </button>
                  <button class="btn btn-sm btn-outline-primary" title="Add to favorites">
                    <i class="bi bi-heart"></i>
                  </button>
                  <!-- More options dropdown -->
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-primary" type="button" id="dropdownMenu{{ musique.id }}" data-bs-toggle="dropdown" aria-expanded="false">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenu{{ musique.id }}">
                      <li>
                        <a class="dropdown-item edit-music-btn" href="#" 
                           data-music-id="{{ musique.id }}"
                           data-music-title="{{ musique.titre }}"
                           data-music-description="{{ musique.description }}"
                           data-music-genre="{{ musique.genre }}"
                           data-bs-toggle="offcanvas" 
                           data-bs-target="#offcanvasEditMusic">
                          <i class="bi bi-pencil pe-2"></i>Edit
                        </a>
                      </li>
                      <li>
                        <form method="post" action="{{ path('app_musiqueartiste_delete', {'id': musique.id}) }}" 
                              style="display: inline;">
                          <button type="submit" class="dropdown-item text-danger" style="border: none; background: none; cursor: pointer; width: 100%; text-align: left;">
                            <i class="bi bi-trash pe-2"></i>Delete
                          </button>
                        </form>
                      </li>
                      <li><a class="dropdown-item" href="#"> <i class="bi bi-share pe-2"></i>Share</a></li>
                    </ul>
                  </div>
                </div>
                
                <!-- Progress bar -->
                <div class="mt-3">
                  <div class="progress music-progress-container" style="height: 5px; cursor: pointer;" role="button" tabindex="0">
                    <div class="progress-bar bg-primary music-progress" role="progressbar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                  <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                    <span class="current-time">0:00</span>
                    <span class="total-time">0:00</span>
                  </div>
                </div>
                
                <!-- Stats -->
                <div class="d-flex justify-content-between align-items-center mt-3 small text-muted">
                  <span><i class="bi bi-hand-thumbs-up pe-1"></i>0</span>
                  <span><i class="bi bi-chat-dots pe-1"></i>0</span>
                  <span><i class="bi bi-collection-play pe-1"></i>0</span>
                </div>
              </div>
              <!-- Card body END -->
            </div>
          </div>
          <!-- Music item END -->
        {% endfor %}
      </div>
      <!-- Music grid END -->
    {% endif %}
  </div>
  <!-- Card body END -->
</div>
<!-- Header and music grid END -->

<!-- Offcanvas Add Music Form START -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasAddMusic" style="width: 600px">
  <div class="offcanvas-body" data-simplebar>
    <div class="offcanvas-header px-2 pt-0">
      <h3 class="offcanvas-title" id="offcanvasAddMusicLabel">Add New Music</h3>
      <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <!-- Form body -->
    <div class="container">
      {{ form_start(form, {'attr': {'class': 'row needs-validation', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
        
        <!-- Display form errors at the top -->
        {% if form.vars.errors|length > 0 %}
          <div class="col-12 mb-3">
            <div class="alert alert-danger">
              <strong>Please fix the following errors:</strong>
              <ul class="mb-0 mt-2">
                {% for error in form.vars.errors %}
                  <li>{{ error.message }}</li>
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endif %}

        <!-- Title -->
        <div class="mb-3 col-12">
          {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.titre) }}
          {{ form_errors(form.titre) }}
        </div>

        <!-- Description -->
        <div class="mb-3 col-12">
          {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.description) }}
          {{ form_errors(form.description) }}
        </div>

        <!-- Genre -->
        <div class="mb-3 col-12">
          {{ form_label(form.genre, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.genre) }}
          {{ form_errors(form.genre) }}
        </div>

        <!-- Cover Image -->
        <div class="mb-3 col-12">
          <h5 class="mb-3">{{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label'}}) }}</h5>
          <div class="icon-shape icon-xxl border rounded position-relative">
            <span class="position-absolute"><i class="bi bi-image fs-3"></i></span>
            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control border-0 opacity-0'}}) }}
          </div>
          {{ form_errors(form.imageFile) }}
          <small class="text-muted">Max 5MB (JPEG, PNG)</small>
        </div>

        <!-- Audio File -->
        <div class="mb-3 col-12">
          <h5 class="mb-3">{{ form_label(form.audioFile, null, {'label_attr': {'class': 'form-label'}}) }}</h5>
          <span class="text-danger">*</span>
          <div class="icon-shape icon-xxl border rounded position-relative">
            <span class="position-absolute"><i class="bi bi-music-note-beamed fs-3"></i></span>
            {{ form_widget(form.audioFile, {'attr': {'class': 'form-control border-0 opacity-0'}}) }}
          </div>
          {{ form_errors(form.audioFile) }}
          <small class="text-muted">Max 20MB (MP3, WAV, AAC, OPUS, OGG, FLAC, M4A)</small>
        </div>

        <!-- Buttons -->
        <div class="col-12">
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-upload pe-2"></i>Upload Music
          </button>
          <button type="button" class="btn btn-outline-primary ms-2" data-bs-dismiss="offcanvas" aria-label="Close">Cancel</button>
        </div>

      {{ form_end(form) }}
    </div>
  </div>
</div>
<!-- Offcanvas Add Music Form END -->

<!-- Offcanvas Edit Music Form START -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasEditMusic" style="width: 600px">
  <div class="offcanvas-body" data-simplebar>
    <div class="offcanvas-header px-2 pt-0">
      <h3 class="offcanvas-title">Edit Music</h3>
      <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <!-- Form body -->
    <div class="container">
      <form method="post" id="editMusicForm" enctype="multipart/form-data" class="row needs-validation" novalidate>
        <input type="hidden" id="editMusicId" name="musicId">
        
        <!-- Title -->
        <div class="mb-3 col-12">
          <label for="editTitre" class="form-label">Title</label>
          <span class="text-danger">*</span>
          <input type="text" class="form-control" id="editTitre" name="titre" required>
        </div>

        <!-- Description -->
        <div class="mb-3 col-12">
          <label for="editDescription" class="form-label">Description</label>
          <span class="text-danger">*</span>
          <textarea class="form-control" id="editDescription" name="description" rows="3" required></textarea>
        </div>

        <!-- Genre -->
        <div class="mb-3 col-12">
          <label for="editGenre" class="form-label">Genre</label>
          <span class="text-danger">*</span>
          <select class="form-select" id="editGenre" name="genre" required>
            <option value="">Select genre</option>
            <option value="Rock">Rock</option>
            <option value="Jazz">Jazz</option>
            <option value="Classique">Classique</option>
            <option value="Pop">Pop</option>
          </select>
        </div>

        <!-- Cover Image -->
        <div class="mb-3 col-12">
          <h5 class="mb-3">Update Cover Image (optional)</h5>
          <div class="icon-shape icon-xxl border rounded position-relative">
            <span class="position-absolute"><i class="bi bi-image fs-3"></i></span>
            <input type="file" class="form-control border-0 opacity-0" name="imageFile" accept="image/*">
          </div>
          <small class="text-muted">Leave empty to keep current image. Max 5MB (JPEG, PNG)</small>
        </div>

        <!-- Buttons -->
        <div class="col-12">
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-check-circle pe-2"></i>Update Music
          </button>
          <button type="button" class="btn btn-outline-primary ms-2" data-bs-dismiss="offcanvas" aria-label="Close">Cancel</button>
        </div>
      </form>
    </div>
  </div>
</div>
<!-- Offcanvas Edit Music Form END -->

<!-- Audio element for playback -->
<audio id="audioPlayer" style="display: none;"></audio>

<script>
// Dynamic Music Player System - Works for any number of songs
(function() {
  'use strict';
  
  // State management
  const MusicPlayer = {
    audio: document.getElementById('audioPlayer'),
    currentCard: null,
    
    // Utility: Format time in MM:SS
    formatTime(seconds) {
      if (!seconds || isNaN(seconds) || !isFinite(seconds)) return '0:00';
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${mins}:${secs.toString().padStart(2, '0')}`;
    },
    
    // Get card elements
    getCardElements(card) {
      return {
        playBtn: card.querySelector('.play-btn'),
        progressBar: card.querySelector('.music-progress'),
        progressContainer: card.querySelector('.music-progress-container'),
        currentTime: card.querySelector('.current-time'),
        totalTime: card.querySelector('.total-time')
      };
    },
    
    // Update button state
    updateButton(button, isPlaying) {
      const icon = button.querySelector('i');
      if (isPlaying) {
        icon.className = 'bi bi-pause-fill pe-1';
        button.innerHTML = '';
        button.appendChild(icon);
        button.appendChild(document.createTextNode(' Pause'));
      } else {
        icon.className = 'bi bi-play-fill pe-1';
        button.innerHTML = '';
        button.appendChild(icon);
        button.appendChild(document.createTextNode(' Play'));
      }
    },
    
    // Reset card display
    resetCard(card) {
      const elements = this.getCardElements(card);
      this.updateButton(elements.playBtn, false);
      elements.progressBar.style.width = '0%';
      elements.progressBar.setAttribute('aria-valuenow', '0');
      elements.currentTime.textContent = '0:00';
    },
    
    // Load and play a song
    loadAndPlay(card, seekPercent = 0) {
      const audioSrc = card.dataset.audioSrc;
      const musicId = card.dataset.musicId;
      const elements = this.getCardElements(card);
      
      // If switching songs, reset the previous one
      if (this.currentCard && this.currentCard !== card) {
        this.resetCard(this.currentCard);
      }
      
      // Set current card BEFORE loading (so events can reference it)
      this.currentCard = card;
      
      // Load new audio if different source
      if (this.audio.src !== audioSrc && audioSrc) {
        this.audio.src = audioSrc;
        this.audio.load();
        
        // Seek once metadata is loaded
        if (seekPercent > 0) {
          this.audio.addEventListener('loadedmetadata', function seekHandler() {
            MusicPlayer.audio.currentTime = seekPercent * MusicPlayer.audio.duration;
            MusicPlayer.audio.removeEventListener('loadedmetadata', seekHandler);
          });
        }
      } else if (seekPercent > 0) {
        // Same audio, just seek
        this.audio.currentTime = seekPercent * this.audio.duration;
      }
      
      // Play audio
      this.audio.play().catch(err => console.warn('Playback failed:', err));
      this.updateButton(elements.playBtn, true);
    },
    
    // Toggle play/pause for a card
    togglePlayPause(card) {
      const elements = this.getCardElements(card);
      
      // If this is a different song or no song is loaded
      if (this.currentCard !== card) {
        this.loadAndPlay(card);
        return;
      }
      
      // Same song - toggle play/pause
      if (this.audio.paused) {
        this.audio.play();
        this.updateButton(elements.playBtn, true);
      } else {
        this.audio.pause();
        this.updateButton(elements.playBtn, false);
      }
    },
    
    // Seek to position in song
    seekTo(card, percent) {
      // If clicking on a different song's progress bar, load and play from that position
      if (this.currentCard !== card) {
        this.loadAndPlay(card, percent);
      } else if (this.audio.duration && isFinite(this.audio.duration)) {
        // Same song - just seek
        this.audio.currentTime = percent * this.audio.duration;
      }
    },
    
    // Initialize audio event listeners
    initAudioEvents() {
      // Update display when metadata loads
      this.audio.addEventListener('loadedmetadata', () => {
        if (this.currentCard && this.audio.duration && isFinite(this.audio.duration)) {
          const elements = this.getCardElements(this.currentCard);
          elements.totalTime.textContent = this.formatTime(this.audio.duration);
        }
      });
      
      // Update progress bar as song plays
      this.audio.addEventListener('timeupdate', () => {
        if (this.currentCard && this.audio.duration && isFinite(this.audio.duration)) {
          const elements = this.getCardElements(this.currentCard);
          const percentage = (this.audio.currentTime / this.audio.duration) * 100;
          elements.progressBar.style.width = percentage + '%';
          elements.progressBar.setAttribute('aria-valuenow', Math.round(percentage));
          elements.currentTime.textContent = this.formatTime(this.audio.currentTime);
        }
      });
      
      // Reset when song ends
      this.audio.addEventListener('ended', () => {
        if (this.currentCard) {
          this.resetCard(this.currentCard);
          this.currentCard = null;
        }
      });
    },
    
    // Initialize event delegation for all music cards
    initCardEvents() {
      document.addEventListener('click', (e) => {
        // Handle play button clicks
        const playBtn = e.target.closest('.play-btn');
        if (playBtn) {
          const card = playBtn.closest('.music-card');
          if (card) {
            e.preventDefault();
            this.togglePlayPause(card);
          }
          return;
        }
        
        // Handle progress bar clicks for seeking
        const progressContainer = e.target.closest('.music-progress-container');
        if (progressContainer) {
          const card = progressContainer.closest('.music-card');
          if (card) {
            const rect = progressContainer.getBoundingClientRect();
            const percent = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            this.seekTo(card, percent);
          }
        }
      });
      
      // Keyboard accessibility for progress bars
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          const progressContainer = e.target.closest('.music-progress-container');
          if (progressContainer) {
            e.preventDefault();
            const card = progressContainer.closest('.music-card');
            if (card) {
              this.seekTo(card, 0.5); // Seek to middle
            }
          }
        }
      });
    },
    
    // Initialize lazy loading for images
    initLazyLoading() {
      const imageObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target;
            if (img.dataset.src) {
              img.src = img.dataset.src;
              img.removeAttribute('data-src');
              imageObserver.unobserve(img);
            }
          }
        });
      });
      
      document.querySelectorAll('.lazy-image').forEach(img => {
        imageObserver.observe(img);
      });
    },
    
    // Initialize everything
    init() {
      this.initAudioEvents();
      this.initCardEvents();
      this.initLazyLoading();
    }
  };
  
  // Start the music player when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => MusicPlayer.init());
  } else {
    MusicPlayer.init();
  }
})();

// Edit Music Form Handler
document.addEventListener('click', function(e) {
  const editBtn = e.target.closest('.edit-music-btn');
  if (editBtn) {
    e.preventDefault();
    
    // Get music data from button attributes
    const musicId = editBtn.dataset.musicId;
    const title = editBtn.dataset.musicTitle;
    const description = editBtn.dataset.musicDescription;
    const genre = editBtn.dataset.musicGenre;
    
    // Populate form fields
    document.getElementById('editMusicId').value = musicId;
    document.getElementById('editTitre').value = title;
    document.getElementById('editDescription').value = description;
    document.getElementById('editGenre').value = genre;
    
    // Update form action
    const form = document.getElementById('editMusicForm');
    form.action = '{{ path('app_musiqueartiste_edit', {'id': '__ID__'}) }}'.replace('__ID__', musicId);
  }
});
</script>
{% endblock %}
