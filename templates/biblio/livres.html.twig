                  <div class="tab-content" id="tabContent">
                    <!-- Tab -->
                    <div class="tab-pane fade show active" id="all-post" role="tabpanel" aria-labelledby="all-post-tab">
                      <div class="table-responsive">
                        <!-- Table -->
                        <table class="table mb-0 text-nowrap table-centered table-hover table-with-checkbox table-centered table-hover">
                          <!-- Table Head -->
                          <thead class="table-light">
                            <tr>
                              <th>
                                <div class="form-check">
                                  <input type="checkbox" class="form-check-input" id="checkAll" />
                                  <label class="form-check-label" for="checkAll"></label>
                                </div>
                              </th>
                              <th>Titre</th>
                              <th>image</th>
                              <th>categorie</th>
                              <th>prix location</th>
                              <th>Artist</th>
                              <th>status</th>
                              <th></th>
                            </tr>
                          </thead>
                          <tbody>
                            {% for livre in livres %}
                            <tr>
                              <td>
                                <div class="form-check">
                                  <input type="checkbox" class="form-check-input" id="post{{ loop.index }}" />
                                  <label class="form-check-label" for="post{{ loop.index }}"></label>
                                </div>
                              </td>
                              <td>
                                <h5 class="mb-0">
                                  <a href="#" class="text-inherit">{{ livre.titre }}</a>
                                </h5>
                              </td>
                              <td>
                                {% if livre.image %}
                                    <img src="{{ path('livre_image', {'id': livre.id}) }}" alt="{{ livre.titre }}" class="book-thumb" style="width:64px;height:96px;object-fit:cover;border-radius:6px;" />
                                  {% else %}
                                    <i class="fe fe-image text-primary fs-4"></i>
                                  {% endif %}
                              </td>
                              <td>
                                <a href="#" class="text-inherit">{{ livre.categorie }}</a>
                              </td>
                              <td>{{ livre.prixLocation }}</td>
                              <td>
                                {% if livre.collection and livre.collection.artiste %}
                                  {{ livre.collection.artiste.nom }}
                                {% else %}
                                  -
                                {% endif %}
                              </td>
                              <td>
                                {% set isActive = false %}
                                {% for loc in livre.locationLivres %}
                                  {% if loc.etat.value == 'Active' %}
                                    {% set isActive = true %}
                                  {% endif %}
                                {% endfor %}
                                {% if isActive %}
                                  <span class="badge bg-success">Loué</span>
                                {% else %}
                                  <span class="badge bg-secondary">Non loué</span>
                                {% endif %}
                              </td>
                              <td>
                                <span class="dropdown dropstart">
                                  <a class="btn-icon btn btn-ghost btn-sm rounded-circle" href="#" role="button" id="courseDropdown{{ loop.index }}" data-bs-toggle="dropdown" data-bs-offset="-20,20" aria-expanded="false">
                                    <i class="fe fe-more-vertical"></i>
                                  </a>
                                  <span class="dropdown-menu" aria-labelledby="courseDropdown{{ loop.index }}">
                                    <span class="dropdown-header">Paramètres</span>
                                      {# compute active location id/date and stats for data attributes #}
                                      {% set activeId = '' %}
                                      {% set activeDate = '' %}
                                      {% for loc in livre.locationLivres %}
                                        {% if loc.etat.value == 'Active' and activeId == '' %}
                                          {% set activeId = loc.id %}
                                          {% set activeDate = loc.dateDebut ? loc.dateDebut|date('Y-m-d') : '' %}
                                        {% endif %}
                                      {% endfor %}
                                      {% set locationCount = livre.locationLivres|length %}
                                      {% set totalRevenue = (locationCount * 7 * (livre.prixLocation ?: 0)) %}
                                      <a class="dropdown-item js-show-details" href="#"
                                         data-id="{{ livre.id }}"
                                         data-titre="{{ livre.titre|e('html_attr') }}"
                                         data-date-creation="{{ livre.dateCreation ? livre.dateCreation|date('Y-m-d H:i:s') : '' }}"
                                         data-description="{{ (livre.description is not empty) ? livre.description|e('html_attr') : '' }}"
                                         data-pdf-url="{{ livre.fichierPdf ? path('livre_pdf', {'id': livre.id})|e('html_attr') : '' }}"
                                         data-image="{{ (livre.image is defined and livre.image) ? (path('livre_image', {'id': livre.id})|e('html_attr')) : '' }}"
                                         data-active-id="{{ activeId }}"
                                         data-active-date="{{ activeDate }}"
                                         data-location-count="{{ locationCount }}"
                                         data-total-revenue="{{ '%.2f'|format(totalRevenue) }}"
                                      >
                                        <i class="fe fe-eye dropdown-item-icon"></i>
                                        Détails
                                      </a>
                                        <a class="dropdown-item js-edit-livre" href="#"
                                           data-id="{{ livre.id }}"
                                           data-titre="{{ livre.titre|e('html_attr') }}"
                                           data-description="{{ (livre.description is not empty) ? livre.description|e('html_attr') : '' }}"
                                           data-categorie="{{ livre.categorie is not empty ? livre.categorie|e('html_attr') : '' }}"
                                           data-prix="{{ livre.prixLocation is not empty ? livre.prixLocation : '' }}"
                                           data-collection="{{ livre.collection ? livre.collection.id : '' }}"
                                           data-edit-url-template="{{ path('livre_edit', {'id': 0}) }}"
                                           data-bs-toggle="offcanvas"
                                           data-bs-target="#offcanvasEditLivre"
                                           aria-controls="offcanvasEditLivre"
                                        >
                                          <i class="fe fe-edit dropdown-item-icon"></i>
                                          Modifier
                                        </a>
                                    <a class="dropdown-item js-delete-livre" href="#"
                                       data-id="{{ livre.id }}"
                                       data-delete-url-template="{{ path('livre_delete', {'id': 0}) }}"
                                    >
                                      <i class="fe fe-trash dropdown-item-icon"></i>
                                      Supprimer
                                    </a>
                                  </span>
                                </span>
                              </td>
                            </tr>
                            {% else %}
                            <tr>
                              <td colspan="8">Aucun livre trouvé.</td>
                            </tr>
                            {% endfor %}
                          </tbody>
                        </table>
