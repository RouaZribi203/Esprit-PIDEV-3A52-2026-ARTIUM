{% extends 'base_admin.html.twig' %}

{%block title %}{{ 'Biobliotheque'|trans }}{% endblock %}

{% block admin_content %}
    <div class="row">
            <!-- Page Header -->
            <div class="col-lg-12 col-md-12 col-12">
              <div class="border-bottom pb-3 mb-3 d-flex align-items-center justify-content-between">
                <div class="d-flex flex-column gap-1">
                  <h1 class="mb-0 h1 fw-bold">Biobliothèque</h1>
                  <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item">
                        <a href="{{ path('app_admin') }}">Tableau de Bord</a>
                      </li>
                      <li class="breadcrumb-item active" aria-current="page">Biobliothèque</li>
                    </ol>
                  </nav>
                </div>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-12 col-md-12 col-12">
              <!-- Card -->
              <div class="card rounded-3">
                <!-- Card Header -->
                <div class="card-header p-0">
                  <ul class="nav nav-lb-tab border-bottom-0" id="tab" role="tablist">
                    <li class="nav-item">
                      <a class="nav-link active" id="all-post-tab" data-bs-toggle="pill" href="#all-post" role="tab" aria-controls="all-post" aria-selected="true">Tout les genres</a>
                    </li>
                  </ul>
                </div>
                <div class="p-4 row">
                  <!-- Form -->
                <div class ="formbtn">
                  <form method="get" class="d-flex align-items-center gap-2" id="livreSearchForm">
                    <span class="position-absolute ps-3 search-icon">
                      <i class="fe fe-search"></i>
                    </span>
                    <input type="search" name="q" class="form-control ps-6 me-2 flex-grow-1" placeholder="Rechercher livre" value="{{ search_q|default('') }}" />
                    <select name="sort" class="form-select form-select-sm w-auto ms-1" aria-label="Trier" onchange="document.getElementById('livreSearchForm').submit()">
                      <option value="">Trier</option>
                      <option value="price_asc" {{ search_sort == 'price_asc' ? 'selected' : '' }}>Prix croissant</option>
                      <option value="price_desc" {{ search_sort == 'price_desc' ? 'selected' : '' }}>Prix décroissant</option>
                      <option value="date_desc" {{ (search_sort == 'date_desc' or search_sort is empty) ? 'selected' : '' }}>Date création récente</option>
                      <option value="date_asc" {{ search_sort == 'date_asc' ? 'selected' : '' }}>Date création ancienne</option>
                    </select>
                    <button type="submit" class="btn btn-outline-primary ms-1 btn-sm">OK</button>
                  </form>
                  <div class="bouton_delete">
                  <a href="#" class="btn btn-primary">Supprimer tout</a>
                  <button class="btn btn-success ms-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasAddLivre" aria-controls="offcanvasAddLivre">Ajouter Livre</button>
                </div>

                <!-- Offcanvas: Ajouter Livre -->
                <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasAddLivre" aria-labelledby="offcanvasAddLivreLabel">
                  <div class="offcanvas-header">
                    <h5 id="offcanvasAddLivreLabel">Ajouter Livre</h5>
                    <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                  </div>
                  <div class="offcanvas-body">
                    {{ form_start(livreForm, {'action': path('livre_create')}) }}
                      <div class="mb-3">
                        {{ form_row(livreForm.titre) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreForm.description) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreForm.image) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreForm.categorie) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreForm.prix_location) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreForm.fichier_pdf) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreForm.collection) }}
                      </div>
                      <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn btn-primary">Create</button>
                      </div>
                    {{ form_end(livreForm) }}
                  </div>
                </div>

                <!-- Offcanvas: Modifier Livre -->
                <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasEditLivre" aria-labelledby="offcanvasEditLivreLabel">
                  <div class="offcanvas-header">
                    <h5 id="offcanvasEditLivreLabel">Modifier Livre</h5>
                    <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                  </div>
                  <div class="offcanvas-body">
                    {# render an empty form view and populate client-side #}
                    {{ form_start(livreEditForm, {'action': '#', 'attr': {'id': 'editLivreForm', 'enctype': 'multipart/form-data'}}) }}
                      <div class="mb-3">
                        {{ form_row(livreEditForm.titre) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreEditForm.description) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreEditForm.image) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreEditForm.categorie) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreEditForm.prix_location) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreEditForm.fichier_pdf) }}
                      </div>
                      <div class="mb-3">
                        {{ form_row(livreEditForm.collection) }}
                      </div>
                      <div class="d-flex justify-content-end mt-3">
                        <button type="submit" class="btn btn-primary">Mettre à jour</button>
                      </div>
                    {{ form_end(livreEditForm) }}
                  </div>
                </div>
                </div>
                </div>
