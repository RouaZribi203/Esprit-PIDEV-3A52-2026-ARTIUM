<script>
document.addEventListener('click', function (event) {
	const commentsBtn = event.target.closest('.fav-comments-load-more');
	if (commentsBtn) {
		event.preventDefault();

		if (commentsBtn.classList.contains('active')) {
			return;
		}

		commentsBtn.classList.add('active');
		const loader = commentsBtn.querySelector('.comments-loader');
		const text = commentsBtn.querySelector('.comments-load-text');
		if (loader) {
			loader.style.display = 'inline-flex';
		}
		if (text) {
			text.textContent = 'Chargement...';
		}

		setTimeout(() => {
			const scope = commentsBtn.closest('.fav-comments-container')
				|| commentsBtn.closest('.glightbox-desc')
				|| commentsBtn.closest('.gdesc-inner');
			if (!scope) {
				commentsBtn.classList.remove('active');
				if (loader) {
					loader.style.display = 'none';
				}
				if (text) {
					text.textContent = 'Voir plus de commentaires';
				}
				return;
			}

			const hiddenComments = Array.from(scope.querySelectorAll('.comment-item.hidden-comment.d-none'));
			hiddenComments.forEach((comment) => {
				comment.classList.remove('d-none');
			});

			const remaining = scope.querySelectorAll('.comment-item.hidden-comment.d-none').length;
			if (remaining === 0) {
				commentsBtn.remove();
				return;
			} else if (text) {
				text.textContent = 'Voir plus de commentaires';
			}

			commentsBtn.classList.remove('active');
			if (loader) {
				loader.style.display = 'none';
			}
		}, 450);

		return;
	}

	// Like toggle functionality
	const likeLink = event.target.closest('.like-toggle');
	if (likeLink) {
		event.preventDefault();
		const oeuvreId = likeLink.dataset.oeuvreId;
		const icon = likeLink.querySelector('i');
		const countSpan = likeLink.querySelector('.like-count');

		fetch(`/oeuvre/${oeuvreId}/like-ajax`, {
			method: 'POST',
			headers: {
				'X-Requested-With': 'XMLHttpRequest'
			}
		})
		.then(response => response.json())
		.then(data => {
			if (data.success) {
				if (data.liked) {
					icon.classList.add('bi-heart-fill', 'text-danger');
					icon.classList.remove('bi-heart');
					likeLink.dataset.liked = 'true';
				} else {
					icon.classList.remove('bi-heart-fill', 'text-danger');
					icon.classList.add('bi-heart');
					likeLink.dataset.liked = 'false';
				}
				countSpan.textContent = data.likeCount;

				// Update all like-toggle links for this oeuvre across all tabs/glightbox instances
				document.querySelectorAll(`.like-toggle[data-oeuvre-id="${oeuvreId}"]`).forEach((link) => {
					const linkIcon = link.querySelector('i');
					const linkCount = link.querySelector('.like-count');
					if (linkIcon) {
						if (data.liked) {
							linkIcon.classList.add('bi-heart-fill', 'text-danger');
							linkIcon.classList.remove('bi-heart');
						} else {
							linkIcon.classList.remove('bi-heart-fill', 'text-danger');
							linkIcon.classList.add('bi-heart');
						}
					}
					if (linkCount) {
						linkCount.textContent = data.likeCount;
					}
					link.dataset.liked = data.liked ? 'true' : 'false';
				});
			}
		})
		.catch(error => {
			console.error('Error toggling like:', error);
		});
		return;
	}

	const removeLink = event.target.closest('.favorite-remove-toggle');
	if (!removeLink) {
		return;
	}

	event.preventDefault();

	const oeuvreId = removeLink.dataset.oeuvreId;
	if (!oeuvreId || removeLink.dataset.loading === 'true') {
		return;
	}

	removeLink.dataset.loading = 'true';

	fetch(`/oeuvre/${oeuvreId}/favorite-ajax`, {
		method: 'POST',
		headers: {
			'X-Requested-With': 'XMLHttpRequest'
		}
	})
	.then(response => response.json())
	.then(data => {
		if (!data.success) {
			return;
		}

		if (data.favorited === false) {
			document.querySelectorAll(`[data-favorite-card][data-oeuvre-id="${oeuvreId}"]`).forEach((card) => {
				card.remove();
			});

			const emptyMessages = {
				'tab-0': "L'utilisateur n'a pas encore de favoris.",
				'tab-1': 'Aucune oeuvre favorite dans cette categorie.',
				'tab-2': 'Aucune oeuvre favorite dans cette categorie.',
				'tab-3': 'Aucune oeuvre favorite dans cette categorie.'
			};

			document.querySelectorAll('.tab-pane .row.g-3').forEach((row) => {
				const tabPane = row.closest('.tab-pane');
				if (!tabPane) {
					return;
				}

				const hasCards = row.querySelector('[data-favorite-card]') !== null;
				let emptyState = row.querySelector('.favorite-empty-state');

				if (!hasCards && !emptyState) {
					emptyState = document.createElement('p');
					emptyState.className = 'col-12 text-center text-muted favorite-empty-state';
					emptyState.textContent = emptyMessages[tabPane.id] || 'Aucune oeuvre favorite dans cette categorie.';
					row.appendChild(emptyState);
				}

				if (hasCards && emptyState) {
					emptyState.remove();
				}
			});
		}
	})
	.catch(() => {})
	.finally(() => {
		removeLink.dataset.loading = 'false';
	});
});

// Reload page when GLightbox closes
document.addEventListener('keydown', function(e) {
	if (e.key === 'Escape') {
		setTimeout(() => {
			location.reload();
		}, 100);
	}
});

document.addEventListener('click', function(e) {
	const overlay = e.target.closest('.goverlay');
	if (overlay) {
		setTimeout(() => {
			location.reload();
		}, 100);
	}

	const closeBtn = e.target.closest('.gclose');
	if (closeBtn) {
		setTimeout(() => {
			location.reload();
		}, 100);
	}
});

// Auto-reopen GLightbox after comment submission and page reload
document.addEventListener('DOMContentLoaded', function() {
	const storedOeuvreId = sessionStorage.getItem('reopenGlightboxOeuvreId');
	if (storedOeuvreId) {
		sessionStorage.removeItem('reopenGlightboxOeuvreId');
		
		// Find and click the gallery link for this oeuvre
		setTimeout(() => {
			const galleryLink = document.querySelector(`a[data-gallery="favorites"][data-glightbox*="custom-desc-${storedOeuvreId}"]`);
			if (galleryLink) {
				galleryLink.click();
			}
		}, 300);
	}
});

// Store oeuvre ID when comment form is submitted inside GLightbox
document.addEventListener('submit', function(e) {
	const form = e.target;
	
	// For add/edit/delete comment - check for oeuvre_id input
	const oeuvreInput = form.querySelector('input[name="oeuvre_id"]');
	if (oeuvreInput && oeuvreInput.value) {
		sessionStorage.setItem('reopenGlightboxOeuvreId', oeuvreInput.value);
		return;
	}
	
	// For add comment without oeuvre_id input
	if (form.action && form.action.includes('/oeuvre/') && form.action.includes('/commentaire')) {
		const match = form.action.match(/\/oeuvre\/(\d+)\/commentaire/);
		if (match) {
			const oeuvreId = match[1];
			sessionStorage.setItem('reopenGlightboxOeuvreId', oeuvreId);
		}
	}
});

// Inline comment edit toggle
document.addEventListener('click', function(e) {
	const editToggle = e.target.closest('.comment-edit-toggle');
	if (editToggle) {
		const editId = editToggle.dataset.editId;
		const viewId = editToggle.dataset.viewId;
		const editForm = document.getElementById(editId);
		const textView = document.getElementById(viewId);

		if (editForm && textView) {
			textView.classList.add('d-none');
			editForm.classList.remove('d-none');
			const textarea = editForm.querySelector('textarea[name="contenu"]');
			if (textarea) {
				textarea.focus();
				textarea.selectionStart = textarea.value.length;
			}
		}
	}

	const cancelToggle = e.target.closest('.comment-edit-cancel');
	if (cancelToggle) {
		const editId = cancelToggle.dataset.editId;
		const viewId = cancelToggle.dataset.viewId;
		const editForm = document.getElementById(editId);
		const textView = document.getElementById(viewId);

		if (editForm && textView) {
			editForm.classList.add('d-none');
			textView.classList.remove('d-none');
		}
	}
});
</script>

<style>
