        if (counter) {
          counter.textContent = `(${editDescriptionInput.value.length}/5000)`;
        }
      };
      editDescriptionInput.addEventListener('input', updateEditCounter);
      editDescriptionInput.addEventListener('change', updateEditCounter);
    }
    
    // Note: Image file validation is now handled by Dropzone component
    
    // Edit form submission validation
    editForm.addEventListener('submit', function(e) {
      editForm.classList.remove('was-validated');
      
      let isValid = true;
      const errors = [];
      
      // Title validation
      if (editTitleInput) {
        const value = editTitleInput.value.trim();
        if (!value) {
          errors.push('Title is required');
          editTitleInput.classList.add('is-invalid');
          isValid = false;
        } else if (value.length < 3) {
          errors.push('Title must be at least 3 characters');
          editTitleInput.classList.add('is-invalid');
          isValid = false;
        } else if (value.length > 255) {
          errors.push('Title cannot exceed 255 characters');
          editTitleInput.classList.add('is-invalid');
          isValid = false;
        } else {
          editTitleInput.classList.remove('is-invalid');
          editTitleInput.classList.add('is-valid');
        }
      }
      
      // Description validation
      if (editDescriptionInput) {
        const value = editDescriptionInput.value.trim();
        if (!value) {
          errors.push('Description is required');
          editDescriptionInput.classList.add('is-invalid');
          isValid = false;
        } else if (value.length < 10) {
          errors.push('Description must be at least 10 characters');
          editDescriptionInput.classList.add('is-invalid');
          isValid = false;
        } else if (value.length > 5000) {
          errors.push('Description cannot exceed 5000 characters');
          editDescriptionInput.classList.add('is-invalid');
          isValid = false;
        } else {
          editDescriptionInput.classList.remove('is-invalid');
          editDescriptionInput.classList.add('is-valid');
        }
      }
      
      // Genre validation
      if (editGenreSelect) {
        const value = editGenreSelect.value;
        if (!value) {
          errors.push('Genre is required');
          editGenreSelect.classList.add('is-invalid');
          isValid = false;
        } else {
          editGenreSelect.classList.remove('is-invalid');
          editGenreSelect.classList.add('is-valid');
        }
      }
      
      // Note: Image file validation is handled by Dropzone component
      
      // If validation failed, prevent submission and show errors
      if (!isValid) {
        e.preventDefault();
        editForm.classList.add('was-validated');
        
        // Show error alert
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-danger alert-dismissible fade show mt-3';
        alertDiv.innerHTML = `
          <strong><i class="bi bi-exclamation-triangle pe-2"></i>Validation Failed:</strong>
          <ul class="mb-0 mt-2">
            ${errors.map(err => `<li>${err}</li>`).join('')}
          </ul>
          <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        `;
        
        // Insert at the top of the form
        editForm.insertBefore(alertDiv, editForm.firstChild);
        
        // Scroll to error
        setTimeout(() => {
          alertDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 100);
      }
    });
  }
  
  // ===== BOOTSTRAP DROPDOWN INITIALIZATION =====
  // Ensure all dropdowns are initialized
  function initializeDropdowns() {
    const dropdownElementList = document.querySelectorAll('[data-bs-toggle="dropdown"]');
    dropdownElementList.forEach(function(dropdownToggle) {
      if (!bootstrap.Dropdown.getInstance(dropdownToggle)) {
        new bootstrap.Dropdown(dropdownToggle);
      }
    });
  }
  
  // Initialize on page load
  initializeDropdowns();
  
  // Re-initialize after AJAX updates (for dynamically loaded content)
  const musicGrid = document.getElementById('musicGrid');
  if (musicGrid) {
    const observer = new MutationObserver(function(mutations) {
      initializeDropdowns();
    });
    observer.observe(musicGrid, { childList: true, subtree: true });
  }
  
  // ===== DELETE CONFIRMATION =====
  document.addEventListener('submit', function(e) {
    const form = e.target;
    
    // Check if this is a delete form
    if (form.classList.contains('delete-music-form')) {
      e.preventDefault();
      
      const musicTitle = form.dataset.musicTitle || 'this music';
      
      // Show confirmation dialog
      if (confirm(`⚠️ Are you sure you want to delete "${musicTitle}"?\n\nThis action cannot be undone!`)) {
        // User confirmed, submit the form
        form.submit();
      }
      // Else: User cancelled, do nothing
    }
  });
});

