{% extends 'base_artiste.html.twig' %}

{% block title %}{{ 'Réclamations'|trans }}{% endblock %}

{% block artiste_content %}
	<!-- Card START -->
	<div class="card h-100">
		<!-- Card header START -->
		<div class="card-header d-sm-flex align-items-center text-center justify-content-sm-between border-0 pb-0">
			<h1 class="h4 card-title">Réclamations</h1>
		</div>
		<!-- Card header END -->
		<!-- Card body START -->
		<div class="card-body">
			<!-- Tab nav line -->
			<ul class="nav nav-tabs nav-bottom-line justify-content-center justify-content-md-start">
				<li class="nav-item"> <a class="nav-link {% if (search_query|default('')) is empty and (selected_statut|default('')) is empty %}active{% endif %}" data-bs-toggle="tab" href="#tab-1"> <i class="bi bi-pencil-square pe-1"></i>Envoyer Réclamation </a> </li>
				<li class="nav-item"> <a class="nav-link {% if (search_query|default('')) is not empty or (selected_statut|default('')) is not empty %}active{% endif %}" data-bs-toggle="tab" href="#tab-2"> <i class="bi bi-list-check pe-1"></i>Mes Réclamations </a> </li>
			</ul>

			<!-- Tab content START -->
			<div class="tab-content mb-0 pb-0">
                
				<!-- Submit Reclamation Tab START -->
				<div class="tab-pane fade {% if (search_query|default('')) is empty and (selected_statut|default('')) is empty %}show active{% endif %}" id="tab-1">
					<div class="card mt-4">
						<!-- Title START -->
						<div class="card-header border-0 pb-0">
							<h5 class="card-title mb-0">Soumettre une Réclamation</h5>
						</div>
						<!-- Title END -->
						<!-- Form START -->
						<div class="card-body">
							{{ form_start(form, {'attr': {'class': 'row g-3', 'novalidate': 'novalidate'}}) }}
								<div class="col-12">
									{{ form_errors(form) }}
								</div>

								<div class="col-12">
									{{ form_label(form.type, 'Type') }}
									{% set type_has_errors = form.type.vars.errors|length > 0 %}
									{{ form_widget(form.type, {'attr': {'class': 'form-select' ~ (type_has_errors ? ' is-invalid' : '')}}) }}
									{% for error in form.type.vars.errors %}
										<div class="invalid-feedback d-block">{{ error.message }}</div>
									{% endfor %}
								</div>

								<div class="col-12">
									{{ form_label(form.texte, 'Description') }}
									{% set texte_has_errors = form.texte.vars.errors|length > 0 %}
									{{ form_widget(form.texte, {
										'attr': {
											'class': 'form-control' ~ (texte_has_errors ? ' is-invalid' : ''),
											'rows': 5,
											'placeholder': 'Decrivez votre probleme en detail...'
										}
									}) }}
									{% for error in form.texte.vars.errors %}
										<div class="invalid-feedback d-block">{{ error.message }}</div>
									{% endfor %}
								</div>


								<div class="col-12 text-end">
									<button type="reset" class="btn btn-outline-secondary me-2">Reinitialiser</button>
									<button type="submit" class="btn btn-primary">Envoyer la reclamation</button>
								</div>
							{{ form_end(form) }}
						</div>
						<!-- Form END -->
					</div>
				</div>
				<!-- Submit Reclamation Tab END -->

				<!-- My Reclamations Tab START -->
				<div class="tab-pane fade {% if (search_query|default('')) is not empty or (selected_statut|default('')) is not empty %}show active{% endif %}" id="tab-2">
					<div class="mt-4">
						<!-- Search and Filter -->
						<form class="row g-3 mb-4" method="get" id="filterForm">
							<div class="col-md-6">
								<input type="search" name="q" id="searchInput" class="form-control" placeholder="Rechercher une reclamation..." value="{{ search_query|default('') }}">
							</div>
							<div class="col-md-6">
								<select name="statut" id="statutSelect" class="form-select">
									<option value="" {% if (selected_statut|default('')) is empty %}selected{% endif %}>Filtrer par statut</option>
									<option value="Traitée" {% if (selected_statut|default('')) == 'Traitée' %}selected{% endif %}>Traite</option>
									<option value="Non traitée" {% if (selected_statut|default('')) == 'Non traitée' %}selected{% endif %}>Non traitee</option>
									<option value="En cours" {% if (selected_statut|default('')) == 'En cours' %}selected{% endif %}>En cours</option>
								</select>
							</div>
						</form>
                        
						<!-- Reclamations List -->
						<div class="row g-3">
							{% if reclamations is not defined or reclamations is empty %}
								<div class="col-12">
									<div class="text-center py-5">
										<i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
										<h6 class="mt-3 text-muted">Aucune reclamation trouvee</h6>
										<p class="small text-muted">Vous n'avez pas encore soumis de reclamation.</p>
									</div>
								</div>
							{% else %}
								{% for reclamation in reclamations %}
									<div class="col-12">
										<div class="card">
											<div class="card-body">
												<div class="row align-items-center">
													<div class="col-md-8">
														<div class="d-flex align-items-start gap-3">
															<div>
																{% if reclamation.statut and reclamation.statut.value == 'Non traitée' %}
																	<span class="badge bg-warning text-dark">Non traitee</span>
																{% elseif reclamation.statut and reclamation.statut.value == 'En cours' %}
																	<span class="badge bg-info text-dark">En cours</span>
																{% else %}
																	<span class="badge bg-success">Traitee</span>
																{% endif %}
															</div>
															<div class="w-100">
																<h6 class="mb-1">{{ reclamation.texte|slice(0, 60) }}{% if reclamation.texte|length > 60 %}...{% endif %}</h6>
																<p class="mb-2 small text-muted">Type: <strong>{{ reclamation.type ? reclamation.type.value : '-' }}</strong></p>
																<p class="mb-0 small">{{ reclamation.texte }}</p>
															</div>
														</div>
													</div>
													<div class="col-md-4 text-md-end">
														<div class="d-flex justify-content-md-end align-items-start gap-2">
															<div class="me-auto">
																<small class="text-muted">Creee le: <strong>{{ reclamation.dateCreation ? reclamation.dateCreation|date('d M Y') : '-' }}</strong></small>
																{% if reclamation.reponses|length > 0 %}
																	<div class="mt-1">
																		<span class="badge bg-success-soft text-success">
																			<i class="bi bi-chat-dots"></i> {{ reclamation.reponses|length }} reponse{{ reclamation.reponses|length > 1 ? 's' : '' }}
																		</span>
																	</div>
																{% endif %}
															</div>
															<div class="dropdown">
																<button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Actions">
																	<i class="bi bi-three-dots"></i>
																</button>
																<ul class="dropdown-menu dropdown-menu-end">
																	<li>
																		<a class="dropdown-item" href="{{ path('app_reclamationartiste_show', {'id': reclamation.id}) }}">
																			<i class="bi bi-chat-dots"></i> Voir reponses
																			{% if reclamation.reponses|length > 0 %}
																				<span class="badge bg-success ms-1">{{ reclamation.reponses|length }}</span>
																			{% endif %}
																		</a>
																	</li>
																	<li>
																		<a class="dropdown-item" href="#offcanvasEditReclamation-{{ reclamation.id }}" data-bs-toggle="offcanvas" data-bs-dismiss="dropdown" role="button" aria-controls="offcanvasEditReclamation-{{ reclamation.id }}">
																			Editer reclamation
																		</a>
																	</li>
																	<li><hr class="dropdown-divider"></li>
																	<li>
																		<form method="post" action="{{ path('app_reclamationartiste_delete', {'id': reclamation.id}) }}" onsubmit="return confirm('Supprimer cette reclamation ?');">
																			<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reclamation.id) }}">
																			<button class="dropdown-item text-danger" type="submit">Supprimer reclamation</button>
																		</form>
																	</li>
																</ul>
															</div>
														</div>
													</div>
												</div>
											</div>
										</div>
									</div>

									<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasEditReclamation-{{ reclamation.id }}" style="width: 600px">
										<div class="offcanvas-body" data-simplebar>
											<div class="offcanvas-header px-2 pt-0">
												<h3 class="offcanvas-title">Editer reclamation</h3>
												<button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
											</div>
											<div class="container">
												{% set edit_form = edit_forms[reclamation.id] ?? null %}
												{% if edit_form %}
													{{ form_start(edit_form, { attr: { class: 'row g-3', 'novalidate': 'novalidate' } }) }}
														<div class="col-12">
															{{ form_label(edit_form.texte, 'Description') }}
															{% set edit_texte_has_errors = edit_form.texte.vars.errors|length > 0 %}
															{{ form_widget(edit_form.texte, {
																'attr': {
																	'class': 'form-control' ~ (edit_texte_has_errors ? ' is-invalid' : ''),
																	'rows': 5,
																	'placeholder': 'Decrivez votre probleme en detail...'
																}
															}) }}
															{% for error in edit_form.texte.vars.errors %}
																<div class="invalid-feedback d-block">{{ error.message }}</div>
															{% endfor %}
														</div>
														<div class="col-12">
															{{ form_label(edit_form.type, 'Type') }}
															{% set edit_type_has_errors = edit_form.type.vars.errors|length > 0 %}
															{{ form_widget(edit_form.type, {'attr': {'class': 'form-select' ~ (edit_type_has_errors ? ' is-invalid' : '')}}) }}
															{% for error in edit_form.type.vars.errors %}
																<div class="invalid-feedback d-block">{{ error.message }}</div>
															{% endfor %}
														</div>
														<div class="col-12 d-flex gap-2">
															<button class="btn btn-primary" type="submit">Enregistrer</button>
															<button type="button" class="btn btn-outline-primary" data-bs-dismiss="offcanvas" aria-label="Close">Fermer</button>
														</div>
													{{ form_end(edit_form) }}
												{% else %}
													<div class="alert alert-warning mb-0">Formulaire indisponible.</div>
												{% endif %}
											</div>
										</div>
									</div>
								{% endfor %}
							{% endif %}
						</div>
					</div>
				</div>
				<!-- My Reclamations Tab END -->
			</div>
			<!-- Tab content END -->
		</div>
		<!-- Card body END -->
	</div>
	<!-- Card END -->
{% endblock %}

