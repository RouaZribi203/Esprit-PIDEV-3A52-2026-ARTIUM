{% extends 'base_amateur.html.twig' %}

{% block title %}{{ 'Fil d’actualités'|trans }}{% endblock %}

{% block amateur_content %}
    {% set initialDisplayCount = initialDisplayCount|default(3) %}
    <div id="feed-container">
    {% for oeuvre in oeuvres|slice(0, initialDisplayCount) %}
    {% set oeuvreComments = commentsByOeuvre[oeuvre.id]|default([]) %}
    <!-- Card feed item START -->
    <div class="card mb-4" id="oeuvre-{{ oeuvre.id }}">
        <!-- Card header START -->
        <div class="card-header border-0 pb-0" >
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <!-- Avatar -->
                    <div class="avatar avatar-story me-2">
                        <a href="#!">
                            <img class="avatar-img rounded-circle" 
                                 src="{{ asset('assetsfront/images/avatar/default.jpg') }}" 
                                 alt="">
                        </a>
                    </div>
                    <!-- Info -->
                    <div>
                        <div class="nav nav-divider">
                            <h6 class="nav-item card-title mb-0">
                                <a href="#!">
                                    {{ (oeuvre.collection and oeuvre.collection.artiste) ? (oeuvre.collection.artiste.nom ~ ' ' ~ oeuvre.collection.artiste.prenom) : 'Artiste Inconnu' }}
                                </a>
                            </h6>
                            <span class="nav-item small">{{ oeuvre.dateCreation|date('d F Y') }}</span>
                        </div>
                        <p class="mb-0 small">{{ (oeuvre.collection and oeuvre.collection.artiste and oeuvre.collection.artiste.specialite) ? oeuvre.collection.artiste.specialite.value : 'Spécialité non renseignée' }}</p>
                    </div>
                </div>
                <!-- Card feed action dropdown START -->
                <div class="dropdown">
                          <a href="#" class="text-secondary btn btn-secondary-soft-hover py-1 px-2"
                              id="cardFeedAction{{ oeuvre.id }}" data-bs-toggle="dropdown" aria-expanded="false" data-turbo="false">
                        <i class="bi bi-three-dots"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="cardFeedAction{{ oeuvre.id }}">
                        <li>
                            <a class="dropdown-item favorite-toggle"
                               href="#" 
                               data-oeuvre-id="{{ oeuvre.id }}"
                               data-favorited="{{ app.user.favUser.contains(oeuvre) ? 'true' : 'false' }}"
                               id="favoriteDropdownBtn{{ oeuvre.id }}">
                                <i class="bi favorite-icon {% if app.user.favUser.contains(oeuvre) %}bi-star-fill text-warning{% else %}bi-star text-secondary{% endif %} pe-2"></i>
                                <span class="favorite-text">{% if app.user.favUser.contains(oeuvre) %}Retirer des favoris{% else %}Ajouter aux Favoris{% endif %}</span>
                            </a>
                        </li>
                    </ul>
                </div>
                <!-- Card feed action dropdown END -->
            </div>
        </div>
        <!-- Card header END -->
        
        <!-- Card body START -->
        <div class="card-body pb-0">
            <h5 class="mb-2">{{ oeuvre.titre }}</h5>
            <p>{{ oeuvre.description|raw }}
                {% if oeuvre.type %}
                    <a href="#!" class="ms-2">#{{ oeuvre.type.value }}</a>
                {% endif %}
                {% if oeuvre.collection %}
                    <a href="#!" class="ms-1">#{{ oeuvre.collection.titre }}</a>
                {% endif %}
            </p>
        </div>
        
        <!-- Card img -->
        {% if oeuvre.image %}
        <div class="overflow-hidden mx-3 mb-2 rounded-3 border">
            <img src="{{ path('oeuvre_image', {'id': oeuvre.id}) }}" 
                 class="img-fluid" 
                 alt="{{ oeuvre.titre }}"
                 style="width: 100%; max-height: 600px; object-fit: contain;">
        </div>
        {% endif %}
        
        <!-- Feed react START -->
        <div class="card-body pt-0">
            <ul class="nav nav-stack py-3 small">
                <li class="nav-item">
                    {% set userLiked = false %}
                    {% for like in oeuvre.likes %}
                        {% if like.user.id == app.user.id %}
                            {% set userLiked = true %}
                        {% endif %}
                    {% endfor %}
                    <a class="nav-link like-toggle" href="#" data-oeuvre-id="{{ oeuvre.id }}" data-liked="{{ userLiked ? 'true' : 'false' }}">
                        <i class="bi bi-heart{{ userLiked ? '-fill text-danger' : '' }} pe-1"></i>
                        <span class="like-count">{{ oeuvre.likes ? oeuvre.likes|length : 0 }}</span>
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#!">
                        <i class="bi bi-chat-fill pe-1"></i>Commentaires (<span class="comment-count" data-oeuvre-id="{{ oeuvre.id }}">{{ oeuvreComments|length }}</span>)</a>
                </li>
				<!-- Card share action START -->
                <li class="nav-item ms-sm-auto d-flex align-items-center">
                    <i class="bi bi-star-fill text-warning fa-fw pe-1"></i>
                    <span class="favorite-count" data-oeuvre-id="{{ oeuvre.id }}">{{ oeuvre.userFav|length }}</span>
                    <span class="ms-1">favoris</span>
                </li>
                
            </ul>
            <!-- Feed react END -->

            <!-- Add comment -->
            <div class="d-flex mb-3">
                <!-- Avatar -->
                <div class="avatar avatar-xs me-2">
                    <a href="#!">
                        {% if app.user and app.user.photoProfil %}
                            <img class="avatar-img rounded-circle" src="{{ asset('uploads/' ~ app.user.photoProfil) }}" alt="">
                        {% else %}
                            <span class="avatar-img rounded-circle bg-light d-inline-block" style="width:32px;height:32px;"></span>
                        {% endif %}
                    </a>
                </div>

                <!-- Comment box  -->
                <form class="w-100" action="{{ path('oeuvre_commentaire', {'id': oeuvre.id}) }}#oeuvre-{{ oeuvre.id }}" method="post" data-turbo-frame="comments-{{ oeuvre.id }}">
                    <div class="position-relative">
                        <textarea name="contenu" data-autoresize class="form-control bg-light rounded pe-5" rows="1"
                                  placeholder="Ajouter un commentaire..."></textarea>
                        <input type="hidden" name="redirect_path" value="{{ app.request.pathInfo }}">
                        <button class="btn btn-link text-primary position-absolute top-50 end-0 translate-middle-y me-2 p-0 comment-submit-button" type="submit" aria-label="Publier le commentaire">
                            <i class="bi bi-send-fill fs-5"></i>
                        </button>
                    </div>
                </form>

            </div>
            
            <!-- Comment wrap START -->
            <turbo-frame id="comments-{{ oeuvre.id }}">
                {% if oeuvreComments|length > 0 %}
                <ul class="comment-wrap list-unstyled mb-0">
                {% for commentaire in oeuvreComments %}
                <!-- Comment item START -->
                <li class="comment-item{% if loop.index > 3 %} hidden-comment d-none{% endif %}">
                    <div class="d-flex">
                        <!-- Avatar -->
                        <div class="avatar avatar-xs">
                            <a href="#!"><img class="avatar-img rounded-circle"
                                    src="{{ asset('assetsfront/images/avatar/default.jpg') }}" alt=""></a>
                        </div>
                        <div class="ms-2 w-100">
                            <!-- Comment by -->
                            <div class="bg-light rounded-start-top-0 p-3 rounded w-100">
                                <div class="d-flex justify-content-between">
                                    <h6 class="mb-1">
                                        <a href="#!">
                                            {{ commentaire.user ? (commentaire.user.nom ~ ' ' ~ commentaire.user.prenom) : 'Utilisateur' }}
                                        </a>
                                    </h6>
                                    <div class="d-flex align-items-center">
                                        <small class="ms-2">{{ commentaire.dateCommentaire|date('d F Y') }}</small>
                                        {% if commentaire.user and app.user and commentaire.user.id == app.user.id %}
                                            <div class="dropdown ms-2">
                                                <a href="#" class="text-secondary btn btn-sm btn-link p-0" id="commentAction{{ commentaire.id }}" data-bs-toggle="dropdown" aria-expanded="false" data-turbo="false">
                                                    <i class="bi bi-three-dots"></i>
                                                </a>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="commentAction{{ commentaire.id }}">
                                                    <li>
                                                        <button type="button" class="dropdown-item comment-edit-toggle" data-edit-id="editComment{{ commentaire.id }}" data-view-id="commentText{{ commentaire.id }}">
                                                            <i class="bi bi-pencil-square text-primary pe-2"></i>Modifier
                                                        </button>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <form method="post" action="{{ path('commentaire_delete', {'id': commentaire.id}) }}" class="m-0" data-turbo-frame="comments-{{ oeuvre.id }}">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ commentaire.id) }}">
                                                            <input type="hidden" name="redirect_path" value="{{ app.request.pathInfo }}">
                                                            <button type="submit" class="dropdown-item text-danger">
                                                                <i class="bi bi-trash3 pe-2"></i>Supprimer
                                                            </button>
                                                        </form>
                                                    </li>
                                                </ul>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                <div id="commentText{{ commentaire.id }}" class="small mb-0 comment-text">{{ commentaire.texte }}</div>
                                {% if commentaire.user and app.user and commentaire.user.id == app.user.id %}
                                    <form method="post" action="{{ path('commentaire_edit', {'id': commentaire.id}) }}" class="d-none w-100" id="editComment{{ commentaire.id }}" data-turbo-frame="comments-{{ oeuvre.id }}">
                                        <div class="position-relative w-100">
                                            <textarea name="contenu" class="form-control bg-white w-100 comment-edit-textarea" rows="3">{{ commentaire.texte }}</textarea>
                                            <input type="hidden" name="_token" value="{{ csrf_token('edit_comment_' ~ commentaire.id) }}">
                                            <input type="hidden" name="redirect_path" value="{{ app.request.pathInfo }}">
                                            <input type="hidden" name="oeuvre_id" value="{{ oeuvre.id }}">
                                            <div class="d-flex gap-2 mt-2">
                                                <button type="submit" class="btn btn-sm btn-primary">
                                                    <i class="bi bi-check2"></i>Enregistrer
                                                </button>
                                                <button type="button" class="btn btn-sm btn-outline-secondary comment-edit-cancel" data-edit-id="editComment{{ commentaire.id }}" data-view-id="commentText{{ commentaire.id }}">
                                                    <i class="bi bi-x-lg"></i>Annuler
                                                </button>
                                            </div>
                                        </div>
                                    </form>
                                {% endif %}
                            </div>
                            <!-- Comment react -->
                            <ul class="nav nav-divider py-2 small">
                                <li class="nav-item">
                                    <a class="nav-link" href="#!">Répondre</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </li>
                <!-- Comment item END -->
                {% endfor %}
                </ul>
                {% else %}
                <ul class="comment-wrap list-unstyled mb-0"></ul>
                {% endif %}
            </turbo-frame>
            <!-- Comment wrap END -->
        </div>
        <!-- Card body END -->
        
        <!-- Card footer START -->
        <div class="card-footer border-0 pt-0" style="display: {{ oeuvreComments|length > 3 ? '' : 'none' }};">
            <!-- Load more comments -->
                <a href="#" role="button" data-turbo="false"
                    class="btn btn-link btn-link-loader btn-sm text-secondary d-flex align-items-center comments-load-more">
                <div class="spinner-dots me-2 comments-loader" style="display: none;">
                    <span class="spinner-dot"></span>
                    <span class="spinner-dot"></span>
                    <span class="spinner-dot"></span>
                </div>
                <span class="comments-load-text">Voir plus de commentaires</span>
            </a>
        </div>
        <!-- Card footer END -->
    </div>
    <!-- Card feed item END -->
    {% else %}
        <div class="card">
            <div class="card-body text-center py-5">
                <h5>Aucune œuvre pour le moment</h5>
                <p class="text-muted">Revenez plus tard pour découvrir de nouvelles créations !</p>
            </div>
        </div>
    {% endfor %}
