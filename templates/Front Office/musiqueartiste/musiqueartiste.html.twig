{% extends 'base_artiste.html.twig' %}

{% block title %}{{ 'Musiques'|trans }}{% endblock %}

{% block artiste_content %}
<!-- Flash messages -->
{% for message in app.flashes('success') %}
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    {{ message }}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
{% endfor %}

{% for message in app.flashes('error') %}
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    {{ message }}
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
{% endfor %}

<!-- Header with title and upload button START -->
<div class="card">
  <div class="card-header d-sm-flex align-items-center text-center justify-content-sm-between border-0 pb-0">
    <h1 class="h4 card-title">Mes pièces musicales</h1>
    <button type="button" class="btn btn-primary-soft" data-bs-toggle="offcanvas" data-bs-target="#offcanvasAddMusic">
      <i class="bi bi-plus-circle pe-2"></i>Ajouter une musique
    </button>
  </div>
  <!-- Card body START -->
  <div class="card-body">
    <!-- Search and Filter Bar START -->
    <div class="row mb-4 g-2 align-items-end">
      <div class="col-md-6">
        <div class="d-flex gap-2">
          <div class="flex-grow-1">
            <label for="searchInput" class="form-label small mb-2">Rechercher par titre, description ou artiste</label>
            <input type="text" class="form-control" id="searchInput" placeholder="Rechercher des chansons..." value="{{ searchTerm }}">
          </div>
          <button type="button" class="btn btn-outline-primary align-self-end" id="searchBtn">
            <i class="bi bi-search"></i> Rechercher
          </button>
          {% if searchTerm %}
            <button type="button" class="btn btn-outline-secondary align-self-end" id="clearSearchBtn">
              <i class="bi bi-x-circle"></i> Effacer
            </button>
          {% endif %}
        </div>
      </div>
      
      <div class="col-md-6">
        <div class="d-flex gap-2">
          <div class="flex-grow-1">
            <label for="sortBy" class="form-label small mb-2">Trier par</label>
            <select class="form-select" id="sortBy">
              <option value="date" {% if sortBy == 'date' %}selected{% endif %}>Date d'ajout</option>
              <option value="titre" {% if sortBy == 'titre' %}selected{% endif %}>Titre (A-Z)</option>
              <option value="genre" {% if sortBy == 'genre' %}selected{% endif %}>Genre</option>
            </select>
          </div>
          
          <div>
            <label class="form-label small mb-2">&nbsp;</label>
            <button type="button" class="btn btn-outline-primary w-100" id="toggleSortBtn">
              <i class="bi {% if sortOrder == 'DESC' %}bi-sort-down{% else %}bi-sort-up{% endif %}"></i>
              <span id="sortOrderText">{{ sortOrder == 'DESC' ? 'Descendant' : 'Ascendant' }}</span>
            </button>
          </div>
        </div>
      </div>
    </div>
    <!-- Search and Filter Bar END -->
    
    <!-- Results info START -->
    <div class="mb-3" id="resultsInfo">
      {% if searchTerm %}
        <p class="text-muted small">
          <i class="bi bi-info-circle"></i> 
          Trouvé <strong>{{ musiques|length }}</strong> chanson(s) correspondant à "{{ searchTerm }}"
          <a href="#" onclick="clearSearch(); return false;" class="ms-2">Afficher toutes les chansons</a>
        </p>
      {% endif %}
    </div>
    <!-- Results info END -->
    {% if musiques is empty %}
      <!-- No music message START -->
      <div class="text-center py-5" id="emptyMessage">
        <i class="bi bi-music-note-beamed display-1 text-muted"></i>
        <h5 class="mt-3">Aucune musique trouvée</h5>
        <p class="text-muted">{% if searchTerm %}Aucune chanson ne correspond à votre recherche. Essayez un mot-clé différent.{% else %}Commencez par télécharger votre première pièce musicale !{% endif %}</p>
      </div>
      <!-- No music message END -->
    {% else %}
      <!-- Music grid START -->
      <div class="row g-4" id="musicGrid">
        {% for musique in musiques %}
          <!-- Music item START -->
          <div class="col-sm-6 col-xl-4">
            <div class="card h-100 music-card" 
                 data-music-id="{{ musique.id }}" 
                 data-audio-src="{{ path('app_musiqueartiste_audio', {'id': musique.id}) }}">
              <!-- Image with genre badge -->
              <div class="position-relative">
                <img class="img-fluid rounded-top" 
                     src="{{ path('app_musiqueartiste_image', {'id': musique.id}) }}" 
                     alt="{{ musique.titre }}"
                     style="background-color: #f0f0f0; min-height: 200px; object-fit: cover;">
                <div class="badge bg-primary text-white mt-2 me-2 position-absolute top-0 end-0">
                  {{ musique.genre }}
                </div>
              </div>
              
              <!-- Card body START -->
              <div class="card-body position-relative pt-0">
                <!-- Genre tag -->
                <a class="btn btn-xs btn-primary mt-n3" href="#">{{ musique.genre }}</a>
                
                <!-- Music title -->
                <h6 class="mt-3"> 
                  <a href="#!"> {{ musique.titre }} </a> 
                </h6>
                {% set artistFullName = ((musique.artiste_prenom|default('')) ~ ' ' ~ (musique.artiste_nom|default('')))|trim %}
                <p class="mb-2 small text-muted">
                  <i class="bi bi-person-fill pe-1"></i>{{ artistFullName != '' ? artistFullName : 'Artiste inconnu' }}
                </p>
                
                <!-- Description -->
                <p class="mb-2 small text-muted">
                  {{ musique.description|length > 50 ? musique.description|slice(0, 50) ~ '...' : musique.description }}
                </p>
                
                <!-- Date -->
                <p class="small"> 
                  <i class="bi bi-calendar pe-1"></i> 
                  {{ musique.date_creation|date('Y-m-d') }} 
                </p>
                
                <!-- Like and action buttons -->
                <div class="d-flex mt-3 gap-2">
                  <button class="btn btn-sm btn-primary flex-grow-1 play-btn">
                    <i class="bi bi-play-fill pe-1"></i> Lecture
                  </button>
                  <button class="btn btn-sm btn-outline-primary" title="Ajouter aux favoris">
                    <i class="bi bi-heart"></i>
                  </button>
                  <!-- More options dropdown -->
                  <div class="dropdown">
                    <button class="btn btn-sm btn-outline-primary" type="button" id="dropdownMenu{{ musique.id }}" data-bs-toggle="dropdown" aria-expanded="false">
                      <i class="bi bi-three-dots"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenu{{ musique.id }}">
                      <li>
                        <a class="dropdown-item edit-music-btn" href="#" 
                           data-music-id="{{ musique.id }}"
                           data-music-title="{{ musique.titre }}"
                           data-music-description="{{ musique.description }}"
                           data-music-genre="{{ musique.genre }}"
                           data-bs-toggle="offcanvas" 
                           data-bs-target="#offcanvasEditMusic">
                          <i class="bi bi-pencil pe-2"></i>Modifier
                        </a>
                      </li>
                      <li>
                        <a class="dropdown-item view-lyrics-btn" href="#"
                           data-music-id="{{ musique.id }}"
                           data-music-title="{{ musique.titre }}">
                          <i class="bi bi-mic pe-2"></i>Voir paroles
                        </a>
                      </li>
                      <li>
                        <form method="post" action="{{ path('app_musiqueartiste_delete', {'id': musique.id}) }}" 
                              class="delete-music-form" 
                              data-music-title="{{ musique.titre }}"
                              style="display: inline;">
                          <input type="hidden" name="confirm_delete" value="1">
                          <button type="submit" class="dropdown-item text-danger delete-music-submit" style="border: none; background: none; cursor: pointer; width: 100%; text-align: left;">
                            <i class="bi bi-trash pe-2"></i>Supprimer
                          </button>
                        </form>
                      </li>
                      <li><a class="dropdown-item" href="#"> <i class="bi bi-share pe-2"></i>Partager</a></li>
                    </ul>
                  </div>
                </div>
                
                <!-- Progress bar -->
                <div class="mt-3">
                  <div class="progress music-progress-container" style="height: 5px; cursor: pointer;" role="button" tabindex="0">
                    <div class="progress-bar bg-primary music-progress" role="progressbar" style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                  <div class="d-flex justify-content-between align-items-center mt-2 small text-muted">
                    <span class="current-time">0:00</span>
                    <span class="total-time">0:00</span>
                  </div>
                </div>
                
                <!-- Stats -->
                <div class="d-flex justify-content-between align-items-center mt-3 small text-muted">
                  <span><i class="bi bi-hand-thumbs-up pe-1"></i>0</span>
                  <span><i class="bi bi-chat-dots pe-1"></i>0</span>
                  <span><i class="bi bi-collection-play pe-1"></i>0</span>
                </div>
              </div>
              <!-- Card body END -->
            </div>
          </div>
          <!-- Music item END -->
        {% endfor %}
      </div>
      <!-- Music grid END -->
    {% endif %}
  </div>
  <!-- Card body END -->
</div>
<!-- Header and music grid END -->

<!-- Offcanvas Add Music Form START -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasAddMusic" style="width: 600px">
  <div class="offcanvas-body" data-simplebar>
    <div class="offcanvas-header px-2 pt-0">
      <h3 class="offcanvas-title" id="offcanvasAddMusicLabel">Ajouter une nouvelle musique</h3>
      <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <!-- Form body -->
    <div class="container">
      {{ form_start(form, {'attr': {'class': 'row needs-validation', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data', 'id': 'addMusicForm', 'data-turbo': 'false'}}) }}
        
        <!-- Display form errors at the top -->
        {% for label, messages in app.flashes %}
          {% if label == 'error' %}
            {% for message in messages %}
              <div class="col-12 mb-3">
                <div class="alert alert-danger alert-dismissible fade show">
                  <strong><i class="bi bi-exclamation-circle pe-2"></i>Erreur:</strong>
                  {{ message }}
                  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        {% endfor %}

        <!-- Title -->
        <div class="mb-3 col-12">
          {{ form_label(form.titre, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.titre) }}
          {% if form.titre.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
              {% for error in form.titre.vars.errors %}
                {{ error.message }}
              {% endfor %}
            </div>
          {% endif %}
          <small class="form-text text-muted d-block mt-1">3-255 caractères</small>
        </div>

        <!-- Description -->
        <div class="mb-3 col-12">
          {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.description, {'attr': {'data-counter': 'descriptionCounter'}}) }}
          {% if form.description.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
              {% for error in form.description.vars.errors %}
                {{ error.message }}
              {% endfor %}
            </div>
          {% endif %}
          <small class="form-text text-muted d-block mt-1">10-5000 caractères <span id="descriptionCounter">(0/5000)</span></small>
        </div>

        <!-- Genre -->
        <div class="mb-3 col-12">
          {{ form_label(form.genre, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.genre) }}
          {% if form.genre.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
              {% for error in form.genre.vars.errors %}
                {{ error.message }}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <!-- Collection -->
        <div class="mb-3 col-12">
          {{ form_label(form.collection, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.collection) }}
          {% if form.collection.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
              {% for error in form.collection.vars.errors %}
                {{ error.message }}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <!-- Cover Image -->
        <div class="mb-3 col-12">
          {{ form_label(form.imageFile, null, {'label_attr': {'class': 'form-label'}}) }}
          {{ form_widget(form.imageFile) }}
          {{ form_help(form.imageFile) }}
          {% if form.imageFile.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
              {% for error in form.imageFile.vars.errors %}
                {{ error.message }}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <!-- Audio File -->
        <div class="mb-3 col-12">
          {{ form_label(form.audioFile, null, {'label_attr': {'class': 'form-label'}}) }}
          <span class="text-danger">*</span>
          {{ form_widget(form.audioFile) }}
          {{ form_help(form.audioFile) }}
          {% if form.audioFile.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
              {% for error in form.audioFile.vars.errors %}
                {{ error.message }}
              {% endfor %}
            </div>
          {% endif %}
        </div>

        <!-- Buttons -->
        <div class="col-12">
          <button class="btn btn-primary" type="submit" id="submitBtn">
            <i class="bi bi-upload pe-2"></i><span id="submitBtnText">Ajouter Musique</span>
          </button>
          <button type="button" class="btn btn-outline-primary ms-2" data-bs-dismiss="offcanvas" aria-label="Close">Annuler</button>
        </div>

      {{ form_end(form) }}
    </div>
  </div>
</div>
<!-- Offcanvas Add Music Form END -->

<!-- Offcanvas Edit Music Form START -->
<div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasEditMusic" style="width: 600px">
  <div class="offcanvas-body" data-simplebar>
    <div class="offcanvas-header px-2 pt-0">
      <h3 class="offcanvas-title">Modifier la musique</h3>
      <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <!-- Form body -->
    <div class="container">
      <form method="post" id="editMusicForm" enctype="multipart/form-data" class="row needs-validation" novalidate data-turbo="false">
        <input type="hidden" id="editMusicId" name="musicId">
        
        <!-- Title -->
        <div class="mb-3 col-12">
          <label for="editTitre" class="form-label">Titre</label>
          <span class="text-danger">*</span>
          <input type="text" class="form-control" id="editTitre" name="titre" 
                 required minlength="3" maxlength="255">
          <div class="invalid-feedback">Le titre doit contenir entre 3 et 255 caractères.</div>
          <small class="form-text text-muted d-block mt-1">3-255 caractères</small>
        </div>

        <!-- Description -->
        <div class="mb-3 col-12">
          <label for="editDescription" class="form-label">Description</label>
          <span class="text-danger">*</span>
          <textarea class="form-control" id="editDescription" name="description" rows="3" 
                    required minlength="10" maxlength="5000" data-counter="editDescriptionCounter"></textarea>
          <div class="invalid-feedback">La description doit contenir entre 10 et 5000 caractères.</div>
          <small class="form-text text-muted d-block mt-1">10-5000 caractères <span id="editDescriptionCounter">(0/5000)</span></small>
        </div>

        <!-- Genre -->
        <div class="mb-3 col-12">
          <label for="editGenre" class="form-label">Genre</label>
          <span class="text-danger">*</span>
          <select class="form-select" id="editGenre" name="genre" required>
            <option value="">Sélectionner un genre</option>
            <option value="Rock">Rock</option>
            <option value="Jazz">Jazz</option>
            <option value="Classique">Classique</option>
            <option value="Pop">Pop</option>
          </select>
          <div class="invalid-feedback">Veuillez sélectionner un genre.</div>
        </div>

        <!-- Cover Image -->
        <div class="mb-3 col-12">
          <label for="editImageFileInput" class="form-label">Modifier l'image de couverture</label>
          <div data-controller="dropzone" class="dropzone-container">
            <input type="file" 
                   class="form-control" 
                   id="editImageFileInput" 
                   name="imageFile" 
                   accept="image/jpeg,image/png,image/jpg"
                   data-dropzone-target="input">
          </div>
          <small class="text-muted d-block mt-2">Optionnel • Laissez vide pour conserver l'image actuelle • Max 5MB • Formats: JPEG, PNG • Recommandé: min 300x300px</small>
        </div>

        <!-- Buttons -->
        <div class="col-12">
          <button class="btn btn-primary" type="submit">
            <i class="bi bi-check-circle pe-2"></i>Modifier la musique
          </button>
          <button type="button" class="btn btn-outline-primary ms-2" data-bs-dismiss="offcanvas" aria-label="Close">Annuler</button>
        </div>
      </form>
    </div>
  </div>
</div>
<!-- Offcanvas Edit Music Form END -->

<!-- Lyrics Modal START -->
<div class="modal fade" id="lyricsModal" tabindex="-1" aria-labelledby="lyricsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="lyricsModalLabel">Paroles</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="lyricsLoading" class="text-center py-4" style="display:none;">
          <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Chargement...</span>
          </div>
          <p class="mt-2 mb-0 text-muted">Chargement des paroles...</p>
        </div>
        <div id="lyricsMessage" class="alert alert-warning" style="display:none;"></div>
        <pre id="lyricsContent" class="mb-0" style="white-space: pre-wrap; font-family: inherit;"></pre>
      </div>
    </div>
  </div>
</div>
<!-- Lyrics Modal END -->

<!-- Audio element for playback -->
<audio id="audioPlayer" style="display: none;"></audio>

<script>
// Dynamic Music Player System - Works for any number of songs
(function() {
  'use strict';
  
  // State management
  const MusicPlayer = {
    audio: document.getElementById('audioPlayer'),
    currentCard: null,
    
    // Utility: Format time in MM:SS
    formatTime(seconds) {
      if (!seconds || isNaN(seconds) || !isFinite(seconds)) return '0:00';
      const mins = Math.floor(seconds / 60);
      const secs = Math.floor(seconds % 60);
      return `${mins}:${secs.toString().padStart(2, '0')}`;
    },
    
    // Get card elements
    getCardElements(card) {
      return {
        playBtn: card.querySelector('.play-btn'),
        progressBar: card.querySelector('.music-progress'),
        progressContainer: card.querySelector('.music-progress-container'),
        currentTime: card.querySelector('.current-time'),
        totalTime: card.querySelector('.total-time')
      };
    },
    
    // Update button state
    updateButton(button, isPlaying) {
      const icon = button.querySelector('i');
      if (isPlaying) {
        icon.className = 'bi bi-pause-fill pe-1';
        button.innerHTML = '';
        button.appendChild(icon);
        button.appendChild(document.createTextNode(' Pause'));
      } else {
        icon.className = 'bi bi-play-fill pe-1';
        button.innerHTML = '';
        button.appendChild(icon);
        button.appendChild(document.createTextNode(' Play'));
      }
    },
    
    // Reset card display
    resetCard(card) {
      const elements = this.getCardElements(card);
      this.updateButton(elements.playBtn, false);
      elements.progressBar.style.width = '0%';
      elements.progressBar.setAttribute('aria-valuenow', '0');
      elements.currentTime.textContent = '0:00';
    },
    
    // Load and play a song
    loadAndPlay(card, seekPercent = 0) {
      const audioSrc = card.dataset.audioSrc;
      const musicId = card.dataset.musicId;
      const elements = this.getCardElements(card);
      
      // If switching songs, reset the previous one
      if (this.currentCard && this.currentCard !== card) {
        this.resetCard(this.currentCard);
      }
      
      // Set current card BEFORE loading (so events can reference it)
      this.currentCard = card;
      
      // Load new audio if different source
      if (this.audio.src !== audioSrc && audioSrc) {
        this.audio.src = audioSrc;
        this.audio.load();
        
        // Seek once metadata is loaded
        if (seekPercent > 0) {
          this.audio.addEventListener('loadedmetadata', function seekHandler() {
            MusicPlayer.audio.currentTime = seekPercent * MusicPlayer.audio.duration;
            MusicPlayer.audio.removeEventListener('loadedmetadata', seekHandler);
          });
        }
      } else if (seekPercent > 0) {
        // Same audio, just seek
        this.audio.currentTime = seekPercent * this.audio.duration;
      }
      
      // Play audio
      this.audio.play().catch(err => console.warn('Playback failed:', err));
      this.updateButton(elements.playBtn, true);
    },
    
    // Toggle play/pause for a card
    togglePlayPause(card) {
      const elements = this.getCardElements(card);
      
      // If this is a different song or no song is loaded
      if (this.currentCard !== card) {
        this.loadAndPlay(card);
        return;
      }
      
      // Same song - toggle play/pause
      if (this.audio.paused) {
        this.audio.play();
        this.updateButton(elements.playBtn, true);
      } else {
        this.audio.pause();
        this.updateButton(elements.playBtn, false);
      }
    },
    
    // Seek to position in song
    seekTo(card, percent) {
      // If clicking on a different song's progress bar, load and play from that position
      if (this.currentCard !== card) {
        this.loadAndPlay(card, percent);
      } else if (this.audio.duration && isFinite(this.audio.duration)) {
        // Same song - just seek
        this.audio.currentTime = percent * this.audio.duration;
      }
    },
    
    // Initialize audio event listeners
    initAudioEvents() {
      // Update display when metadata loads
      this.audio.addEventListener('loadedmetadata', () => {
        if (this.currentCard && this.audio.duration && isFinite(this.audio.duration)) {
          const elements = this.getCardElements(this.currentCard);
          elements.totalTime.textContent = this.formatTime(this.audio.duration);
        }
      });
      
      // Update progress bar as song plays
      this.audio.addEventListener('timeupdate', () => {
        if (this.currentCard && this.audio.duration && isFinite(this.audio.duration)) {
          const elements = this.getCardElements(this.currentCard);
          const percentage = (this.audio.currentTime / this.audio.duration) * 100;
          elements.progressBar.style.width = percentage + '%';
          elements.progressBar.setAttribute('aria-valuenow', Math.round(percentage));
          elements.currentTime.textContent = this.formatTime(this.audio.currentTime);
        }
      });
      
      // Reset when song ends
      this.audio.addEventListener('ended', () => {
        if (this.currentCard) {
          this.resetCard(this.currentCard);
          this.currentCard = null;
        }
      });
    },
    
    // Initialize event delegation for all music cards
    initCardEvents() {
      document.addEventListener('click', (e) => {
        // Handle play button clicks
        const playBtn = e.target.closest('.play-btn');
        if (playBtn) {
          const card = playBtn.closest('.music-card');
          if (card) {
            e.preventDefault();
            this.togglePlayPause(card);
          }
          return;
        }
        
        // Handle progress bar clicks for seeking
        const progressContainer = e.target.closest('.music-progress-container');
        if (progressContainer) {
          const card = progressContainer.closest('.music-card');
          if (card) {
            const rect = progressContainer.getBoundingClientRect();
            const percent = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            this.seekTo(card, percent);
          }
        }
      });
      
      // Keyboard accessibility for progress bars
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          const progressContainer = e.target.closest('.music-progress-container');
          if (progressContainer) {
            e.preventDefault();
            const card = progressContainer.closest('.music-card');
            if (card) {
              this.seekTo(card, 0.5); // Seek to middle
            }
          }
        }
      });
    },
    
    // Images load eagerly now, no lazy loading needed
    initLazyLoading() {
      // Placeholder for future use
    },
    
    // Initialize everything
    init() {
      this.initAudioEvents();
      this.initCardEvents();
      this.initLazyLoading();
    }
  };
  
  // Start the music player when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      MusicPlayer.init();
      updateSortButton();
    });
  } else {
    MusicPlayer.init();
    updateSortButton();
  }
})();

