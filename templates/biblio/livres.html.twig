                <script>
                document.addEventListener('DOMContentLoaded', function(){
                  const forms = document.querySelectorAll('.needs-validation');

                  forms.forEach(function (form) {
                    // ensure an .invalid-feedback exists next to each input/select/textarea
                    Array.from(form.querySelectorAll('input, textarea, select')).forEach(function(el){
                      if (!el.name) return;
                      if (el.type === 'hidden') return;
                      if (el.matches('button, [type="submit"], [type="button"]')) return;
                      const parent = el.parentElement || el.closest('.mb-3') || el;
                      if (!parent) return;
                      if (!parent.querySelector('.invalid-feedback')){
                        const fb = document.createElement('div');
                        fb.className = 'invalid-feedback';
                        parent.appendChild(fb);
                      }
                    });

                    form.addEventListener('submit', function (event) {
                      const valid = form.checkValidity();

                      Array.from(form.querySelectorAll('input, textarea, select')).forEach(function(el){
                        if (!el.name) return;
                        if (el.type === 'hidden') return;
                        if (el.matches('button, [type="submit"], [type="button"]')) return;

                        const parent = el.parentElement || el.closest('.mb-3') || el;
                        const fb = parent ? parent.querySelector('.invalid-feedback') : null;

                        if (!el.checkValidity()){
                          el.classList.add('is-invalid');
                          el.classList.remove('is-valid');
                          if (fb){
                            let msg = 'Champ invalide.';
                            const v = el.validity;
                            if (v.valueMissing) msg = 'Ce champ est requis.';
                            else if (v.tooShort) msg = 'Valeur trop courte.';
                            else if (v.tooLong) msg = 'Valeur trop longue.';
                            else if (v.patternMismatch) msg = 'Format invalide.';
                            else if (v.typeMismatch) msg = 'Format incorrect.';
                            else if (v.rangeUnderflow || v.rangeOverflow) msg = 'Valeur hors limites.';
                            else if (v.stepMismatch) msg = 'Valeur invalide.';
                            fb.textContent = msg;
                          }
                        } else {
                          el.classList.remove('is-invalid');
                          el.classList.add('is-valid');
                          if (fb) fb.textContent = '';
                        }
                      });

                      if (!valid) {
                        event.preventDefault();
                        event.stopPropagation();
                      }
                      form.classList.add('was-validated');
                    }, false);
                  });
                });
                </script>
