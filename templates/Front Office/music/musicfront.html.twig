    <!-- Audio partagé global (défini dans base_amateur) -->

    <div id="globalMusicPlayer" class="music-player-bar fixed-bottom bg-dark border-top border-secondary px-3 py-2 text-white">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-disc text-success"></i>
                <div>
                    <div id="playerTrackTitle" class="fw-semibold player-track-title">Aucune musique en cours</div>
                    <div id="playerTrackSubtitle" class="small text-secondary">Sélectionnez une chanson</div>
                </div>
            </div>

            <div class="d-flex align-items-center gap-2">
                <button id="playerPrevBtn" type="button" class="btn btn-sm btn-outline-light" title="Précédent">
                    <i class="bi bi-skip-backward-fill"></i>
                </button>
                <button id="playerToggleBtn" type="button" class="btn btn-sm btn-success" title="Lire / Pause">
                    <i class="bi bi-play-fill" id="playerToggleIcon"></i>
                </button>
                <button id="playerNextBtn" type="button" class="btn btn-sm btn-outline-light" title="Suivant">
                    <i class="bi bi-skip-forward-fill"></i>
                </button>
            </div>

            <div class="d-flex align-items-center gap-2 flex-grow-1" style="min-width: 220px; max-width: 440px;">
                <span id="playerCurrentTime" class="small text-secondary">0:00</span>
                <input id="playerSeekSlider" type="range" class="form-range flex-grow-1 player-seek-slider" min="0" max="100" value="0" step="0.1" aria-label="Position de lecture">
                <span id="playerDuration" class="small text-secondary">0:00</span>
            </div>
        </div>
    </div>

    <script>
        const audioPlayer = document.getElementById('sharedAudioElement');
        let currentPlayingButton = null;
        let currentTrackCard = null;
        let currentTrackIndex = -1;
        let isSeeking = false;
        let pendingSeekPercent = null;
        let isPlaylistModalPlaybackActive = false;
        const PLAYER_STORAGE_KEY = 'artium_music_player_state_v1';
        const PLAYER_QUEUE_KEY = 'artium_music_player_queue_v1';
        let currentSortOrder = '{{ sortOrder }}';

        function getPlayerUi() {
            return {
                playerTrackTitle: document.getElementById('playerTrackTitle'),
                playerTrackSubtitle: document.getElementById('playerTrackSubtitle'),
                playerToggleBtn: document.getElementById('playerToggleBtn'),
                playerToggleIcon: document.getElementById('playerToggleIcon'),
                playerPrevBtn: document.getElementById('playerPrevBtn'),
                playerNextBtn: document.getElementById('playerNextBtn'),
                playerSeekSlider: document.getElementById('playerSeekSlider'),
                playerCurrentTime: document.getElementById('playerCurrentTime'),
                playerDuration: document.getElementById('playerDuration')
            };
        }

        function getPlayableCards() {
            return Array.from(document.querySelectorAll('.music-card[data-audio-src]'));
        }

        function formatTime(seconds) {
            if (!Number.isFinite(seconds) || seconds < 0) {
                return '0:00';
            }

            const mins = Math.floor(seconds / 60);
            const secs = Math.floor(seconds % 60).toString().padStart(2, '0');
            return `${mins}:${secs}`;
        }

        function resetAllCardProgress() {
            document.querySelectorAll('.music-progress').forEach(progressBar => {
                progressBar.style.width = '0%';
            });
        }

        function syncCardButtons() {
            document.querySelectorAll('.play-btn').forEach(button => {
                const icon = button.querySelector('i');
                const card = button.closest('.music-card');
                const isCurrent = card && card === currentTrackCard && !audioPlayer.paused;

                if (isCurrent) {
                    if (icon) icon.className = 'bi bi-pause-fill pe-1';
                    button.textContent = ' Pause';
                    if (icon) button.prepend(icon);
                    currentPlayingButton = button;
                } else {
                    if (icon) icon.className = 'bi bi-play-fill pe-1';
                    button.textContent = ' Jouer';
                    if (icon) button.prepend(icon);
                }
            });
        }

        function updateGlobalPlayerUI() {
            const ui = getPlayerUi();
            if (!ui.playerToggleIcon || !ui.playerSeekSlider || !ui.playerCurrentTime || !ui.playerDuration) {
                return;
            }

            if (audioPlayer.paused) {
                ui.playerToggleIcon.className = 'bi bi-play-fill';
            } else {
                ui.playerToggleIcon.className = 'bi bi-pause-fill';
            }

            const duration = audioPlayer.duration || 0;
            const currentTime = audioPlayer.currentTime || 0;
            const progress = duration ? (currentTime / duration) * 100 : 0;

            if (!isSeeking) {
                ui.playerSeekSlider.value = progress;
            }
            ui.playerCurrentTime.textContent = formatTime(currentTime);
            ui.playerDuration.textContent = formatTime(duration);

            if (currentTrackCard) {
                const cardProgress = currentTrackCard.querySelector('.music-progress');
                if (cardProgress) {
                    cardProgress.style.width = `${progress}%`;
                }
            }
        }

        function persistPlayerState() {
            if (!audioPlayer.src) {
                return;
            }

            const ui = getPlayerUi();
            const trackQueue = getPlayableCards().map(card => ({
                src: card.getAttribute('data-audio-src') || '',
                absoluteSrc: card.getAttribute('data-audio-src')
                    ? new URL(card.getAttribute('data-audio-src'), window.location.origin).toString()
                    : '',
                title: card.querySelector('h6 a')?.textContent?.trim() || 'Titre inconnu',
                artist: card.getAttribute('data-artist-name')?.trim() || 'Artiste inconnu'
            })).filter(track => track.src !== '');

            const state = {
                src: audioPlayer.src,
                title: ui.playerTrackTitle?.textContent || 'Titre inconnu',
                artist: ui.playerTrackSubtitle?.textContent || 'Artiste inconnu',
                currentTime: audioPlayer.currentTime || 0,
                isPlaying: !audioPlayer.paused,
                currentTrackIndex,
                trackQueue,
                updatedAt: Date.now()
            };

            localStorage.setItem(PLAYER_STORAGE_KEY, JSON.stringify(state));
            if (trackQueue.length) {
                localStorage.setItem(PLAYER_QUEUE_KEY, JSON.stringify({
                    trackQueue,
                    currentTrackIndex,
                    updatedAt: Date.now()
                }));
            }
        }

        function persistQueueSnapshot() {
            const trackQueue = getPlayableCards().map(card => ({
                src: card.getAttribute('data-audio-src') || '',
                absoluteSrc: card.getAttribute('data-audio-src')
                    ? new URL(card.getAttribute('data-audio-src'), window.location.origin).toString()
                    : '',
                title: card.querySelector('h6 a')?.textContent?.trim() || 'Titre inconnu',
                artist: card.getAttribute('data-artist-name')?.trim() || 'Artiste inconnu'
            })).filter(track => track.src !== '');

            if (!trackQueue.length) {
                return;
            }

            const activeSrc = audioPlayer.src || '';
            const activeIndex = activeSrc
                ? trackQueue.findIndex(track => activeSrc.endsWith(track.src))
                : currentTrackIndex;

            localStorage.setItem(PLAYER_QUEUE_KEY, JSON.stringify({
                trackQueue,
                currentTrackIndex: activeIndex >= 0 ? activeIndex : currentTrackIndex,
                updatedAt: Date.now()
            }));
        }

        function setTrackFromCard(card, shouldAutoplay = true) {
            if (!card) {
                return;
            }

            const ui = getPlayerUi();
            if (!ui.playerTrackTitle || !ui.playerTrackSubtitle || !ui.playerSeekSlider) {
                return;
            }

            const cards = getPlayableCards();
            currentTrackIndex = cards.findIndex(c => c === card);
            currentTrackCard = card;

            const audioSrc = card.getAttribute('data-audio-src');
            const title = card.querySelector('h6 a')?.textContent?.trim() || 'Titre inconnu';
            const artistName = card.getAttribute('data-artist-name')?.trim() || 'Artiste inconnu';

            if (audioPlayer.src !== audioSrc) {
                audioPlayer.src = audioSrc;
                resetAllCardProgress();
                pendingSeekPercent = null;
                ui.playerSeekSlider.value = 0;
            }

            ui.playerTrackTitle.textContent = title;
            ui.playerTrackSubtitle.textContent = artistName;

            audioPlayer.dataset.title = title;
            audioPlayer.dataset.artist = artistName;

            if (shouldAutoplay) {
                audioPlayer.play();
            }

            syncCardButtons();
            updateGlobalPlayerUI();
            persistPlayerState();
            persistQueueSnapshot();
        }

        function playTrackByOffset(offset) {
            const cards = getPlayableCards();
            if (!cards.length) {
                return;
            }

            if (currentTrackIndex === -1) {
                setTrackFromCard(cards[0], true);
                return;
            }

            const nextIndex = (currentTrackIndex + offset + cards.length) % cards.length;
            setTrackFromCard(cards[nextIndex], true);
        }

        function bindPlayButtons() {
            const playButtons = document.querySelectorAll('.play-btn');
            playButtons.forEach(button => {
                button.addEventListener('click', function(e) {
                    e.preventDefault();
                    playPauseMusic(this);
                });
            });
        }

        function updateSortButton() {
            const btn = document.getElementById('toggleSortBtn');
            const icon = btn ? btn.querySelector('i') : null;
            const text = document.getElementById('sortOrderText');

            if (icon && text) {
                if (currentSortOrder === 'DESC') {
                    icon.className = 'bi bi-sort-down';
                    text.textContent = 'Desc';
                } else {
                    icon.className = 'bi bi-sort-up';
                    text.textContent = 'Asc';
                }
            }
        }

        function loadMusicResults() {
            const search = document.getElementById('searchInput')?.value || '';
            const sort = document.getElementById('sortBy')?.value || 'date';
            const hasSearch = search.trim().length > 0;

            const params = new URLSearchParams();
            if (search) params.append('search', search);
            params.append('sort', sort);
            params.append('order', currentSortOrder);

            const tabContent = document.getElementById('musicTabContent');
            if (tabContent) {
                tabContent.innerHTML = '<div class="text-center py-4"><div class="spinner-border" role="status"><span class="visually-hidden">Chargement...</span></div></div>';
            }

            fetch(`{{ path('app_musicfront') }}?${params.toString()}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');

                const newTabContent = doc.querySelector('#musicTabContent');
                const newResults = doc.querySelector('#resultsInfo');

                if (newTabContent && tabContent) {
                    tabContent.innerHTML = newTabContent.innerHTML;
                }

                if (newResults) {
                    const resultsInfo = document.getElementById('resultsInfo');
                    if (resultsInfo) {
                        resultsInfo.innerHTML = newResults.innerHTML;
                    }
                }

                const activeTabId = hasSearch ? '#tab-all' : '#tab-all';
                
                document.querySelectorAll('.nav-link').forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href') === activeTabId) {
                        link.classList.add('active');
                    }
                });
                
                document.querySelectorAll('.tab-pane').forEach(pane => {
                    pane.classList.remove('show', 'active');
                });
                const activePane = document.querySelector(activeTabId);
                if (activePane) {
                    activePane.classList.add('show', 'active');
                }

                updateSortButton();
                bindPlayButtons();
                syncCardButtons();
                persistQueueSnapshot();
            })
            .catch(error => console.error('Error loading results:', error));
        }

        document.addEventListener('DOMContentLoaded', function() {
            bindPlayButtons();
            updateSortButton();
            syncCardButtons();
            bindMainPlayerControls();
            persistQueueSnapshot();

            const searchSortForm = document.getElementById('searchSortForm');
            const sortBy = document.getElementById('sortBy');
            const toggleSortBtn = document.getElementById('toggleSortBtn');
            const searchInput = document.getElementById('searchInput');

            if (searchSortForm) {
                searchSortForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    loadMusicResults();
                });
            }

            if (searchInput) {
                searchInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        loadMusicResults();
                    }
                });
            }

            if (sortBy) {
                sortBy.addEventListener('change', function() {
                    loadMusicResults();
                });
            }

            if (toggleSortBtn) {
                toggleSortBtn.addEventListener('click', function() {
                    currentSortOrder = currentSortOrder === 'DESC' ? 'ASC' : 'DESC';
                    updateSortButton();
                    loadMusicResults();
                });
            }

            // Handle create playlist form with AJAX
            const createPlaylistForm = document.getElementById('createPlaylistForm');
            if (createPlaylistForm) {
                createPlaylistForm.addEventListener('submit', function(e) {
                    e.preventDefault();

                    const formData = new FormData(this);

                    fetch('{{ path("app_playlist_create") }}', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            createPlaylistForm.reset();
                            
                            // Close collapse
                            const collapseElement = document.getElementById('createPlaylistCollapse');
                            if (collapseElement) {
                                collapseElement.classList.remove('show');
                            }
                            
                            // Refresh playlists tab
                            fetch('{{ path("app_musicfront") }}', {
                                headers: {
                                    'X-Requested-With': 'XMLHttpRequest'
                                }
                            })
                            .then(response => response.text())
                            .then(html => {
                                const parser = new DOMParser();
                                const doc = parser.parseFromString(html, 'text/html');
                                const newPlaylistsTab = doc.querySelector('#tab-playlists');
                                const currentPlaylistsTab = document.querySelector('#tab-playlists');
                                if (newPlaylistsTab && currentPlaylistsTab) {
                                    currentPlaylistsTab.innerHTML = newPlaylistsTab.innerHTML;
                                }
                            });
                        } else {
                            alert(data.error || 'Erreur lors de la création de la playlist');
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Une erreur s\'est produite');
                    });
                });
            }
        });

        document.addEventListener('turbo:load', function () {
            if (document.body?.dataset?.route !== 'app_musicfront') {
                return;
            }

            bindPlayButtons();
            updateSortButton();
            syncCardButtons();
            bindMainPlayerControls();
            updateGlobalPlayerUI();
            persistQueueSnapshot();
        });

        let currentPlaylistId = null;

        function loadPlaylistSongs(targetContainer = null) {
            const container = targetContainer || document.getElementById('playlistInlineBody');
            if (!container) {
                return;
            }

            fetch('{{ path("app_playlist_songs", {"id": "__PLAYLIST_ID__"}) }}'.replace('__PLAYLIST_ID__', currentPlaylistId), {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                const songs = data.songs;
                
                if (songs.length === 0) {
                    container.innerHTML = '<p class="text-muted text-center py-4">Aucune musique dans cette playlist</p>';
                    return;
                }

                const removeSongUrlTemplate = "{{ path('app_playlist_remove_song', {'playlistId': 'PLAYLIST_ID', 'musicId': 'MUSIC_ID'}) }}";
                const smartPool = Array.isArray(data.smartPool) ? data.smartPool : [];
                let songsHtml = '<div class="list-group">';

                songsHtml += `
                    <div class="list-group-item bg-light border mb-2">
                        <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                            <span class="fw-semibold small">Mode de lecture playlist</span>
                            <div class="btn-group btn-group-sm" role="group" aria-label="Playback mode">
                                <button type="button" class="btn btn-outline-secondary playlist-mode-btn active" data-mode="normal">Normal</button>
                                <button type="button" class="btn btn-outline-secondary playlist-mode-btn" data-mode="shuffle">Shuffle</button>
                                <button type="button" class="btn btn-outline-secondary playlist-mode-btn" data-mode="smart">Smart Shuffle</button>
                            </div>
                        </div>
                        <div class="small text-muted mt-2">Smart Shuffle ajoute 1 morceau hors playlist toutes les 2 musiques.</div>
                    </div>
                `;
                
                songs.forEach(song => {
                    const safeTitle = String(song.titre || 'Titre inconnu').replace(/"/g, '&quot;');
                    const safeArtist = String(song.artist || 'Artiste inconnu').replace(/"/g, '&quot;');
                    const safeGenre = String(song.genre || '').replace(/"/g, '&quot;');
                    songsHtml += `
                        <div class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>${song.titre}</span>
                                <div class="d-flex gap-2">
                                    <button class="btn btn-sm btn-outline-primary playlist-play-btn" data-audio-id="${song.id}" data-audio-src="${song.audioSrc}" data-title="${safeTitle}" data-artist="${safeArtist}" data-genre="${safeGenre}" data-is-smart-injected="0">
                                        <i class="bi bi-play-fill"></i>
                                    </button>
                                    <form method="post" action="${removeSongUrlTemplate.replace('PLAYLIST_ID', currentPlaylistId).replace('MUSIC_ID', song.id)}" style="display: inline;" onsubmit="return confirm('Êtes-vous sûr?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('remove_song') }}">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    `;
                });
                
                songsHtml += '</div>';
                container.innerHTML = songsHtml;

                const playButtons = container.querySelectorAll('.playlist-play-btn');
                let currentlyPlaying = null;
                let playlistMode = 'normal';
                let currentPlaylistIndex = -1;
                let playedSinceSmartInject = 0;

                const baseQueue = songs.map(song => ({
                    id: String(song.id),
                    audioSrc: song.audioSrc,
                    title: song.titre || 'Titre inconnu',
                    artist: song.artist || 'Artiste inconnu',
                    genre: song.genre || '',
                    isSmartInjected: false,
                }));

                const smartQueue = smartPool.map(song => ({
                    id: String(song.id),
                    audioSrc: song.audioSrc,
                    title: song.titre || 'Titre inconnu',
                    artist: song.artist || 'Artiste inconnu',
                    genre: song.genre || '',
                    isSmartInjected: true,
                }));

                function isTrackInPlaylist(trackId) {
                    return baseQueue.some(item => item.id === String(trackId));
                }

                function resetModeButtons() {
                    container.querySelectorAll('.playlist-mode-btn').forEach(btn => {
                        btn.classList.remove('active', 'btn-primary');
                        btn.classList.add('btn-outline-secondary');
                    });
                }

                function setMode(mode) {
                    playlistMode = mode;
                    playedSinceSmartInject = 0;
                    resetModeButtons();
                    const activeBtn = container.querySelector(`.playlist-mode-btn[data-mode="${mode}"]`);
                    if (activeBtn) {
                        activeBtn.classList.remove('btn-outline-secondary');
                        activeBtn.classList.add('active', 'btn-primary');
                    }
                }

                function syncPlaylistPlayButtons(currentId) {
                    playButtons.forEach(btn => {
                        const icon = btn.querySelector('i');
                        if (!icon) {
                            return;
                        }
                        if (currentId && btn.dataset.audioId === currentId && !audioPlayer.paused) {
                            icon.className = 'bi bi-pause-fill';
                        } else {
                            icon.className = 'bi bi-play-fill';
                        }
                    });
                }

                function setGlobalPlayerMeta(title, artist) {
                    const titleEl = document.getElementById('playerTrackTitle');
                    const artistEl = document.getElementById('playerTrackSubtitle');
                    if (titleEl) {
                        titleEl.textContent = title || 'Titre inconnu';
                    }
                    if (artistEl) {
                        artistEl.textContent = artist || 'Artiste inconnu';
                    }
                    audioPlayer.dataset.title = title || 'Titre inconnu';
                    audioPlayer.dataset.artist = artist || 'Artiste inconnu';
                }

                function getRandomTrack(excludedId = null) {
                    const pool = baseQueue.filter(track => track.id !== excludedId);
                    if (!pool.length) {
                        return null;
                    }
                    return pool[Math.floor(Math.random() * pool.length)];
                }

                function getSmartInjectedTrack() {
                    const candidates = smartQueue.filter(track => track.id !== currentlyPlaying);
                    if (!candidates.length) {
                        return null;
                    }
                    return candidates[Math.floor(Math.random() * candidates.length)];
                }

                function pickNextTrack() {
                    if (!baseQueue.length) {
                        return null;
                    }

                    if (playlistMode === 'shuffle') {
                        return getRandomTrack(currentlyPlaying);
                    }

                    if (playlistMode === 'smart') {
                        if (playedSinceSmartInject >= 2) {
                            const injected = getSmartInjectedTrack();
                            if (injected) {
                                playedSinceSmartInject = 0;
                                return injected;
                            }
                        }

                        if (currentPlaylistIndex < 0) {
                            currentPlaylistIndex = 0;
                        } else {
                            currentPlaylistIndex = (currentPlaylistIndex + 1) % baseQueue.length;
                        }

                        playedSinceSmartInject += 1;
                        return baseQueue[currentPlaylistIndex];
                    }

                    if (currentPlaylistIndex < 0) {
                        currentPlaylistIndex = 0;
                    } else {
                        currentPlaylistIndex = (currentPlaylistIndex + 1) % baseQueue.length;
                    }

                    return baseQueue[currentPlaylistIndex];
                }

                function playTrack(track) {
                    if (!track || !track.audioSrc) {
                        return;
                    }

                    const trackId = String(track.id || '');
                    const inPlaylist = isTrackInPlaylist(trackId);

                    if ((playlistMode === 'normal' || playlistMode === 'shuffle') && !inPlaylist) {
                        const fallbackIndex = currentPlaylistIndex >= 0 ? currentPlaylistIndex : 0;
                        const fallbackTrack = baseQueue[fallbackIndex] || baseQueue[0];
                        if (!fallbackTrack) {
                            return;
                        }
                        track = fallbackTrack;
                    }

                    isPlaylistModalPlaybackActive = true;
                    audioPlayer.src = track.audioSrc;
                    audioPlayer.play().catch(() => {});
                    currentlyPlaying = track.id;

                    const baseIndex = baseQueue.findIndex(item => item.id === track.id);
                    if (baseIndex >= 0) {
                        currentPlaylistIndex = baseIndex;
                    }

                    setGlobalPlayerMeta(track.title, track.artist);
                    syncPlaylistPlayButtons(currentlyPlaying);
                }

                container.querySelectorAll('.playlist-mode-btn').forEach(modeBtn => {
                    modeBtn.addEventListener('click', function () {
                        const mode = this.dataset.mode || 'normal';
                        setMode(mode);
                    });
                });

                playButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const audioSrc = this.getAttribute('data-audio-src');
                        const audioId = this.getAttribute('data-audio-id');
                        const title = this.getAttribute('data-title') || 'Titre inconnu';
                        const artist = this.getAttribute('data-artist') || 'Artiste inconnu';

                        const clickedBaseIndex = baseQueue.findIndex(item => item.id === String(audioId));
                        if (clickedBaseIndex >= 0) {
                            currentPlaylistIndex = clickedBaseIndex;
                        }
                        
                        if (currentlyPlaying === audioId && !audioPlayer.paused) {
                            audioPlayer.pause();
                            this.innerHTML = '<i class="bi bi-play-fill"></i>';
                        } 
                        else if (currentlyPlaying === audioId && audioPlayer.paused) {
                            audioPlayer.play();
                            this.innerHTML = '<i class="bi bi-pause-fill"></i>';
                        } 
                        else {
                            playTrack({
                                id: String(audioId),
                                audioSrc,
                                title,
                                artist,
                                genre: this.getAttribute('data-genre') || '',
                                isSmartInjected: this.getAttribute('data-is-smart-injected') === '1'
                            });
                        }
                    });
                });

                audioPlayer.onended = function() {
                    if (!isPlaylistModalPlaybackActive) {
                        return;
                    }

                    if (!currentPlaylistId || !baseQueue.length) {
                        syncPlaylistPlayButtons(null);
                        currentlyPlaying = null;
                        return;
                    }

                    const nextTrack = pickNextTrack();
                    if (nextTrack) {
                        if ((playlistMode === 'normal' || playlistMode === 'shuffle') && !isTrackInPlaylist(nextTrack.id)) {
                            const safeTrack = baseQueue[currentPlaylistIndex >= 0 ? currentPlaylistIndex : 0] || baseQueue[0];
                            if (safeTrack) {
                                playTrack(safeTrack);
                                return;
                            }
                        }
                        playTrack(nextTrack);
                        return;
                    }

                    syncPlaylistPlayButtons(null);
                    currentlyPlaying = null;
                };

                setMode('normal');
            })
            .catch(error => {
                console.error('Error:', error);
                container.innerHTML = '<p class="text-danger">Erreur lors du chargement de la playlist</p>';
            });
        }

        document.addEventListener('click', function(e) {
            const openBtn = e.target.closest('.playlist-open-inline');
            if (openBtn) {
                const viewer = document.getElementById('playlistInlineViewer');
                const title = document.getElementById('playlistInlineTitle');
                const body = document.getElementById('playlistInlineBody');
                if (!viewer || !title || !body) {
                    return;
                }

                currentPlaylistId = openBtn.getAttribute('data-playlist-id');
                const playlistName = openBtn.getAttribute('data-playlist-name') || 'Playlist';
                title.textContent = `"${playlistName}"`;
                viewer.classList.remove('d-none');
                viewer.scrollIntoView({ behavior: 'smooth', block: 'start' });
                body.innerHTML = '<div class="text-center py-4"><div class="spinner-border" role="status"><span class="visually-hidden">Chargement...</span></div></div>';
                loadPlaylistSongs(body);
                return;
            }

            const closeBtn = e.target.closest('#playlistInlineCloseBtn');
            if (closeBtn) {
                const viewer = document.getElementById('playlistInlineViewer');
                const body = document.getElementById('playlistInlineBody');
                if (viewer) {
                    viewer.classList.add('d-none');
                }
                if (body) {
                    body.innerHTML = '';
                }
                isPlaylistModalPlaybackActive = false;
                currentPlaylistId = null;
            }
        });

        const addSongsModal = document.getElementById('addSongsModal');
        if (addSongsModal) {
            addSongsModal.addEventListener('show.bs.modal', function(event) {
                const button = event.relatedTarget;
                currentPlaylistId = button.getAttribute('data-playlist-id');
                const playlistName = button.getAttribute('data-playlist-name');
                
                const modalLabel = document.getElementById('addSongsModalLabel');
                if (modalLabel) {
                    modalLabel.textContent = `Ajouter des musiques à "${playlistName}"`;
                }

                loadSongsForPlaylist();
            });
        }

        function loadSongsForPlaylist() {
            const modalBody = document.getElementById('addSongsModalBody');
            
            fetch('{{ path("app_musicfront") }}', {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                const parser = new DOMParser();
                const doc = parser.parseFromString(html, 'text/html');
                
                const allGenresTab = doc.querySelector('#tab-all');
                const musicCards = allGenresTab ? allGenresTab.querySelectorAll('.music-card[data-music-id]') : [];
                
                let songsHtml = `
                    <input type="hidden" name="_token" value="{{ csrf_token('add_to_playlist') }}">
                    <input type="hidden" name="playlist_id" value="${currentPlaylistId}">
                    <div class="list-group">
                `;
                
                musicCards.forEach(card => {
                    const musicId = card.getAttribute('data-music-id');
                    const titleElement = card.querySelector('h6 a');
                    const title = titleElement ? titleElement.textContent.trim() : 'Unknown';
                    
                    songsHtml += `
                        <label class="list-group-item">
                            <input class="form-check-input me-2" type="checkbox" name="song_ids[]" value="${musicId}">
                            <span>${title}</span>
                        </label>
                    `;
                });
                
                songsHtml += '</div>';
                modalBody.innerHTML = songsHtml;
                
                // Attach form submit handler
                const addSongsForm = document.getElementById('addSongsForm');
                if (addSongsForm) {
                    addSongsForm.removeEventListener('submit', handleAddSongsSubmit);
                    addSongsForm.addEventListener('submit', handleAddSongsSubmit);
                }
            })
            .catch(error => {
                console.error('Error:', error);
                modalBody.innerHTML = '<p class="text-danger">Erreur lors du chargement des musiques</p>';
            });
        }

        function handleAddSongsSubmit(e) {
            e.preventDefault();
            
            const selectedCheckboxes = document.querySelectorAll('#addSongsModalBody input[name="song_ids[]"]:checked');

            const formData = new FormData();
            const csrfToken = document.querySelector('#addSongsModalBody input[name="_token"]').value;
            formData.append('_token', csrfToken);
            formData.append('playlist_id', currentPlaylistId);
            
            selectedCheckboxes.forEach(checkbox => {
                formData.append('song_ids[]', checkbox.value);
            });

            fetch('{{ path("app_playlist_add_multiple") }}', {
                method: 'POST',
