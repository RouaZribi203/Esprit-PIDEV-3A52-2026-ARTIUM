{% extends 'base_artiste.html.twig' %}

{% block title %}{{ 'Bibliothèque'|trans }}{% endblock %}

{% block artiste_content %}

<div class="card mb-4">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-3">
      <h4 class="mb-0">Ma Bibliothèque</h4>
      <button class="btn btn-success"
              type="button"
              data-bs-toggle="offcanvas"
              data-bs-target="#offcanvasAddLivreFront">
        Ajouter un Livre
      </button>
    </div>

    <div class="row g-3">
      {% if livres is defined and livres|length > 0 %}
        {% for livre in livres %}

          <div class="col-12 col-sm-6 col-md-4">
            <div class="card h-100 shadow-sm border-0 rounded-3 position-relative">
              <div class="card-body d-flex flex-column p-3">

                <div style="position:absolute;top:8px;right:8px;z-index:5;">
                  <div class="dropdown">
                    <a href="#" class="text-muted" data-bs-toggle="dropdown">
                      <i class="bi bi-three-dots-vertical"></i>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">

                      <!-- DETAILS -->
                      <li>
                        <a class="dropdown-item js-show-details"
                           href="#"
                           data-id="{{ livre.id }}"
                           data-titre="{{ livre.titre|e('html_attr') }}"
                           data-date-creation="{{ livre.dateCreation ? livre.dateCreation|date('Y-m-d H:i:s') : '' }}"
                           data-description="{{ livre.description|e('html_attr') }}"
                           data-pdf-url="{{ path('livre_pdf', {'id': livre.id}) }}"
                           data-image="{{ path('livre_image', {'id': livre.id}) }}">
                          Détails
                        </a>
                      </li>

                      <!-- EDIT -->
                      <li>
                        <a class="dropdown-item js-edit-livre"
                           href="#"
                           data-id="{{ livre.id }}"
                           data-titre="{{ livre.titre|e('html_attr') }}"
                           data-description="{{ livre.description|e('html_attr') }}"
                           data-categorie="{{ livre.categorie|e('html_attr') }}"
                           data-prix="{{ livre.prixLocation }}"
                           data-collection="{{ livre.collection ? livre.collection.id : '' }}">
                          Modifier
                        </a>
                      </li>

                      <!-- DELETE -->
                      <li>
                        <a class="dropdown-item text-danger js-delete-livre"
                           href="#"
                           data-id="{{ livre.id }}">
                          Supprimer
                        </a>
                      </li>

                    </ul>
                  </div>
                </div>

                <div class="d-flex flex-column align-items-center text-center">
                  <img src="{{ path('livre_image', {'id': livre.id}) }}"
                       class="rounded mb-3"
                       style="width:140px;height:200px;object-fit:cover;">

                  <h5 class="mb-1 fw-semibold">{{ livre.titre }}</h5>

                  <div class="mb-2 text-muted">
                    Catégorie:
                    <span class="fw-medium text-dark">{{ livre.categorie }}</span>
                  </div>

                  <div class="mb-2">
                    <strong class="text-primary">
                      {{ livre.prixLocation }} €
                    </strong>
                    <small class="text-muted">/ jour</small>
                  </div>

                  <div class="text-muted small mt-2">
                    Collection:
                    <span class="text-dark">
                      {{ livre.collection ? livre.collection.titre : '-' }}
                    </span>
                  </div>
                </div>

              </div>
            </div>
          </div>

        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<!-- ========================= -->
<!-- DETAILS MODAL -->
<!-- ========================= -->
<div class="modal fade" id="livreDetailsModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Détails du livre</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">
        <h5 id="detail-titre">—</h5>
        <p><strong>ID:</strong> <span id="detail-id">—</span></p>
        <p><strong>Date:</strong> <span id="detail-date-creation">—</span></p>
        <p id="detail-description">—</p>

        <img id="detail-image"
             class="img-fluid mb-3"
             style="max-height:200px;">

        <div id="detail-pdf-label"></div>
      </div>

    </div>
  </div>
</div>

<!-- ========================= -->
<!-- OFFCANVAS ADD -->
<!-- ========================= -->
<div class="offcanvas offcanvas-end"
     tabindex="-1"
     id="offcanvasAddLivreFront">

  <div class="offcanvas-header">
    <h5>Ajouter Livre</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">

    {{ form_start(livreForm, {
      action: path('artiste_livre_create'),
      attr: {'enctype': 'multipart/form-data'}
    }) }}

      {{ form_row(livreForm.titre, {'attr': {'class': 'form-control'}}) }}
      {{ form_row(livreForm.description, {'attr': {'class': 'form-control'}}) }}
      {{ form_row(livreForm.image, {'attr': {'class': 'form-control'}}) }}
      {{ form_row(livreForm.fichier_pdf, {'attr': {'class': 'form-control'}}) }}
      {{ form_row(livreForm.categorie, {'attr': {'class': 'form-control'}}) }}
      {{ form_row(livreForm.prix_location, {'attr': {'class': 'form-control'}}) }}
      {{ form_row(livreForm.collection, {'attr': {'class': 'form-select'}}) }}

      <button type="submit" class="btn btn-primary w-100">
        Enregistrer
      </button>

    {{ form_end(livreForm) }}

  </div>
</div>

<!-- ========================= -->
<!-- OFFCANVAS EDIT -->
<!-- ========================= -->
<div class="offcanvas offcanvas-end"
     tabindex="-1"
     id="offcanvasEditLivreFront">

  <div class="offcanvas-header">
    <h5>Modifier Livre</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
  </div>

  <div class="offcanvas-body">
    <form id="editLivreFormFront"
          method="post"
          enctype="multipart/form-data">

      <input type="text" name="livre[titre]" class="form-control mb-3">
      <textarea name="livre[description]" class="form-control mb-3"></textarea>
      <input type="file" name="livre[image]" class="form-control mb-3">
      <input type="file" name="livre[fichier_pdf]" class="form-control mb-3">
      <input type="text" name="livre[categorie]" class="form-control mb-3">
      <input type="number" step="0.01"
             name="livre[prix_location]"
             class="form-control mb-3">

      <select name="livre[collection]" class="form-select mb-3">
        {% for coll in collections %}
          <option value="{{ coll.id }}">{{ coll.titre }}</option>
        {% endfor %}
      </select>

      <button type="submit" class="btn btn-primary w-100">
        Enregistrer
      </button>

    </form>
  </div>
</div>

<script>
document.addEventListener('click', function(e){

  // DETAILS
  const detailsBtn = e.target.closest('.js-show-details');
  if (detailsBtn) {
    e.preventDefault();
    const d = detailsBtn.dataset;

    document.getElementById('detail-id').textContent = d.id;
    document.getElementById('detail-titre').textContent = d.titre;
    document.getElementById('detail-date-creation').textContent = d.dateCreation;
    document.getElementById('detail-description').textContent = d.description;
    document.getElementById('detail-image').src = d.image;
    document.getElementById('detail-pdf-label').innerHTML =
      '<iframe src="' + d.pdfUrl + '" style="width:100%;height:300px;border:0;"></iframe>';

    new bootstrap.Modal(document.getElementById('livreDetailsModal')).show();
  }

  // EDIT (FIXED PREFILL)
  const editBtn = e.target.closest('.js-edit-livre');
  if (editBtn) {
    e.preventDefault();

    const d = editBtn.dataset;
    const form = document.getElementById('editLivreFormFront');

    form.action = "/artiste-bibliotheque/livre/" + d.id + "/edit";

    form.querySelector('[name="livre[titre]"]').value = d.titre || '';
    form.querySelector('[name="livre[description]"]').value = d.description || '';
    form.querySelector('[name="livre[categorie]"]').value = d.categorie || '';
    form.querySelector('[name="livre[prix_location]"]').value = d.prix || '';
    form.querySelector('[name="livre[collection]"]').value = d.collection || '';

    bootstrap.Offcanvas.getOrCreateInstance(
      document.getElementById('offcanvasEditLivreFront')
    ).show();
  }

  // DELETE
  const deleteBtn = e.target.closest('.js-delete-livre');
  if (deleteBtn) {
    e.preventDefault();
    if (!confirm('Êtes-vous sûr ?')) return;

    const id = deleteBtn.dataset.id;
    const form = document.createElement('form');
    form.method = 'post';
    form.action = "/artiste-bibliotheque/livre/" + id + "/delete";
    document.body.appendChild(form);
    form.submit();
  }

});
</script>

{% endblock %}
