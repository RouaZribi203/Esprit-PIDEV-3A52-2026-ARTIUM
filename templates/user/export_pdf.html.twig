<style>
    .pdf-logo {
        width: 110px;
        margin-bottom: 10px;
        display: block;
        margin-left: auto;
        margin-right: auto;
    }
    .pdf-title {
        text-align: center;
        font-size: 22px;
        font-weight: bold;
        color: #2c3e50;
        margin-bottom: 12px;
        margin-top: 0;
        letter-spacing: 1px;
    }
    .confidential-banner {
        background: #e74c3c;
        color: #fff;
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        padding: 8px 0;
        margin-bottom: 18px;
        letter-spacing: 2px;
        border-radius: 6px;
        box-shadow: 0 2px 6px rgba(44,62,80,0.08);
    }
    .pdf-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        margin-top: 0;
        box-shadow: 0 2px 8px rgba(44,62,80,0.08);
        background: #fff;
        border-radius: 8px;
        overflow: hidden;
    }
    .pdf-table th, .pdf-table td {
        border: 1px solid #dee2e6;
        padding: 8px 10px;
        text-align: left;
        vertical-align: middle;
    }
    .pdf-table th {
        background: #2979ff;
        color: #fff;
        font-weight: 700;
        border-bottom: 2px solid #1565c0;
        text-align: center;
        letter-spacing: 0.5px;
    }
    .pdf-table tbody tr:nth-child(even) {
        background: #f0f6ff;
    }
    .pdf-table tbody tr:nth-child(odd) {
        background: #ffffff;
    }
    .pdf-table tbody tr:hover {
        background: #e3f2fd;
    }
    .pdf-table td {
        color: #222;
        font-size: 13px;
    }
    .pdf-footer {
        margin-top: 28px;
        font-size: 13px;
        color: #888;
        text-align: right;
        border-top: 1px solid #dee2e6;
        padding-top: 10px;
    }
    .pdf-signature {
        margin-top: 18px;
        text-align: left;
        font-size: 14px;
        color: #2c3e50;
    }
</style>


<div class="pdf-title">
    {% if type == 'artistes' %}
        Liste des Artistes
    {% else %}
        Liste des Amateurs
    {% endif %}
</div>
<table class="pdf-table">
    <thead>
        <tr>
            <th style="width: 4%;">#</th>
            <th style="width: 14%;">Nom</th>
            <th style="width: 14%;">Prénom</th>
            <th style="width: 20%;">Email</th>
            <th style="width: 10%;">Téléphone</th>
            <th style="width: 10%;">Ville</th>
            <th style="width: 12%;">Date inscription</th>
            <th style="width: 8%;">Statut</th>
            {% if type == 'artistes' %}
                <th style="width: 8%;">Spécialité</th>
            {% else %}
                <th style="width: 8%;">Centre d'intérêt</th>
            {% endif %}
        </tr>
    </thead>
    <tbody>
    {% for user in users %}
        <tr>
            <td>{{ loop.index }}</td>
            <td>{{ user.nom }}</td>
            <td>{{ user.prenom }}</td>
            <td>{{ user.email }}</td>
            <td>{{ user.numTel }}</td>
            <td>{{ user.ville }}</td>
            <td>{{ user.dateInscription ? user.dateInscription|date('d/m/Y') : '-' }}</td>
            <td>{{ user.statut.value }}</td>
            {% if type == 'artistes' %}
                <td>
                    {% if user.specialite is iterable %}
                        {{ user.specialite|map(s => attribute(s, 'value'))|join(', ') }}
                    {% elseif user.specialite is defined and user.specialite is not null and attribute(user.specialite, 'value') is defined %}
                        {{ attribute(user.specialite, 'value') }}
                    {% else %}
                        {{ user.specialite ?? '-' }}
                    {% endif %}
                </td>
            {% else %}
                <td>
                    {% if user.centreInteret is iterable %}
                        {{ user.centreInteret|map(ci => attribute(ci, 'value'))|join(', ') }}
                    {% elseif user.centreInteret is defined and user.centreInteret is not null and attribute(user.centreInteret, 'value') is defined %}
                        {{ attribute(user.centreInteret, 'value') }}
                    {% else %}
                        {{ user.centreInteret ?? '-' }}
                    {% endif %}
                </td>
            {% endif %}
        </tr>
    {% endfor %}
    </tbody>
</table>
<div class="pdf-footer">
    Exporté le {{ "now"|date('d/m/Y H:i') }}
    <br>Par : {{ app.user.nom ~ ' ' ~ app.user.prenom }}
    <br>Document à usage strictement confidentiel.
</div>
<div class="pdf-signature">
    Signature : ____________________________
</div>
