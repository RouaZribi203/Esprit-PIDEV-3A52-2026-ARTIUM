{% extends 'base_amateur.html.twig' %}

{% block title %}{{ 'Bibliothèque'|trans }}{% endblock %}

{% block amateur_content %}
    <div class="card h-100" data-library-root>
    <style>
        /* Library card layout tweaks: keeps cards consistent and images cropped */
        .library-cover{height:220px;overflow:hidden}
        .library-cover img{width:100%;height:100%;object-fit:cover;display:block}
        .library-card .card-body{min-height:220px;display:flex;flex-direction:column}
        .library-description{display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
        .library-card h6{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
        .library-details div{margin-bottom:.25rem}
        .library-remaining{font-size:.85rem}
        .library-card .btn{min-width:92px}
        @media (max-width:576px){.library-cover{height:180px}.library-card .card-body{min-height:200px}}
        /* Keep modal body scrollable so embedded PDF scrolls inside the details modal */
        [data-library-root] .modal-body{max-height:calc(100vh - 200px);overflow:auto}
        [data-library-root] .library-pdf{overflow:auto}
      </style>
      <div class="card-header d-sm-flex align-items-center text-center justify-content-sm-between border-0 pb-0">
        <div>
          <h1 class="h4 card-title mb-1">Bibliotheque numerique</h1>
          <p class="small text-muted mb-0">Explore, view details, and rent ebooks instantly.</p>
        </div>
        <form class="d-flex mt-3 mt-sm-0" role="search" method="get" action="{{ path('app_bibliofront') }}">
          <input class="form-control form-control-sm me-2" name="q" type="search" placeholder="Search title" aria-label="Search" value="{{ search_q|default('') }}">
          <select name="category" class="form-select form-select-sm me-2">
            <option value="">All categories</option>
            {% for cat in categories|default([]) %}
              <option value="{{ cat }}" {% if cat == search_category %}selected{% endif %}>{{ cat }}</option>
            {% endfor %}
          </select>
          <button class="btn btn-sm btn-primary ms-2" type="submit">Search</button>
        </form>
      </div>
      <div class="card-body">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
          <span class="badge bg-primary-subtle text-primary">Ebooks</span>
          <span class="badge bg-info-subtle text-info">Instant access</span>
          <span class="badge bg-success-subtle text-success">Rent & read</span>
        </div>
        <div class="row g-4">
          {% for livre in livres %}
            <div class="col-sm-6 col-xl-4">
              <div
                class="card h-100 library-card"
                data-book-card
                data-book-id="book-{{ livre.id }}"
                data-title="{{ livre.titre|e('html_attr') }}"
                data-author="{{ (livre.collection and livre.collection.artiste) ? (livre.collection.artiste.prenom ~ ' ' ~ livre.collection.artiste.nom)|e('html_attr') : '' }}"
                data-pages=""
                data-category="{{ livre.categorie|e('html_attr') }}"
                data-price="{{ livre.prixLocation is not null ? (livre.prixLocation|number_format(2, ',', '.')) : '' }}"
                data-price-value="{{ livre.prixLocation is not null ? livre.prixLocation : '' }}"
                data-duration-days="7"
                data-pdf-url="{{ livre.fichierPdf ? path('livre_pdf', {'id': livre.id})|e('html_attr') : '' }}"
                data-initial-status="{{ livreStatus[livre.id] is defined ? livreStatus[livre.id] : 'available' }}"
                data-active-date="{{ livreActiveDate[livre.id] is defined ? livreActiveDate[livre.id] : '' }}"
                data-expiration-date="{{ livreExpirationDate[livre.id] is defined ? livreExpirationDate[livre.id] : '' }}"
                data-rental-days="{{ livreRentalDays[livre.id] is defined ? livreRentalDays[livre.id] : '' }}"
                data-remaining-days="{{ livreRemainingDays[livre.id] is defined ? livreRemainingDays[livre.id] : '' }}"
              >
                
                <div class="position-relative library-cover">
                  <img class="img-fluid rounded-top" src="{{ livre.id ? path('livre_image', {'id': livre.id}) : asset('assetsfront/images/events/01.jpg') }}" alt="Couverture {{ livre.titre }}">
                  {% set status = livreStatus[livre.id] is defined ? livreStatus[livre.id] : 'available' %}
                  {% if status == 'available' %}
                    <span class="badge bg-success text-white mt-2 me-2 position-absolute top-0 end-0" data-book-status>Available</span>
                  {% elseif status == 'rented_by_you' %}
                    <span class="badge bg-warning text-dark mt-2 me-2 position-absolute top-0 end-0" data-book-status>Rented (you)</span>
                  {% else %}
                    <span class="badge bg-warning text-dark mt-2 me-2 position-absolute top-0 end-0" data-book-status>Rented</span>
                  {% endif %}
                </div>
                <div class="card-body d-flex flex-column">
                  <h6 class="mt-2 mb-1">{{ livre.titre }}</h6>
                  <p class="small text-muted mb-2">by {{ (livre.collection and livre.collection.artiste) ? (livre.collection.artiste.prenom ~ ' ' ~ livre.collection.artiste.nom) : '' }}</p>
                  <div class="d-flex flex-wrap gap-2 mb-2">
                    <span class="badge bg-light text-dark">{{ livre.categorie }}</span>
                  </div>
                  <p class="library-description mb-3">{{ livre.description ? (livre.description|length > 200 ? livre.description[:200] ~ '…' : livre.description) : '' }}</p>
                  <div class="d-flex align-items-center justify-content-between mb-3">
                    <div>
                      <small class="text-muted d-block">Rental price</small>
                      <span class="fw-semibold">{{ livre.prixLocation is not null ? (livre.prixLocation|number_format(2, ',', '.') ~ '€') : '' }}</span>
                    </div>
                    <div class="text-end">
                      <small class="text-muted d-block">Access</small>
                      <span class="fw-semibold">Instant</span>
                    </div>
                  </div>
                  <div class="mt-auto d-flex align-items-center justify-content-between">
                    <small class="text-muted library-remaining" data-book-remaining hidden></small>
                    <div class="d-flex gap-2">
                      <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#book-{{ livre.id }}-modal">View Details</button>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="modal fade" id="book-{{ livre.id }}-modal" tabindex="-1" aria-labelledby="book-{{ livre.id }}-modal-label" aria-hidden="true" data-book-modal data-book-id="book-{{ livre.id }}">
              <div class="modal-dialog modal-dialog-centered modal-lg">
                <div class="modal-content">
                  <div class="modal-header">
                    <h5 class="modal-title" id="book-{{ livre.id }}-modal-label">{{ livre.titre }}</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                  </div>
                  <div class="modal-body">
                    <div class="row g-4">
                      <div class="col-md-4">
                        <img class="img-fluid rounded" src="{{ livre.id ? path('livre_image', {'id': livre.id}) : asset('assetsfront/images/events/01.jpg') }}" alt="Couverture {{ livre.titre }}">
                      </div>
                      <div class="col-md-8">
                        <p class="small text-muted mb-2">Author</p>
                        <p>{{ livre.description ?: '' }}</p>
                        <div class="library-details">
                          <div><span class="fw-semibold">Author:</span> {{ (livre.collection and livre.collection.artiste) ? (livre.collection.artiste.prenom ~ ' ' ~ livre.collection.artiste.nom) : '' }}</div>
                          <div><span class="fw-semibold">Category:</span> {{ livre.categorie }}</div>
                          <div><span class="fw-semibold">Rental price:</span> {{ livre.prixLocation is not null ? (livre.prixLocation|number_format(2, ',', '.') ~ '€') : '' }}</div>
                          <div><span class="fw-semibold">Rental start date:</span> <span data-book-field="start">{{ livreActiveDate[livre.id] is defined ? livreActiveDate[livre.id] : 'Not rented' }}</span></div>
                          <div><span class="fw-semibold">Rental expiration date:</span> <span data-book-field="expiration">{{ livreExpirationDate[livre.id] is defined ? livreExpirationDate[livre.id] : 'Not rented' }}</span></div>
                          <div><span class="fw-semibold">Current status:</span> <span data-book-field="status">{{ (livreStatus[livre.id] is defined and livreStatus[livre.id] == 'available') ? 'Available' : 'Rented' }}</span></div>
                        </div>
                        <div class="alert alert-warning small mt-3 mb-0" data-book-expired-message hidden>Rental expired. The book is available again.</div>
                      </div>
                    </div>
                      <div class="mt-4">
                      <div class="d-flex flex-wrap align-items-center gap-2">
                        <span class="text-muted small" data-book-lock-message hidden>Rent this book to access the content.</span>
                        <button class="btn btn-sm btn-outline-secondary ms-2" type="button" data-book-rent data-book-id="{{ livre.id }}">Louer</button>
                      </div>
                      {% if livre.fichierPdf %}
                        <div class="library-pdf mt-3 position-relative" style="height:480px;">
                          <iframe title="{{ livre.titre }} PDF" src="{{ path('livre_pdf', {'id': livre.id}) }}" class="library-pdf-frame w-100 h-100" style="border:0;" ></iframe>
                        </div>
                      {% endif %}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {% else %}
            <div class="col-12"><p class="text-muted">No books available.</p></div>
          {% endfor %}
        </div>
      </div>
    </div>

        {# Offcanvas rent UI (copied pattern from bibliothequeartiste modifier offcanvas) #}
        <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasRentLivre" aria-labelledby="offcanvasRentLivreLabel">
          <div class="offcanvas-header">
            <h5 id="offcanvasRentLivreLabel">Louer le livre</h5>
            <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
          </div>
          <div class="offcanvas-body">
            <form id="rentLivreForm" method="post" action="" class="row g-3">
              <input type="hidden" name="id" value="" />
              <div class="col-12">
                <label class="form-label">Titre</label>
                <input type="text" class="form-control" name="titre">
              </div>
              <div class="col-6">
                <label class="form-label">Prix / jour</label>
                <div class="form-control-plaintext prix-par-jour">-</div>
                <input type="hidden" name="prix_par_jour" value="">
              </div>
              <div class="col-6">
                <label class="form-label">Nombre de jours</label>
                <input type="number" min="1" step="1" value="1" class="form-control" name="nombre_jours">
              </div>
              <div class="col-12">
                <label class="form-label">Total</label>
                <div class="fw-semibold rental-total">0.00€</div>
              </div>
              <div class="col-12 d-flex justify-content-end">
                <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="offcanvas">Annuler</button>
                <button type="submit" class="btn btn-primary">Confirmer la location</button>
              </div>
            </form>
          </div>
        </div>

        {% block javascripts %}
          <script>
            // Use the same offcanvas prefill pattern as in bibliothequeartiste
            document.addEventListener('click', function(e){
              const btn = e.target.closest('[data-book-rent]');
              if (!btn) return;
              e.preventDefault();

              const form = document.getElementById('rentLivreForm');
              if (!form) return;

              const dataset = btn.dataset || {};
              const id = dataset.bookId || btn.getAttribute('data-book-id') || '';
              // try to find the original card element by its data-book-id="book-<id>"
              const card = document.querySelector('[data-book-id="book-' + id + '"]') || btn.closest('[data-book-card]');
              const titre = dataset.bookTitle || dataset.bookTitre || (card ? (card.dataset.title || '') : '') || '';
              const prixRaw = (card ? (card.dataset.price || '') : '') || '';
              const prixValue = (card ? (card.dataset.priceValue || '') : '') || prixRaw || '';
              const status = (card ? (card.dataset.initialStatus || '') : '') || '';

              // if book already rented, show notification
              if (status && status !== 'available') {
                alert('Livre déjà loué');
                return;
              }

              const prix = prixRaw;

              // set form action to rent endpoint (frontend confirm)
              form.action = id ? ('/user-bibliotheque/louer/' + id + '/confirm') : '';
              form.querySelector('[name="id"]').value = id;
              const titreEl = form.querySelector('[name="titre"]'); if (titreEl) titreEl.value = titre || '';
              const prixDisplay = form.querySelector('.prix-par-jour'); if (prixDisplay) prixDisplay.textContent = (prixValue !== '' ? parseFloat(prixValue).toFixed(2) + ' €' : '-');
              const prixHidden = form.querySelector('[name="prix_par_jour"]'); if (prixHidden) prixHidden.value = prixValue;

              const qty = form.querySelector('[name="nombre_jours"]');
              function updateTotal(){
                const n = Math.max(1, parseInt(qty.value, 10) || 1);
                const p = parseFloat((prixValue || prix || '').toString().replace(',', '.')) || 0;
                const total = (n * p).toFixed(2) + '€';
                const totalEl = form.querySelector('.rental-total'); if (totalEl) totalEl.textContent = total;
              }
              if (qty) { qty.addEventListener('input', updateTotal); updateTotal(); }

            // populate details when a book modal is shown
            document.querySelectorAll('[data-book-modal]').forEach(function(modalEl){
              modalEl.addEventListener('show.bs.modal', function (ev) {
                const id = modalEl.dataset.bookId || (modalEl.id || '').replace('book-','').replace('-modal','');
                const card = document.querySelector('[data-book-id="book-' + id + '"]');
                if (!card) return;
                const status = card.dataset.initialStatus || 'available';
                const durationEl = modalEl.querySelector('[data-book-field="duration"]');
                const startEl = modalEl.querySelector('[data-book-field="start"]');
                const expEl = modalEl.querySelector('[data-book-field="expiration"]');
                const remEl = modalEl.querySelector('[data-book-field="remaining"]');

                const days = card.dataset.rentalDays || card.dataset.durationDays || '7';
                if (durationEl) durationEl.textContent = days + ' days';

                const start = card.dataset.activeDate || '';
                if (startEl) startEl.textContent = start || 'Not rented';

                let expiration = card.dataset.expirationDate || '';
                if (!expiration && start) {
                  try {
                    const d = new Date(start.replace(' ', 'T'));
                    d.setDate(d.getDate() + parseInt(days,10));
                    expiration = d.toISOString().slice(0,19).replace('T',' ');
                  } catch(e){ expiration = ''; }
                }
                if (expEl) expEl.textContent = expiration || 'Not rented';

                if (remEl) {
                  if (expiration) {
                    const now = new Date();
                    const exp = new Date(expiration.replace(' ', 'T'));
                    const diffMs = Math.max(0, exp - now);
                    const diffDays = Math.ceil(diffMs / (1000*60*60*24));
                    remEl.textContent = diffDays + ' days';
                  } else {
                    remEl.textContent = '-';
                  }
                }
                // update status text inside modal
                const statusEl = modalEl.querySelector('[data-book-field="status"]');
                if (statusEl) statusEl.textContent = (status === 'available' ? 'Available' : 'Rented');
              });
            });

              // if a modal is open (we opened the offcanvas from inside a modal), hide it so inputs are focusable
              const openModal = document.querySelector('.modal.show');
              if (openModal) {
                try {
                  const modalInst = bootstrap.Modal.getInstance(openModal) || new bootstrap.Modal(openModal);
                  modalInst.hide();
                } catch (err) {
                  // ignore
                }
              }

              const off = bootstrap.Offcanvas.getOrCreateInstance(document.getElementById('offcanvasRentLivre'));
              off.show();

              // intercept submit to call JSON endpoint and update UI
              form.addEventListener('submit', function submitHandler(ev){
                ev.preventDefault();
                const action = form.action;
                const fd = new FormData(form);
                fetch(action, { method: 'POST', body: fd, credentials: 'same-origin' })
                  .then(r => r.json())
                  .then(json => {
                    if (json.success) {
                          // update card and modal status to 'Loué'
                          if (card) {
                            const statusBadge = card.querySelector('[data-book-status]');
                            if (statusBadge) { statusBadge.className = 'badge bg-success text-white mt-2 me-2 position-absolute top-0 end-0'; statusBadge.textContent = 'Rented'; }
                            card.dataset.initialStatus = 'unavailable';
                            // store active start/expiration on the card for later detail views
                            if (json.start_date) card.dataset.activeDate = json.start_date;
                            if (json.expiration_date) card.dataset.expirationDate = json.expiration_date;
                            if (json.nombre_jours) card.dataset.rentalDays = json.nombre_jours;
                          }
                          // update the details modal if open
                          const modalEl = document.getElementById('book-' + id + '-modal');
                          if (modalEl) {
                            const startEl = modalEl.querySelector('[data-book-field="start"]');
                            const expEl = modalEl.querySelector('[data-book-field="expiration"]');
                            const durEl = modalEl.querySelector('[data-book-field="duration"]');
                            const remEl = modalEl.querySelector('[data-book-field="remaining"]');
                            if (durEl && json.nombre_jours) durEl.textContent = json.nombre_jours + ' days';
                            if (startEl && json.start_date) startEl.textContent = json.start_date;
                            if (expEl && json.expiration_date) expEl.textContent = json.expiration_date;
                            if (remEl && json.expiration_date) {
                              const now = new Date();
                              const exp = new Date(json.expiration_date.replace(' ', 'T'));
                              const diffMs = Math.max(0, exp - now);
                              const diffDays = Math.ceil(diffMs / (1000*60*60*24));
                              remEl.textContent = diffDays + ' days';
                            }
                          }
                      // hide offcanvas
                      const offInst = bootstrap.Offcanvas.getOrCreateInstance(document.getElementById('offcanvasRentLivre'));
                      offInst.hide();
                      // refresh page to reflect server state (optional)
                      // location.reload();
                    } else {
                      alert(json.message || 'Erreur lors de la location');
                    }
                  })
                  .catch(() => { alert('Erreur réseau lors de la confirmation'); });

                // remove this handler after first submit to avoid duplicate handlers
                form.removeEventListener('submit', submitHandler);
              });

            });
          </script>
        {% endblock %}
      {% endblock %}

