							<!-- Photographies tab START -->
							<div class="tab-pane fade" id="tab-3">
								<div class="row g-3 align-items-start">
									{% if favoritesPhotographies is not empty %}
										{% for oeuvre in favoritesPhotographies %}
											<div class="col-6 col-lg-3 position-relative" data-favorite-card data-oeuvre-id="{{ oeuvre.id }}">
												<div class="position-absolute bottom-0 end-0">
													<div class="dropdown mb-2 me-3">
													<a href="#" class="icon-sm bg-primary text-white rounded-circle" id="photoActionEdit{{ oeuvre.id }}" data-bs-toggle="dropdown" aria-expanded="false" data-turbo="false">
															<i class="bi bi-pencil-fill"></i>
														</a>
														<ul class="dropdown-menu dropdown-menu-end" aria-labelledby="photoActionEdit{{ oeuvre.id }}">
													<li>
														<a class="dropdown-item favorite-remove-toggle" href="#" data-oeuvre-id="{{ oeuvre.id }}" data-favorited="true">
															<i class="bi bi-star-fill text-warning fa-fw pe-1"></i> Retirer des favoris
														</a>
													</li>
														</ul>
													</div>
												</div>
												{% if oeuvre.image %}
													<a href="#" class="favorite-post-open" data-bs-toggle="modal" data-bs-target="#favorisPostModal{{ oeuvre.id }}">
														<img class="rounded img-fluid" src="{{ path('favoris_oeuvre_image', {'id': oeuvre.id}) }}" alt="{{ oeuvre.titre }}">
													</a>
												{% else %}
													<a href="#" class="favorite-post-open" data-bs-toggle="modal" data-bs-target="#favorisPostModal{{ oeuvre.id }}">
