{% extends 'base_amateur.html.twig' %}

{% block title %}{{ 'Bibliothèque'|trans }}{% endblock %}

{% block amateur_content %}
    <div class="card h-100">
      <div class="card-header d-sm-flex align-items-center text-center justify-content-sm-between border-0 pb-0">
        <div>
          <h1 class="h4 card-title mb-1">Bibliotheque</h1>
          <p class="small text-muted mb-0">Browse the collection and open a book to see details and rent it.</p>
        </div>
        <form class="d-flex mt-3 mt-sm-0" role="search">
          <input class="form-control form-control-sm" type="search" placeholder="Search title, author" aria-label="Search">
          <button class="btn btn-sm btn-primary ms-2" type="submit">Search</button>
        </form>
      </div>
      <div class="card-body">
        <div class="row g-4">
          <div class="col-sm-6 col-xl-4">
            <div class="card h-100">
              <div class="position-relative">
                <a href="{{ path('app_bookdetails') }}#book-1">
                  <img class="img-fluid rounded-top" src="assets/images/events/01.jpg" alt="The Silent Library cover">
                </a>
                <span class="badge bg-success text-white mt-2 me-2 position-absolute top-0 end-0">Available</span>
              </div>
              <div class="card-body">
                <h6 class="mt-2 mb-1">
                  <a href="{{ path('app_bookdetails') }}#book-1">The Silent Library</a>
                </h6>
                <p class="small text-muted mb-2">by Lina Kacem</p>
                <ul class="list-inline small text-muted mb-2">
                  <li class="list-inline-item"><i class="bi bi-book"></i> Fiction</li>
                  <li class="list-inline-item"><i class="bi bi-translate"></i> French</li>
                  <li class="list-inline-item"><i class="bi bi-hash"></i> 320 pages</li>
                </ul>
                <p class="small mb-3">A quiet town hides a secret archive where every book changes its reader.</p>
                <div class="d-flex align-items-center justify-content-between">
                  <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#book-1-modal">View details</button>
                </div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-xl-4">
            <div class="card h-100">
              <div class="position-relative">
                <a href="{{ path('app_bookdetails') }}#book-2">
                  <img class="img-fluid rounded-top" src="assets/images/events/02.jpg" alt="Atlas of Light cover">
                </a>
                <span class="badge bg-success text-white mt-2 me-2 position-absolute top-0 end-0">Available</span>
              </div>
              <div class="card-body">
                <h6 class="mt-2 mb-1">
                  <a href="{{ path('app_bookdetails') }}#book-2">Atlas of Light</a>
                </h6>
                <p class="small text-muted mb-2">by Omar Benali</p>
                <ul class="list-inline small text-muted mb-2">
                  <li class="list-inline-item"><i class="bi bi-book"></i> History</li>
                  <li class="list-inline-item"><i class="bi bi-translate"></i> Arabic</li>
                  <li class="list-inline-item"><i class="bi bi-hash"></i> 412 pages</li>
                </ul>
                <p class="small mb-3">A journey through coastal cities and the artists who shaped them.</p>
                <div class="d-flex align-items-center justify-content-between">
                  <button class="btn btn-sm btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#book-2-modal">View details</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="book-1-modal" tabindex="-1" aria-labelledby="book-1-modal-label" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="book-1-modal-label">The Silent Library</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <img class="img-fluid rounded mb-3" src="assets/images/events/01.jpg" alt="The Silent Library cover">
            <p class="small text-muted mb-2">Author introduction</p>
            <p class="mb-0">In this quiet-town tale, Lina Kacem invites readers into a hidden archive where every shelf whispers a truth. The story follows a young curator who learns that books can be mirrors, and that the courage to read is the courage to change.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="modal fade" id="book-2-modal" tabindex="-1" aria-labelledby="book-2-modal-label" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="book-2-modal-label">Atlas of Light</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <img class="img-fluid rounded mb-3" src="assets/images/events/02.jpg" alt="Atlas of Light cover">
            <p class="small text-muted mb-2">Author introduction</p>
            <p class="mb-0">Omar Benali blends travel notes with archival sketches to trace the artists who shaped luminous coastal cities. This resume is an invitation to follow light itself through history, memory, and the maps we carry within.</p>
          </div>
        </div>
      </div>
    </div>
{% endblock %}

