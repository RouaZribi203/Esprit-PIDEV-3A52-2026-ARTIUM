{% extends 'base_amateur.html.twig' %}

{% block title %}{{ 'Favoris'|trans }}{% endblock %}

{% block amateur_content %}
<!-- Card START -->
				<div class="card">
					<!-- Card header START -->
					<div class="card-header d-sm-flex text-center align-items-center justify-content-between border-0 pb-0">
						<h1 class="card-title h4">Favoris</h1>
						
					</div>
					<!-- Card header START -->
					<!-- Card body START -->
					<div class="card-body">

						<!-- Tab nav line START -->
						<ul class="nav nav-tabs nav-bottom-line justify-content-center justify-content-md-start">
							<li class="nav-item"> <a class="nav-link active" data-bs-toggle="tab" href="#tab-0"> Toutes les oeuvres </a> </li>
							<li class="nav-item"> <a class="nav-link" data-bs-toggle="tab" href="#tab-1"> Peintures </a> </li>
							<li class="nav-item"> <a class="nav-link" data-bs-toggle="tab" href="#tab-2"> Sculptures </a> </li>
							<li class="nav-item"> <a class="nav-link" data-bs-toggle="tab" href="#tab-3"> Photographies </a> </li>
						</ul>
						<!-- Tab nav line START -->

						<!-- Album Tab content START -->
						<div class="tab-content mb-0 pb-0">

							<!-- Toutes les oeuvres tab START -->
							<div class="tab-pane fade show active" id="tab-0">
								<div class="row g-3">
									{% if favorites is not empty %}
										{% for oeuvre in favorites %}
											<div class="col-6 col-lg-3 position-relative">
												<div class="position-absolute bottom-0 end-0">
													<div class="dropdown mb-2 me-3">
														<a href="#" class="icon-sm bg-primary text-white rounded-circle" id="photoActionEditAll{{ oeuvre.id }}" data-bs-toggle="dropdown" aria-expanded="false">
															<i class="bi bi-pencil-fill"></i>
														</a>
														<ul class="dropdown-menu dropdown-menu-end" aria-labelledby="photoActionEditAll{{ oeuvre.id }}">
															<li><a class="dropdown-item" href="#"><i class="bi bi-tag fa-fw pe-1"></i> Remove from favorites</a></li>
														</ul>
													</div>
												</div>
												{% if processedOeuvres[oeuvre.id] is defined %}
													<a href="data:{{ processedOeuvres[oeuvre.id].mimeType ?? 'image/jpeg' }};base64,{{ processedOeuvres[oeuvre.id].imageBase64 }}" data-gallery="favorites" data-glightbox="description: .custom-desc-all-{{ oeuvre.id }}; descPosition: left;">
														<img class="rounded img-fluid" src="data:{{ processedOeuvres[oeuvre.id].mimeType ?? 'image/jpeg' }};base64,{{ processedOeuvres[oeuvre.id].imageBase64 }}" alt="{{ oeuvre.titre }}">
													</a>
												{% else %}
													<a href="{{ asset('assetsfront/images/albums/01.jpg') }}" data-gallery="favorites" data-glightbox="description: .custom-desc-all-{{ oeuvre.id }}; descPosition: left;">
														<img class="rounded img-fluid" src="{{ asset('assetsfront/images/albums/01.jpg') }}" alt="{{ oeuvre.titre }}">
													</a>
												{% endif %}
												<div class="glightbox-desc custom-desc-all-{{ oeuvre.id }}">
													<div class="d-flex align-items-center justify-content-between">
														<div class="d-flex align-items-center">
															<div class="avatar me-2">
																<img class="avatar-img rounded-circle" src="{{ asset('assetsfront/images/avatar/default.jpg') }}" alt="">
															</div>
															<div>
																<div class="nav nav-divider">
																	<h6 class="nav-item card-title mb-0">{{ oeuvre.collection.artiste.nom ?? 'Unknown Author' }}</h6>
																	<span class="nav-item small">{{ oeuvre.dateCreation ? oeuvre.dateCreation|date('d M Y H:i') : '' }}</span>
																</div>
																<p class="mb-0 small">{{ oeuvre.type ? oeuvre.type.value : '' }}</p>
															</div>
														</div>
													</div>
													<h5 class="mt-3">{{ oeuvre.titre }}</h5>
													<p class="mb-2">{{ oeuvre.description }}</p>
													<ul class="nav nav-stack py-2 small">
														<li class="nav-item">
															<a class="nav-link active" href="#"><i class="bi bi-hand-thumbs-up-fill pe-1"></i>Liked ({{ oeuvre.likes ? oeuvre.likes|length : 0 }})</a>
														</li>
														<li class="nav-item">
															<a class="nav-link" href="#"><i class="bi bi-chat-fill pe-1"></i>Comments ({{ oeuvre.commentaires ? oeuvre.commentaires|length : 0 }})</a>
														</li>
													</ul>
													<ul class="comment-wrap list-unstyled">
														{% for commentaire in oeuvre.commentaires %}
															<li class="comment-item mb-2">
																<div class="d-flex">
																	<div class="avatar avatar-xs">
																		<img class="avatar-img rounded-circle" src="{{ asset('assetsfront/images/avatar/default.jpg') }}" alt="">
																	</div>
																	<div class="ms-2 w-100">
																		<div class="bg-light p-2 rounded">
																			<div class="d-flex justify-content-between">
																				<h6 class="mb-1">{{ commentaire.user.nom ?? 'User' }}</h6>
																				<small>{{ commentaire.dateCommentaire ? commentaire.dateCommentaire|date('d M Y H:i') : '' }}</small>
																			</div>
																		<p class="small mb-0">{{ commentaire.texte }}</p>
																	</div>
																</div>
															</div>
														</li>
													{% else %}
														<li class="text-muted small">No comments yet.</li>
													{% endfor %}
												</ul>
												<form class="position-relative w-100 mt-3">
													<textarea class="form-control pe-4 bg-light" rows="1" placeholder="Add a comment..."></textarea>
													<div class="text-end mt-2">
														<button type="button" class="btn btn-sm btn-primary">Comment</button>
													</div>
												</form>
											</div>
										</div>
									{% endfor %}
								{% else %}
									<p class="text-center text-muted">L'utilisateur n'a pas encore de favoris.</p>
								{% endif %}
								</div>
