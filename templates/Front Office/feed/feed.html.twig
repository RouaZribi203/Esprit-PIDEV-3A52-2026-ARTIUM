                                                <a href="#" class="text-secondary btn btn-sm btn-link p-0" id="commentAction{{ commentaire.id }}" data-bs-toggle="dropdown" aria-expanded="false">
                                                    <i class="bi bi-three-dots"></i>
                                                </a>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="commentAction{{ commentaire.id }}">
                                                    <li>
                                                        <button type="button" class="dropdown-item" data-bs-toggle="collapse" data-bs-target="#editComment{{ commentaire.id }}" aria-expanded="false" aria-controls="editComment{{ commentaire.id }}">
                                                            <i class="bi bi-pencil-square text-primary pe-2"></i>Modifier
                                                        </button>
                                                    </li>
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <form method="post" action="{{ path('commentaire_delete', {'id': commentaire.id}) }}" class="m-0">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ commentaire.id) }}">
                                                            <input type="hidden" name="redirect_path" value="{{ app.request.pathInfo }}">
                                                            <button type="submit" class="dropdown-item text-danger">
