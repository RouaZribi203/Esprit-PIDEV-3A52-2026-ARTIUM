                                </li>
                            </ul>
                        </div>
                    </div>
                </li>
                <!-- Comment item END -->
                {% endfor %}
            </ul>
            {% endif %}
            <!-- Comment wrap END -->
        </div>
        <!-- Card body END -->
        
        <!-- Card footer START -->
        {% if oeuvre.commentaires and oeuvre.commentaires|length > 3 %}
        <div class="card-footer border-0 pt-0">
            <!-- Load more comments -->
            <a href="#!" role="button"
