{% extends 'base_admin.html.twig' %}

{%block title %}{{ 'Oeuvres'|trans }}{% endblock %}

{% block admin_content %}
          <div class="row">
            <!-- Page Header -->
            <div class="col-lg-12 col-md-12 col-12">
              <div class="border-bottom pb-3 mb-3 d-flex align-items-center justify-content-between">
                <div class="d-flex flex-column gap-1">
                  <h1 class="mb-0 h1 fw-bold">Tous les Oeuvres</h1>
                  <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                      <li class="breadcrumb-item">
                        <a href="{{ path('app_admin') }}">Tableau de Bord</a>
                      </li>
                      <li class="breadcrumb-item active" aria-current="page">Tous les Oeuvres</li>
                    </ol>
                  </nav>
                </div>
              </div>
            </div>
          </div>
          <div class="row">
            <div class="col-lg-12 col-md-12 col-12">
              <!-- Card -->
              <div class="card rounded-3">
                <!-- Card Header -->
                <div class="card-header p-0">
                  <ul class="nav nav-lb-tab border-bottom-0" id="tab" role="tablist">
                    <li class="nav-item">
                      <a class="nav-link active" id="all-post-tab" data-bs-toggle="pill" href="#all-post" role="tab" aria-controls="all-post" aria-selected="true">Tout</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="published-tab" data-bs-toggle="pill" href="#published" role="tab" aria-controls="published" aria-selected="false">Peinture</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="scheduled-tab" data-bs-toggle="pill" href="#scheduled" role="tab" aria-controls="scheduled" aria-selected="false">Sculpture</a>
                    </li>
                    <li class="nav-item">
                      <a class="nav-link" id="draft-tab" data-bs-toggle="pill" href="#draft" role="tab" aria-controls="draft" aria-selected="false">Photohgraphie</a>
                    </li>
                  </ul>
                </div>
                <div class="p-4">
                  <div class="d-flex align-items-center gap-3">
                    <!-- Search Form -->
                    <form class="d-flex align-items-center flex-grow-1" method="get" action="{{ path('oeuvres') }}" id="searchForm" style="max-width: 300px;">
                      <span class="position-absolute ps-3 search-icon">
                        <i class="fe fe-search"></i>
                      </span>
                      <input type="search" name="q" class="form-control ps-6" placeholder="Rechercher Oeuvre" value="{{ currentQuery }}" />
                      <input type="hidden" name="sort" id="sortInput" value="{{ sortBy }}" />
                      <input type="hidden" name="order" id="orderInput" value="{{ sortOrder }}" />
                    </form>

                    <!-- Sort Dropdown and Order Button -->
                    <div class="d-flex align-items-center gap-2">
                      <select id="sortSelect" class="form-select" style="width: 200px;">
                        <option value="" disabled selected>Trier par...</option>
                        <option value="favoris" {{ sortBy == 'favoris' ? 'selected' : '' }}>Favoris</option>
                        <option value="commentaires" {{ sortBy == 'commentaires' ? 'selected' : '' }}>Commentaires</option>
                        <option value="likes" {{ sortBy == 'likes' ? 'selected' : '' }}>J'aimes</option>
                      </select>
                      <button type="button" class="btn btn-outline-primary" id="orderToggle" onclick="toggleOrder()">
                        {{ sortOrder == 'ASC' ? '↑ ASC' : '↓ DESC' }}
                      </button>
                    </div>

                    <!-- Delete All Button -->
                    <div class="ms-auto">
                      <a href="#" class="btn btn-primary">Supprimer tout</a>
                    </div>
                  </div>
                </div>

                <script>
                  document.getElementById('sortSelect').addEventListener('change', function() {
                    if (this.value) {
                      document.getElementById('sortInput').value = this.value;
                      document.getElementById('searchForm').submit();
                    }
                  });

                  function toggleOrder() {
                    const currentOrder = document.getElementById('orderInput').value;
                    document.getElementById('orderInput').value = currentOrder === 'ASC' ? 'DESC' : 'ASC';
                    document.getElementById('searchForm').submit();
                  }
                </script>

                {% if isSearchActive and noResultsMessage %}
                  <div class="alert alert-info mx-4 mb-3" role="alert">
                    <i class="fe fe-info me-2"></i>{{ noResultsMessage }}
                  </div>
                {% endif %}

                {% if isSearchActive and searchResults|length > 1 %}
                  <div class="alert alert-info mx-4 mb-3" role="alert">
                    <i class="fe fe-info me-2"></i>{{ searchResults|length }} résultat(s) trouvé(s)
                  </div>
                {% endif %}

                <div>
                
              <div class="tab-content" id="tabContent">
                    <!-- ALL -->
                    <!-- Tab -->
                    <div class="tab-pane fade show active" id="all-post" role="tabpanel" aria-labelledby="all-post-tab">
                      <div class="table-responsive">
                        <!-- Table -->
                        <table class="table mb-0 text-nowrap table-centered table-hover table-with-checkbox table-centered table-hover">
                          <!-- Table Head -->
                          <thead class="table-light">
                            <tr>
                              <th>
                                <div class="form-check">
                                  <input type="checkbox" class="form-check-input" id="checkAll" />
                                  <label class="form-check-label" for="checkAll"></label>
                                </div>
                              </th>
                              <th>Oeuvre</th>
                              <th>Catégorie</th>
                              <th>Collection</th>
                              <th>Date de publication</th>
                              <th>Artiste</th>
                              <th>J'aimes</th>
                              <th>Commentaires</th>
                              <th>Favoris</th>
                              <th></th>
                            </tr>
                          </thead>
                          <tbody>
                            {# Render search results or all oeuvres #}
                            {% set displayOeuvres = isSearchActive ? searchResults : oeuvres %}
                            {% for oeuvre in displayOeuvres %}
                            <tr>
                              <td>
                                <div class="form-check">
                                  <input type="checkbox" class="form-check-input" id="post{{ oeuvre.id }}" />
                                  <label class="form-check-label" for="post{{ oeuvre.id }}"></label>
                                </div>
                              </td>
                              <td>
                                <h5 class="mb-0">
                                  <a  class="text-inherit">{{ oeuvre.titre }}</a>
                                </h5>
                              </td>
                              <td>
                                {{ oeuvre.type ? oeuvre.type.value : '—' }}
                              </td>
                              <td>
                                <a  class="text-inherit">{{ oeuvre.collection ? oeuvre.collection.titre : '—' }}</a>
                              </td>
                              <td class="text-center">{{ oeuvre.dateCreation ?  oeuvre.dateCreation|date('d M Y') : '—' }}</td>
                              <td>
                                <div class="d-flex align-items-center flex-row gap-2">
                                  <h5 class="mb-0">{{ (oeuvre.collection and oeuvre.collection.artiste) ? (oeuvre.collection.artiste.nom ~ ' ' ~ oeuvre.collection.artiste.prenom) : '—' }}</h5>
                                </div>
                              </td>
                              <td class="text-center">
                                <div class="d-flex align-items-center justify-content-center gap-1">
                                <i class="fe fe-heart text-danger"></i>
                                <span>{{ oeuvre.likes ? oeuvre.likes|length : 0 }}</span>
                                </div>
                              </td>

                              <td class="text-center">
                                <div class="d-flex align-items-center justify-content-center gap-1">
                                <i class="fe fe-message-square"></i>
                                <span>{{ oeuvre.commentaires ? oeuvre.commentaires|length : 0 }}</span>
                                </div>
                              </td>
                              <td class="text-center">
                                <div class="d-flex align-items-center justify-content-center gap-1">
                                  <i class="fe fe-star"></i>
                                  <span>{{ oeuvre.userFav ? oeuvre.userFav|length : 0 }}</span>
                                </div>
                              </td>

                              <td>
                                <span class="dropdown dropstart">
                                  <a
                                    class="btn-icon btn btn-ghost btn-sm rounded-circle"
                                    href="#"
                                    role="button"
                                    id="courseDropdown{{ oeuvre.id }}"
                                    data-bs-toggle="dropdown"
                                    data-bs-offset="-20,20"
                                    aria-expanded="false">
                                    <i class="fe fe-more-vertical"></i>
                                  </a>
                                  <span class="dropdown-menu" aria-labelledby="courseDropdown{{ oeuvre.id }}">
                                    <span class="dropdown-header">Paramètres</span>
                                    <a class="dropdown-item" href="{{ path('app_oeuvre_details', {'id': oeuvre.id}) }}">
                                      <i class="fe fe-eye dropdown-item-icon"></i>
                                      Détails
                                    </a>
                                    {# Bouton Modifier 
                                    <button 
                                      class="dropdown-item" 
                                      type="button"
                                      data-bs-toggle="offcanvas" 
                                      data-bs-target="#offcanvasOeuvreEdit"
                                      data-oeuvre-id="{{ oeuvre.id }}"
                                      data-titre="{{ oeuvre.titre }}"
                                      data-description="{{ oeuvre.description }}"
                                      data-type="{{ oeuvre.type ? oeuvre.type.value : '' }}"
                                      data-date-creation="{{ oeuvre.dateCreation ? oeuvre.dateCreation|date('Y-m-d') : '' }}"
                                      data-collection-id="{{ oeuvre.collection ? oeuvre.collection.id : '' }}">
                                      <i class="fe fe-edit dropdown-item-icon"></i>
                                      Modifier
                                    </button>#}
                                    <button 
                                      class="dropdown-item" 
                                      type="button"
                                      onclick="document.getElementById('deleteForm{{ oeuvre.id }}').submit();" style="color: inherit; text-decoration: none;">
                                      <i class="fe fe-trash dropdown-item-icon"></i>
                                      Supprimer
                                    </button>
                                    <form id="deleteForm{{ oeuvre.id }}" method="post" action="{{ path('app_oeuvre_delete', {'id': oeuvre.id}) }}" style="display:none;">
                                      <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ oeuvre.id) }}">
                                    </form>
                                  </span>
                                </span>
                              </td>
                            </tr>
                            {% else %}
                            <tr>
                              <td colspan="9">Aucune œuvre trouvée.</td>
                            </tr>
                            {% endfor %}
                          </tbody>
                        </table>
                      </div>
