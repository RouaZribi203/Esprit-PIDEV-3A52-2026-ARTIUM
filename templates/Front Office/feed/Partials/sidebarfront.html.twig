<!-- Sidenav START -->
<div class="col-lg-3">
	<!-- Advanced filter responsive toggler START -->
	<div class="d-flex align-items-center d-lg-none">
		<button class="border-0 bg-transparent" type="button" data-bs-toggle="offcanvas"
			data-bs-target="#offcanvasSideNavbar" aria-controls="offcanvasSideNavbar">
			<span class="btn btn-primary">
				<i class="fa-solid fa-sliders-h"></i>
			</span>
			<span class="h6 mb-0 fw-bold d-lg-none ms-2">A Propos</span>
		</button>
	</div>
	<!-- Advanced filter responsive toggler END -->

	<!-- Navbar START-->
	<nav class="navbar navbar-expand-lg mx-0">
		<div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasSideNavbar">
			<!-- Offcanvas body -->
			<div class="offcanvas-body d-block px-2 px-lg-0">
				<!-- Card START -->
				<div class="card overflow-hidden">
					<!-- Cover image -->
					<div class="h-50px"
						style="background-image:url(assets/assetsfront/images/bg/01.jpg); background-position: center; background-size: cover; background-repeat: no-repeat;">
					</div>
					<!-- Card body START -->
					<div class="card-body pt-0">
						<div class="text-center">
							<!-- Avatar -->
							<div class="avatar avatar-lg mt-n5 mb-3">
								<a href="#!">
									{% if app.user and app.user.photoProfil %}
										<img class="avatar-img rounded border border-white border-3" src="{{ asset('uploads/' ~ app.user.photoProfil) }}" alt="">
									{% else %}
										<span class="avatar-img rounded border border-white border-3 bg-light d-inline-block d-flex align-items-center justify-content-center" style="width:64px;height:64px;">
											<i class="bi bi-person" style="font-size:2rem;color:#b0b7c3;"></i>
										</span>
									{% endif %}
								</a>
							</div>
							<!-- Info -->
							<h5 class="mb-0">
							<a href="#!">{{ app.user ? app.user.nom ~ ' ' ~ app.user.prenom : 'User' }}
							</a>
						</h5>
						<small>Amateur D'art</small>
						<p class="mt-3">{{ app.user.biographie ?? "I'd love to change the world, but they won't give me the source code." }}</p>

						<!-- User stat START -->
						<div class="hstack gap-2 gap-xl-3 justify-content-center">
							<!-- User stat item -->
							<div>
								<h6 class="mb-0">{{ app.user.ville ?? 'Tunis' }}</h6>
								<small>Ville</small>
							</div>
							<!-- Divider -->
							<div class="vr"></div>
							<!-- User stat item -->
							<div>
								<h6 class="mb-0">{{ app.user.dateNaissance ? app.user.dateNaissance|date('d M Y') : '12 Nov 1990' }}</h6>
								<!-- User stat item -->
							</div>
							<!-- User stat END -->
						</div>

						<!-- Divider -->
						<hr>

						<!-- Side Nav START -->
						<ul class="nav nav-link-secondary flex-column fw-bold gap-2">
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_feed') }}">
									<img class="me-2 h-20px fa-fw"
										src="{{ asset('assetsfront/images/icon/home-outline-filled.svg') }}"
										alt=""><span>Fil d’actualités
									</span>
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_favoris') }}">
									<img class="me-2 h-20px fa-fw"
										src="{{ asset('assetsfront/images/icon/favori.png') }}" alt=""><span>Favoris
									</span>
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_eventsfront') }}">
									<img class="me-2 h-20px fa-fw"
										src="{{ asset('assetsfront/images/icon/calendar-outline-filled.svg') }}"
										alt=""><span>Evènements
									</span>
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_bibliofront') }}">
									<img class="me-2 h-20px fa-fw"
										src="{{ asset('assetsfront/images/icon/livre-ouvert.png') }}"
										alt=""><span>Bibliothèque
									</span>
								</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_reclamationfront') }}">
									<img class="me-2 h-20px fa-fw"
										src="{{ asset('assetsfront/images/icon/attention.png') }}"
										alt=""><span>Réclamations
									</span>
								</a>
							</li>
						</ul>
						<!-- Side Nav END -->
					</div>
					<!-- Card body END -->
					<!-- Card footer -->
					<div class="card-footer text-center py-2">
						<a class="btn btn-link btn-sm" href="#" data-bs-toggle="offcanvas"
							data-bs-target="#offcanvasProfile">Modifier Profile
						</a>
					</div>
				</div>

				<!-- Copyright -->
				<p class="small text-center mt-1">©2026
					<a class="text-reset" target="_blank">
						Artium
					</a>
				</p>
			</div>
		</div>
	</nav>
	<!-- Navbar END-->
</div>
<!-- Sidenav END -->