{% extends 'base_amateur.html.twig' %}

{% block title %}{{ 'Fil d’actualités'|trans }}{% endblock %}

{% block amateur_content %}
   
    <div id="feed-container">
    {% for oeuvre in oeuvres|slice(0, 3) %}
    <!-- Card feed item START -->
    <div class="card mb-4">
        <!-- Card header START -->
        <div class="card-header border-0 pb-0">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <!-- Avatar -->
                    <div class="avatar avatar-story me-2">
                        <a href="#!">
                            <img class="avatar-img rounded-circle" 
                                 src="{{ asset('assetsfront/images/avatar/default.jpg') }}" 
                                 alt="">
                        </a>
                    </div>
                    <!-- Info -->
                    <div>
                        <div class="nav nav-divider">
                            <h6 class="nav-item card-title mb-0">
                                <a href="#!">
                                    {{ (oeuvre.collection and oeuvre.collection.artiste) ? (oeuvre.collection.artiste.nom ~ ' ' ~ oeuvre.collection.artiste.prenom) : 'Artiste Inconnu' }}
                                </a>
                            </h6>
                            <span class="nav-item small">{{ oeuvre.dateCreation|date('d M') }}</span>
                        </div>
                        <p class="mb-0 small">{{ oeuvre.dateCreation ? oeuvre.dateCreation|date('d F Y à H:i') : '' }}</p>
                    </div>
                </div>
                <!-- Card feed action dropdown START -->
                <div class="dropdown">
                    <a href="#" class="text-secondary btn btn-secondary-soft-hover py-1 px-2"
                       id="cardFeedAction{{ oeuvre.id }}" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="bi bi-three-dots"></i>
                    </a>
                    
                </div>
                <!-- Card feed action dropdown END -->
            </div>
        </div>
        <!-- Card header END -->
        
        <!-- Card body START -->
        <div class="card-body pb-0">
            <h5 class="mb-2">{{ oeuvre.titre }}</h5>
            <p>{{ oeuvre.description|raw }}
                {% if oeuvre.type %}
                    <a href="#!" class="ms-2">#{{ oeuvre.type.value }}</a>
                {% endif %}
                {% if oeuvre.collection %}
                    <a href="#!" class="ms-1">#{{ oeuvre.collection.titre }}</a>
                {% endif %}
            </p>
        </div>
        
        <!-- Card img -->
        {% if oeuvre.image %}
        <div class="overflow-hidden w-100">
            <img src="data:{{ processedOeuvres[oeuvre.id].mimeType ?? 'image/jpeg' }};base64,{{ processedOeuvres[oeuvre.id].imageBase64 }}" 
                 class="img-fluid" 
                 alt="{{ oeuvre.titre }}"
                 style="width: 100%; max-height: 600px; object-fit: contain;">
        </div>
        {% endif %}
        
        <!-- Feed react START -->
        <div class="card-body pt-0">
            <ul class="nav nav-stack py-3 small">
                <li class="nav-item">
                    <a class="nav-link active" href="#!">
                        <i class="bi bi-heart pe-1"></i>J'adore ({{ oeuvre.likes ? oeuvre.likes|length : 0 }})</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#!">
                        <i class="bi bi-chat-fill pe-1"></i>Commentaires ({{ oeuvre.commentaires ? oeuvre.commentaires|length : 0 }})</a>
                </li>
				<!-- Card share action START -->
                <li class="nav-item dropdown ms-sm-auto">
    <a class="nav-link mb-0" 
       href="{{ path('oeuvre_favorite', {'id': oeuvre.id}) }}" 
       id="cardShareAction{{ oeuvre.id }}">
        <i class="bi bi-star-fill fa-fw pe-2"></i>Ajouter aux Favoris
    </a>
</li>
                
            </ul>
            <!-- Feed react END -->

            <!-- Add comment -->
            <div class="d-flex mb-3">
                <!-- Avatar -->
                <div class="avatar avatar-xs me-2">
                    <a href="#!">
                        {% if app.user and app.user.photoProfil %}
                            <img class="avatar-img rounded-circle" src="{{ asset('uploads/' ~ app.user.photoProfil) }}" alt="">
                        {% else %}
                            <span class="avatar-img rounded-circle bg-light d-inline-block" style="width:32px;height:32px;"></span>
                        {% endif %}
                    </a>
                </div>

                <!-- Comment box  -->
                <form class="input-group" action="{{ path('oeuvre_commentaire', {'id': oeuvre.id}) }}" method="post">
    <textarea name="contenu" data-autoresize class="form-control me-2 bg-light rounded" rows="1"
              placeholder="Ajouter un commentaire..."></textarea>
    <button class="btn btn-primary mb-0 rounded" type="submit">Publier</button>
</form>

            </div>
            
            <!-- Comment wrap START -->
            {% if oeuvre.commentaires and oeuvre.commentaires|length > 0 %}
            <ul class="comment-wrap list-unstyled mb-0">
                {% for commentaire in oeuvre.commentaires|slice(0, 3) %}
                <!-- Comment item START -->
                <li class="comment-item">
                    <div class="d-flex">
                        <!-- Avatar -->
                        <div class="avatar avatar-xs">
                            <a href="#!"><img class="avatar-img rounded-circle"
                                    src="{{ asset('assetsfront/images/avatar/default.jpg') }}" alt=""></a>
                        </div>
                        <div class="ms-2">
                            <!-- Comment by -->
                            <div class="bg-light rounded-start-top-0 p-3 rounded">
                                <div class="d-flex justify-content-between">
                                    <h6 class="mb-1">
                                        <a href="#!">
                                            {{ commentaire.user ? (commentaire.user.nom ~ ' ' ~ commentaire.user.prenom) : 'Utilisateur' }}
                                        </a>
                                    </h6>
                                    <small class="ms-2">{{ commentaire.dateCommentaire|date('d M') }}</small>
                                </div>
                                <p class="small mb-0">{{ commentaire.texte }}</p>
                            </div>
                            <!-- Comment react -->
                            <ul class="nav nav-divider py-2 small">
                                <li class="nav-item">
                                    <a class="nav-link" href="#!">Répondre</a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </li>
                <!-- Comment item END -->
                {% endfor %}
            </ul>
            {% endif %}
            <!-- Comment wrap END -->
        </div>
        <!-- Card body END -->
        
        <!-- Card footer START -->
        {% if oeuvre.commentaires and oeuvre.commentaires|length > 3 %}
        <div class="card-footer border-0 pt-0">
            <!-- Load more comments -->
            <a href="#!" role="button"
               class="btn btn-link btn-link-loader btn-sm text-secondary d-flex align-items-center">
                <div class="spinner-dots me-2">
                    <span class="spinner-dot"></span>
                    <span class="spinner-dot"></span>
                    <span class="spinner-dot"></span>
                </div>
                Voir plus de commentaires
            </a>
        </div>
        {% endif %}
        <!-- Card footer END -->
    </div>
    <!-- Card feed item END -->
    {% else %}
        <div class="card">
            <div class="card-body text-center py-5">
                <h5>Aucune œuvre pour le moment</h5>
                <p class="text-muted">Revenez plus tard pour découvrir de nouvelles créations !</p>
            </div>
        </div>
    {% endfor %}
    </div>

    <!-- Hidden oeuvres for load more -->
    <div id="hidden-oeuvres" style="display: none;">
