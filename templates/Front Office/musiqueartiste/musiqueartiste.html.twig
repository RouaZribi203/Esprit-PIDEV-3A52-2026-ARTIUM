// Lyrics Modal Handler
document.addEventListener('click', async function(e) {
  const lyricsBtn = e.target.closest('.view-lyrics-btn');
  if (!lyricsBtn) {
    return;
  }

  e.preventDefault();

  const musicId = lyricsBtn.dataset.musicId;
  const musicTitle = lyricsBtn.dataset.musicTitle || 'Paroles';

  const modalElement = document.getElementById('lyricsModal');
  const modalTitle = document.getElementById('lyricsModalLabel');
  const loading = document.getElementById('lyricsLoading');
  const message = document.getElementById('lyricsMessage');
  const content = document.getElementById('lyricsContent');

  if (!modalElement || !loading || !message || !content || !modalTitle) {
    return;
  }

  modalTitle.textContent = `Paroles - ${musicTitle}`;
  message.style.display = 'none';
  content.textContent = '';
  loading.style.display = 'block';

  const modal = bootstrap.Modal.getOrCreateInstance(modalElement);
  modal.show();

  try {
    const url = '{{ path('app_musiqueartiste_lyrics', {'id': '__ID__'}) }}'.replace('__ID__', musicId);
    const response = await fetch(url, {
      headers: {
        'X-Requested-With': 'XMLHttpRequest'
      }
    });

    const data = await response.json();
    loading.style.display = 'none';

    if (!response.ok || !data.success || !data.lyrics) {
      message.textContent = data.message || 'Impossible de récupérer les paroles pour cette musique.';
      message.style.display = 'block';
      return;
    }

    content.textContent = data.lyrics;
  } catch (error) {
    loading.style.display = 'none';
    message.textContent = 'Erreur réseau lors de la récupération des paroles.';
    message.style.display = 'block';
  }
});

// AJAX Search and Sort System
let currentSortOrder = '{{ sortOrder }}';

function loadMusicResults() {
  const searchInput = document.getElementById('searchInput');
  const sortBySelect = document.getElementById('sortBy');
  const grid = document.getElementById('musicGrid');
  const emptyMsg = document.getElementById('emptyMessage');
  
  if (!searchInput || !sortBySelect) {
    console.error('Search or sort elements not found');
    return;
  }
  
  const search = searchInput.value;
  const sort = sortBySelect.value;
  
  const params = new URLSearchParams();
  if (search) params.append('search', search);
  params.append('sort', sort);
  params.append('order', currentSortOrder);
  
  // Show loading spinner
  if (grid) grid.innerHTML = '<div class="col-12 text-center"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>';
  if (emptyMsg) emptyMsg.style.display = 'none';
  
  // Fetch results
  fetch(`{{ path('app_musiqueartiste') }}?${params.toString()}`, {
    headers: {
      'X-Requested-With': 'XMLHttpRequest'
    }
  })
  .then(response => response.text())
  .then(html => {
    // Parse the HTML and extract just the music grid
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    
    // Try to get the grid
    const newGrid = doc.querySelector('#musicGrid');
    const newEmpty = doc.querySelector('#emptyMessage');
    const newResults = doc.querySelector('#resultsInfo');
    
    // Update grid
    if (grid && newGrid) {
      grid.innerHTML = newGrid.innerHTML;
      emptyMsg.style.display = 'none';
    } else if (emptyMsg && newEmpty) {
      grid.style.display = 'none';
      emptyMsg.innerHTML = newEmpty.innerHTML;
      emptyMsg.style.display = 'block';
    }
    
    // Update results info
    if (newResults) {
      document.getElementById('resultsInfo').innerHTML = newResults.innerHTML;
    }
    
    // Reinitialize Bootstrap dropdowns after AJAX update
    const dropdownElementList = document.querySelectorAll('[data-bs-toggle="dropdown"]');
    dropdownElementList.forEach(function(dropdownToggle) {
      new bootstrap.Dropdown(dropdownToggle);
    });
    
    // Update sort order button icon
    updateSortButton();
  })
  .catch(error => console.error('Error loading results:', error));
}

function updateSortButton() {
  const btn = document.getElementById('toggleSortBtn');
  if (!btn) return;
  
  const icon = btn.querySelector('i');
  const text = document.getElementById('sortOrderText');
  
  if (icon && currentSortOrder === 'DESC') {
    icon.className = 'bi bi-sort-down';
    if (text) text.textContent = 'Descendant';
  } else if (icon) {
    icon.className = 'bi bi-sort-up';
    if (text) text.textContent = 'Ascendant';
  }
}

function clearSearch() {
  const searchInput = document.getElementById('searchInput');
  const sortBySelect = document.getElementById('sortBy');
  
  if (searchInput) searchInput.value = '';
  currentSortOrder = 'DESC';
  if (sortBySelect) sortBySelect.value = 'date';
  loadMusicResults();
}

// Toggle sort order
function toggleSortOrder(form) {
  const currentOrder = document.getElementById('sortOrderInput').value;
  const newOrder = currentOrder === 'DESC' ? 'ASC' : 'DESC';
  document.getElementById('sortOrderInput').value = newOrder;
  form.submit();
}

// ===== INITIALIZE EVERYTHING ON DOM READY =====
document.addEventListener('DOMContentLoaded', function() {
  // Search/Sort Event listeners
  const searchBtn = document.getElementById('searchBtn');
  const searchInput = document.getElementById('searchInput');
  const sortBySelect = document.getElementById('sortBy');
  const toggleSortBtn = document.getElementById('toggleSortBtn');
  const clearBtn = document.getElementById('clearSearchBtn');
  
  if (searchBtn) {
    searchBtn.addEventListener('click', () => {
      currentSortOrder = 'DESC';
      if (sortBySelect) sortBySelect.value = 'date';
      loadMusicResults();
    });
  }
  
  if (searchInput) {
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        currentSortOrder = 'DESC';
        if (sortBySelect) sortBySelect.value = 'date';
        loadMusicResults();
      }
    });
  }
  
  if (sortBySelect) {
    sortBySelect.addEventListener('change', () => {
      currentSortOrder = 'DESC';
      loadMusicResults();
    });
  }
  
  if (toggleSortBtn) {
    toggleSortBtn.addEventListener('click', () => {
      currentSortOrder = currentSortOrder === 'DESC' ? 'ASC' : 'DESC';
      updateSortButton();
      loadMusicResults();
    });
  }
  
  if (clearBtn) {
    clearBtn.addEventListener('click', clearSearch);
  }
  
  // ===== STIMULUS CONTROLLER INITIALIZATION FOR OFFCANVAS =====
  // Reinitialize Stimulus controllers when offcanvas opens
  const offcanvasAddMusic = document.getElementById('offcanvasAddMusic');
  const offcanvasEditMusic = document.getElementById('offcanvasEditMusic');
  
  if (offcanvasAddMusic) {
    offcanvasAddMusic.addEventListener('shown.bs.offcanvas', function() {
      // Force Stimulus to connect controllers in the offcanvas
      if (window.Stimulus && window.Stimulus.application) {
        window.Stimulus.application.load();
      }
    });
  }
  
  if (offcanvasEditMusic) {
    offcanvasEditMusic.addEventListener('shown.bs.offcanvas', function() {
      // Force Stimulus to connect controllers in the offcanvas
      if (window.Stimulus && window.Stimulus.application) {
        window.Stimulus.application.load();
      }
    });
  }
  
  // ===== FORM VALIDATION (Contrôle de Saisie) =====
  const form = document.getElementById('addMusicForm');
  if (!form) return;
  
  // File input elements
  const imageFileInput = document.getElementById('music_imageFile') || document.querySelector('input[name*="imageFile"]');
  const audioFileInput = document.getElementById('music_audioFile') || document.querySelector('input[name*="audioFile"]');
  const titleInput = document.querySelector('input[name*="titre"]');
  const descriptionInput = document.querySelector('textarea[name*="description"]');
  const genreSelect = document.querySelector('select[name*="genre"]');
  
  // Character counter for description
  if (descriptionInput) {
    const updateCounter = () => {
      const counter = document.getElementById('descriptionCounter');
      if (counter) {
        counter.textContent = `(${descriptionInput.value.length}/5000)`;
      }
    };
    descriptionInput.addEventListener('input', updateCounter);
    descriptionInput.addEventListener('change', updateCounter);
  }
  
  // File input change handlers with preview
  if (imageFileInput) {
    imageFileInput.addEventListener('change', function(e) {
      const fileName = document.getElementById('imageFileName');
      const preview = document.getElementById('imagePreview');
      const previewImg = document.getElementById('imagePreviewImg');
      const validation = document.getElementById('imageValidation');
      const file = this.files[0];
      
      if (file) {
        // File size validation (5MB = 5242880 bytes)
        if (file.size > 5242880) {
          fileName.textContent = `❌ File too large (${(file.size / 1024 / 1024).toFixed(2)}MB > 5MB)`;
          fileName.classList.remove('text-success');
          fileName.classList.add('text-danger');
          validation.innerHTML = '';
          preview.style.display = 'none';
          this.value = '';
          return;
        }
        
        // MIME type validation
        const validMimes = ['image/jpeg', 'image/png', 'image/jpg'];
        if (!validMimes.includes(file.type)) {
          fileName.textContent = `❌ Invalid format (${file.type}). Use JPEG or PNG.`;
          fileName.classList.remove('text-success');
          fileName.classList.add('text-danger');
          validation.innerHTML = '';
          preview.style.display = 'none';
          this.value = '';
          return;
        }
        
        // Read file and check dimensions
        const reader = new FileReader();
        reader.onload = function(event) {
          const img = new Image();
          img.onload = function() {
            const width = img.width;
            const height = img.height;
            let validationMsg = '';
            let validationClass = 'text-success';
            
            fileName.textContent = `✓ ${file.name} (${(file.size / 1024).toFixed(2)}KB) • ${width}x${height}px`;
            
            // Check minimum dimensions (recommended 300x300px)
            if (width < 300 || height < 300) {
              validationMsg = `⚠️ Image dimensions (${width}x${height}px) are smaller than recommended (300x300px minimum)`;
              validationClass = 'text-warning';
            } else {
              validationMsg = `✓ Image dimensions: ${width}x${height}px`;
            }
            
            validation.textContent = validationMsg;
            validation.className = `small mt-2 ${validationClass}`;
            
            fileName.classList.remove('text-danger');
            fileName.classList.add('text-success');
            
            // Show preview
            previewImg.src = event.target.result;
            preview.style.display = 'block';
          };
          img.onerror = function() {
            fileName.textContent = `❌ Invalid image file or corrupted.`;
            fileName.classList.remove('text-success');
            fileName.classList.add('text-danger');
            validation.innerHTML = '';
            preview.style.display = 'none';
            imageFileInput.value = '';
          };
          img.src = event.target.result;
        };
        reader.readAsDataURL(file);
      } else {
        fileName.textContent = '';
        validation.innerHTML = '';
        preview.style.display = 'none';
      }
    });
  }
  
  if (audioFileInput) {
    audioFileInput.addEventListener('change', function(e) {
      const fileName = document.getElementById('audioFileName');
      const file = this.files[0];
      
      if (file) {
        // File size validation (20MB = 20971520 bytes)
        if (file.size > 20971520) {
          fileName.textContent = `❌ File too large (${(file.size / 1024 / 1024).toFixed(2)}MB > 20MB)`;
          fileName.classList.remove('text-success');
          fileName.classList.add('text-danger');
          this.value = '';
          return;
        }
        
        // MIME type validation
        const validMimes = [
          'audio/mpeg', 'audio/mp3', 'audio/wav', 'audio/x-wav',
          'audio/aac', 'audio/aacp', 'audio/opus', 'audio/ogg',
          'audio/webm', 'audio/flac', 'audio/x-m4a', 'audio/mp4'
        ];
        
        if (!validMimes.includes(file.type)) {
          // Allow if file extension looks reasonable
          const ext = file.name.split('.').pop().toLowerCase();
          const validExts = ['mp3', 'wav', 'aac', 'opus', 'ogg', 'webm', 'flac', 'm4a', 'mp4'];
          
          if (!validExts.includes(ext)) {
            fileName.textContent = `⚠️ Unusual format (.${ext}). Please verify it's a valid audio file.`;
            fileName.classList.remove('text-success');
            fileName.classList.add('text-warning');
            return;
          }
        }
        
        fileName.textContent = `✓ ${file.name} (${(file.size / 1024 / 1024).toFixed(2)}MB)`;
        fileName.classList.remove('text-danger', 'text-warning');
        fileName.classList.add('text-success');
      } else {
        fileName.textContent = '';
      }
    });
  }
  
  // Form submission validation
  form.addEventListener('submit', function(e) {
    // Reset validation classes
    form.classList.remove('was-validated');
    
    let isValid = true;
    const errors = [];
    
    // Title validation
    if (titleInput) {
      const value = titleInput.value.trim();
      if (!value) {
        errors.push('Title is required');
        titleInput.classList.add('is-invalid');
        isValid = false;
      } else if (value.length < 3) {
        errors.push('Title must be at least 3 characters');
        titleInput.classList.add('is-invalid');
        isValid = false;
      } else if (value.length > 255) {
        errors.push('Title cannot exceed 255 characters');
        titleInput.classList.add('is-invalid');
        isValid = false;
      } else {
        titleInput.classList.remove('is-invalid');
        titleInput.classList.add('is-valid');
      }
    }
    
    // Description validation
    if (descriptionInput) {
      const value = descriptionInput.value.trim();
      if (!value) {
        errors.push('Description is required');
        descriptionInput.classList.add('is-invalid');
        isValid = false;
      } else if (value.length < 10) {
        errors.push('Description must be at least 10 characters');
        descriptionInput.classList.add('is-invalid');
        isValid = false;
      } else if (value.length > 5000) {
        errors.push('Description cannot exceed 5000 characters');
        descriptionInput.classList.add('is-invalid');
        isValid = false;
      } else {
        descriptionInput.classList.remove('is-invalid');
        descriptionInput.classList.add('is-valid');
      }
    }
    
    // Genre validation
    if (genreSelect) {
      const value = genreSelect.value;
      if (!value) {
        errors.push('Genre is required');
        genreSelect.classList.add('is-invalid');
        isValid = false;
      } else {
        genreSelect.classList.remove('is-invalid');
        genreSelect.classList.add('is-valid');
      }
    }
    
    // Audio file validation
    if (audioFileInput) {
      const file = audioFileInput.files[0];
      if (!file) {
        errors.push('Audio file is required');
        audioFileInput.classList.add('is-invalid');
        isValid = false;
      } else {
        // Double-check file size
        if (file.size > 20971520) {
          errors.push(`Audio file is too large (${(file.size / 1024 / 1024).toFixed(2)}MB > 20MB)`);
          audioFileInput.classList.add('is-invalid');
          isValid = false;
        } else {
          audioFileInput.classList.remove('is-invalid');
        }
      }
    }
    
    // Image file validation (optional but if provided, must be valid)
    if (imageFileInput && imageFileInput.files.length > 0) {
      const file = imageFileInput.files[0];
      if (file.size > 5242880) {
        errors.push(`Image file is too large (${(file.size / 1024 / 1024).toFixed(2)}MB > 5MB)`);
        imageFileInput.classList.add('is-invalid');
        isValid = false;
      } else {
        imageFileInput.classList.remove('is-invalid');
      }
    }
    
    // If validation failed, prevent submission and show errors
    if (!isValid) {
      e.preventDefault();
      form.classList.add('was-validated');
      
      // Show error alert
      const alertDiv = document.createElement('div');
      alertDiv.className = 'alert alert-danger alert-dismissible fade show mt-3';
      alertDiv.innerHTML = `
        <strong><i class="bi bi-exclamation-triangle pe-2"></i>Validation Failed:</strong>
        <ul class="mb-0 mt-2">
          ${errors.map(err => `<li>${err}</li>`).join('')}
        </ul>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      `;
      
      // Insert at the top of the form
      form.insertBefore(alertDiv, form.firstChild);
      
      // Scroll to error
      setTimeout(() => {
        alertDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  });
  
  // ===== EDIT FORM VALIDATION =====
  const editForm = document.getElementById('editMusicForm');
  if (editForm) {
    const editTitleInput = document.getElementById('editTitre');
    const editDescriptionInput = document.getElementById('editDescription');
    const editGenreSelect = document.getElementById('editGenre');
    const editImageFileInput = document.getElementById('editImageFileInput');
    
    // Character counter for edit description
