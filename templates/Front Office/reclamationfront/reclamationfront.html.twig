{% extends 'base_amateur.html.twig' %}

{% block title %}{{ 'Réclamations'|trans }}{% endblock %}

{% block amateur_content %}
    <!-- Card START -->
    <div class="card h-100">
        <!-- Card header START -->
        <div class="card-header d-sm-flex align-items-center text-center justify-content-sm-between border-0 pb-0">
            <h1 class="h4 card-title">Réclamations</h1>
        </div>
        <!-- Card header END -->
        <!-- Card body START -->
        <div class="card-body">
            <!-- Tab nav line -->
            <ul class="nav nav-tabs nav-bottom-line justify-content-center justify-content-md-start">
                <li class="nav-item"> <a class="nav-link active" data-bs-toggle="tab" href="#tab-1"> <i class="bi bi-pencil-square pe-1"></i>Envoyer Réclamation </a> </li>
                <li class="nav-item"> <a class="nav-link" data-bs-toggle="tab" href="#tab-2"> <i class="bi bi-list-check pe-1"></i>Mes Réclamations </a> </li>
            </ul>

            <!-- Tab content START -->
            <div class="tab-content mb-0 pb-0">
                
                <!-- Submit Reclamation Tab START -->
                <div class="tab-pane fade show active" id="tab-1">
                    <div class="card mt-4">
                        <!-- Title START -->
                        <div class="card-header border-0 pb-0">
                            <h5 class="card-title mb-0">Soumettre une Réclamation</h5>
                        </div>
                        <!-- Title END -->
                        <!-- Form START -->
                        <div class="card-body">
                            <form class="row g-3">
                                <!-- Subject -->
                                <div class="col-12">
                                    <label class="form-label">Sujet <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" placeholder="Sujet de votre réclamation" required>
                                </div>

                                <!-- Category -->
                                <div class="col-sm-6">
                                    <label class="form-label">Catégorie <span class="text-danger">*</span></label>
                                    <select class="form-select" required>
                                        <option value="">Sélectionner une catégorie</option>
                                        <option value="qualite">Qualité de service</option>
                                        <option value="facturation">Facturation</option>
                                        <option value="produit">Produit défectueux</option>
                                        <option value="livraison">Livraison</option>
                                        <option value="autre">Autre</option>
                                    </select>
                                </div>

                                <!-- Priority -->
                                <div class="col-sm-6">
                                    <label class="form-label">Priorité <span class="text-danger">*</span></label>
                                    <select class="form-select" required>
                                        <option value="">Sélectionner une priorité</option>
                                        <option value="basse">Basse</option>
                                        <option value="normale">Normale</option>
                                        <option value="haute">Haute</option>
                                    </select>
                                </div>

                                <!-- Description -->
                                <div class="col-12">
                                    <label class="form-label">Description <span class="text-danger">*</span></label>
                                    <textarea class="form-control" rows="5" placeholder="Décrivez votre problème en détail..." required></textarea>
                                    <small class="text-muted">Caractères max: 1000</small>
                                </div>

                                <!-- Attachment -->
                                <div class="col-12">
                                    <label class="form-label">Joindre un fichier (optionnel)</label>
                                    <input type="file" class="form-control" accept=".pdf,.doc,.docx,.jpg,.png,.jpeg">
                                    <small class="text-muted">Formats acceptés: PDF, DOC, DOCX, JPG, PNG (Max 5MB)</small>
                                </div>

                                <!-- Submit Button -->
                                <div class="col-12 text-end">
                                    <button type="reset" class="btn btn-outline-secondary me-2">Réinitialiser</button>
                                    <button type="submit" class="btn btn-primary">Envoyer la Réclamation</button>
                                </div>
                            </form>
                        </div>
                        <!-- Form END -->
                    </div>
                </div>
                <!-- Submit Reclamation Tab END -->

                <!-- My Reclamations Tab START -->
                <div class="tab-pane fade" id="tab-2">
                    <div class="mt-4">
                        <!-- Search and Filter -->
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <input type="search" class="form-control" placeholder="Rechercher une réclamation...">
                            </div>
                            <div class="col-md-6">
                                <select class="form-select">
                                    <option value="">Filtrer par statut</option>
                                    <option value="ouverte">Ouverte</option>
                                    <option value="en-cours">En cours</option>
                                    <option value="resolue">Résolue</option>
                                    <option value="fermee">Fermée</option>
                                </select>
                            </div>
                        </div>

                        <!-- Reclamations List -->
                        <div class="row g-3">
                            <!-- Reclamation Card 1 -->
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <div class="d-flex align-items-start gap-3">
                                                    <!-- Status Indicator -->
                                                    <div>
                                                        <span class="badge bg-warning text-dark">En cours</span>
                                                    </div>
                                                    <!-- Content -->
                                                    <div class="w-100">
                                                        <h6 class="mb-1">Problème avec la commande #12345</h6>
                                                        <p class="mb-2 small text-muted">Catégorie: <strong>Livraison</strong></p>
                                                        <p class="mb-0 small">Le produit commandé n'a pas été livré dans les délais prévus...</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4 text-md-end">
                                                <div class="mb-2">
                                                    <small class="text-muted">Créée le: <strong>08 Feb 2026</strong></small>
                                                </div>
                                                <button class="btn btn-sm btn-outline-primary">Voir détails</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Reclamation Card 2 -->
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <div class="d-flex align-items-start gap-3">
                                                    <!-- Status Indicator -->
                                                    <div>
                                                        <span class="badge bg-success">Résolue</span>
                                                    </div>
                                                    <!-- Content -->
                                                    <div class="w-100">
                                                        <h6 class="mb-1">Qualité de service défaillante</h6>
                                                        <p class="mb-2 small text-muted">Catégorie: <strong>Qualité de service</strong></p>
                                                        <p class="mb-0 small">Le service client n'a pas répondu à ma demande dans les 48 heures...</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4 text-md-end">
                                                <div class="mb-2">
                                                    <small class="text-muted">Créée le: <strong>05 Feb 2026</strong></small>
                                                </div>
                                                <button class="btn btn-sm btn-outline-primary">Voir détails</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Reclamation Card 3 -->
                            <div class="col-12">
                                <div class="card">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-md-8">
                                                <div class="d-flex align-items-start gap-3">
                                                    <!-- Status Indicator -->
                                                    <div>
                                                        <span class="badge bg-danger">Fermée</span>
                                                    </div>
                                                    <!-- Content -->
                                                    <div class="w-100">
                                                        <h6 class="mb-1">Produit défectueux</h6>
                                                        <p class="mb-2 small text-muted">Catégorie: <strong>Produit défectueux</strong></p>
                                                        <p class="mb-0 small">Le produit livré présente un défaut de fabrication...</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-md-4 text-md-end">
                                                <div class="mb-2">
                                                    <small class="text-muted">Créée le: <strong>01 Feb 2026</strong></small>
                                                </div>
                                                <button class="btn btn-sm btn-outline-primary">Voir détails</button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Empty State (when no reclamations) -->
                            <div class="col-12" style="display: none;">
                                <div class="text-center py-5">
                                    <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                                    <h6 class="mt-3 text-muted">Aucune réclamation trouvée</h6>
                                    <p class="small text-muted">Vous n'avez pas encore soumis de réclamation.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- My Reclamations Tab END -->
            </div>
            <!-- Tab content END -->
        </div>
        <!-- Card body END -->
    </div>
    <!-- Card END -->
{% endblock %}


