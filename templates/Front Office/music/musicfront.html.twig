        function playPauseMusic(button) {
            const card = button.closest('.music-card');

            if (currentTrackCard && currentTrackCard === card && !audioPlayer.paused) {
                audioPlayer.pause();
                syncCardButtons();
                updateGlobalPlayerUI();
                return;
            }

            if (currentTrackCard && currentTrackCard === card && audioPlayer.paused) {
                audioPlayer.play();
                syncCardButtons();
                updateGlobalPlayerUI();
            } else {
                setTrackFromCard(card, true);
            }
        }

        function updateSeekPreview(progressValue) {
            const ui = getPlayerUi();
            if (!ui.playerCurrentTime) {
                return;
            }

            const duration = audioPlayer.duration || 0;
            if (!duration) {
                return;
            }

            const clampedProgress = Math.min(100, Math.max(0, Number(progressValue) || 0));
            const previewTime = (clampedProgress / 100) * duration;
            ui.playerCurrentTime.textContent = formatTime(previewTime);

            if (currentTrackCard) {
                const cardProgress = currentTrackCard.querySelector('.music-progress');
                if (cardProgress) {
                    cardProgress.style.width = `${clampedProgress}%`;
                }
            }
        }

        function commitSeek(progressValue, storeIfPending = true) {
            const duration = audioPlayer.duration || 0;
            if (!duration) {
                if (storeIfPending) {
                    pendingSeekPercent = Math.min(100, Math.max(0, Number(progressValue) || 0));
                }
                return;
            }

            const clampedProgress = Math.min(100, Math.max(0, Number(progressValue) || 0));
            audioPlayer.currentTime = (clampedProgress / 100) * duration;
            pendingSeekPercent = null;
        }

        function bindMainPlayerControls() {
            const ui = getPlayerUi();
            if (!ui.playerPrevBtn || !ui.playerNextBtn || !ui.playerToggleBtn || !ui.playerSeekSlider) {
                return;
            }

            ui.playerPrevBtn.onclick = () => {
                playTrackByOffset(-1);
            };

            ui.playerNextBtn.onclick = () => {
                playTrackByOffset(1);
            };

            ui.playerToggleBtn.onclick = () => {
                if (!audioPlayer.src) {
                    const cards = getPlayableCards();
                    if (cards.length) {
                        setTrackFromCard(cards[0], true);
                    }
                    return;
                }

                if (audioPlayer.paused) {
                    audioPlayer.play();
                } else {
                    audioPlayer.pause();
                }
            };

            ui.playerSeekSlider.oninput = (event) => {
                isSeeking = true;
                updateSeekPreview(event.target.value);
                commitSeek(event.target.value);
            };

            ui.playerSeekSlider.onchange = (event) => {
                commitSeek(event.target.value);
                isSeeking = false;
                updateGlobalPlayerUI();
                persistPlayerState();
            };

            ui.playerSeekSlider.onpointerdown = () => {
                isSeeking = true;
            };

            ui.playerSeekSlider.onpointerup = () => {
                commitSeek(ui.playerSeekSlider.value);
                isSeeking = false;
                updateGlobalPlayerUI();
                persistPlayerState();
            };
        }

        audioPlayer.addEventListener('timeupdate', updateGlobalPlayerUI);
        audioPlayer.addEventListener('play', () => {
            syncCardButtons();
            updateGlobalPlayerUI();
            persistPlayerState();
        });
        audioPlayer.addEventListener('pause', () => {
            syncCardButtons();
            updateGlobalPlayerUI();
            persistPlayerState();
        });
        audioPlayer.addEventListener('ended', () => {
            if (isPlaylistModalPlaybackActive) {
                return;
            }
            playTrackByOffset(1);
        });

        audioPlayer.addEventListener('loadedmetadata', () => {
            if (pendingSeekPercent !== null) {
                commitSeek(pendingSeekPercent, false);
            }
            updateGlobalPlayerUI();
            persistPlayerState();
            persistQueueSnapshot();
        });

        bindMainPlayerControls();

        audioPlayer.addEventListener('timeupdate', persistPlayerState);
        window.addEventListener('beforeunload', persistPlayerState);
        document.addEventListener('turbo:before-cache', () => {
            persistPlayerState();
            persistQueueSnapshot();
        });
        window.addEventListener('pagehide', () => {
            persistPlayerState();
            persistQueueSnapshot();
        });

        // Lyrics functionality
        document.querySelectorAll('.lyrics-btn').forEach(button => {
            button.addEventListener('click', function() {
                const musicId = this.getAttribute('data-music-id');
                const modal = new bootstrap.Modal(document.getElementById('lyricsModal'));
                const modalBody = document.getElementById('lyricsContent');
                const modalTitle = document.getElementById('lyricsModalLabel');
                const loadingDiv = document.getElementById('lyricsLoading');
                const messageDiv = document.getElementById('lyricsMessage');

                // Show loading state
                loadingDiv.classList.remove('d-none');
                messageDiv.classList.add('d-none');
                modalBody.classList.add('d-none');
                modalTitle.textContent = 'Chargement des paroles...';

                modal.show();

                // Fetch lyrics
                fetch(`{{ path('app_musicfront_lyrics', {'id': '__ID__'}) }}`.replace('__ID__', musicId))
                    .then(response => response.json())
                    .then(data => {
                        loadingDiv.classList.add('d-none');

                        if (data.success) {
                            modalTitle.textContent = `${data.track} - ${data.artist}`;
                            modalBody.textContent = data.lyrics;
                            modalBody.classList.remove('d-none');
                        } else {
                            modalTitle.textContent = 'Paroles non disponibles';
                            messageDiv.textContent = data.message || 'Impossible de charger les paroles';
                            messageDiv.classList.remove('d-none');
                        }
                    })
                    .catch(error => {
                        console.error('Error fetching lyrics:', error);
                        loadingDiv.classList.add('d-none');
                        modalTitle.textContent = 'Erreur';
                        messageDiv.textContent = 'Échec du chargement des paroles. Veuillez réessayer plus tard.';
                        messageDiv.classList.remove('d-none');
                    });
            });
        });
    </script>

    </div>

    <!-- Lyrics Modal -->
    <div class="modal fade" id="lyricsModal" tabindex="-1" aria-labelledby="lyricsModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="lyricsModalLabel">Paroles</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="lyricsLoading" class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Chargement...</span>
                        </div>
                        <p class="mt-2 text-muted">Chargement des paroles...</p>
                    </div>
                    <div id="lyricsMessage" class="alert alert-info d-none" role="alert"></div>
                    <pre id="lyricsContent" class="d-none" style="white-space: pre-wrap; font-family: inherit;"></pre>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
