{% extends 'base_amateur.html.twig' %}

{% block title %}{{ evenement.titre }} - {{ 'Détails'|trans }}{% endblock %}

{% block amateur_content %}
    <div class="card card-body">
        <!-- Image de couverture -->
        <div class="mb-4">
            {% if image %}
                <img class="img-fluid rounded" src="{{ image }}" alt="{{ evenement.titre }}" style="max-height: 400px; width: 100%; object-fit: cover;">
            {% else %}
                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 300px;">
                    <i class="bi bi-image text-muted fs-1"></i>
                </div>
            {% endif %}
        </div>

        <!-- Titre et description -->
        <div class="mb-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <h2 class="mb-2">{{ evenement.titre }}</h2>
                    <div class="d-flex gap-2">
                        <span class="badge bg-{{ evenement.statut.value == 'A_VENIR' ? 'success' : 'secondary' }}">
                            {{ evenement.statut.value == 'A_VENIR' ? 'À venir' : 'Terminé' }}
                        </span>
                        <span class="badge bg-primary">{{ evenement.type ? evenement.type.value : '' }}</span>
                    </div>
                </div>
                <form method="post" action="{{ path('app_eventdetails', { id: evenement.id }) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('buy_ticket_' ~ evenement.id) }}">
                    <button class="btn btn-primary" type="submit">
                        <i class="bi bi-ticket-perforated me-2"></i>Acheter ticket
                    </button>
                </form>
            </div>
            <p class="text-muted">{{ evenement.description }}</p>
        </div>

        <hr class="my-4">

        <!-- Informations principales en grille -->
        <div class="row g-4 mb-4 justify-content-center text-center">
            <!-- Timings -->
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex flex-column align-items-center">
                    <i class="bi bi-clock fs-3 text-primary me-3"></i>
                    <div>
                        <h6 class="mb-2">Horaires</h6>
                        <p class="small mb-1"><strong>Date début:</strong> {{ evenement.dateDebut ? evenement.dateDebut|date('d/m/Y') : '-' }}</p>
                        <p class="small mb-1"><strong>Heure début:</strong> {{ evenement.dateDebut ? evenement.dateDebut|date('H:i') : '-' }}</p>
                        <p class="small mb-1"><strong>Date fin:</strong> {{ evenement.dateFin ? evenement.dateFin|date('d/m/Y') : '-' }}</p>
                        <p class="small mb-0"><strong>Heure fin:</strong> {{ evenement.dateFin ? evenement.dateFin|date('H:i') : '-' }}</p>
                    </div>
                </div>
            </div>

            <!-- Prix -->
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex flex-column align-items-center">
                    <i class="bi bi-currency-euro fs-3 text-success me-3"></i>
                    <div>
                        <h6 class="mb-2">Prix d'entrée</h6>
                        <p class="h4 mb-0 text-success">{{ evenement.prixTicket }} DT</p>
                    </div>
                </div>
            </div>

            <!-- Capacité -->
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex flex-column align-items-center">
                    <i class="bi bi-people fs-3 text-info me-3"></i>
                    <div>
                        <h6 class="mb-2">Capacité</h6>
                        <p class="small mb-0"><strong>{{ evenement.capaciteMax }} Personnes</strong></p>
                    </div>
                </div>
            </div>

            <!-- Galerie -->
            <div class="col-sm-6 col-lg-3">
                <div class="d-flex flex-column align-items-center">
                    <i class="bi bi-building fs-3 text-warning me-3"></i>
                    <div>
                        <h6 class="mb-2">Galerie</h6>
                        {% if evenement.galerie %}
                            <p class="small mb-0"><strong>{{ evenement.galerie.nom }}</strong></p>
                        {% else %}
                            <p class="small mb-0">Non spécifié</p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if tickets is defined and tickets is not empty %}
    <div class="card card-body mt-4">
        <h5 class="mb-3">
            <i class="bi bi-ticket-perforated me-2"></i>Vos tickets
        </h5>
        <div class="list-group">
            {% for ticket in tickets %}
                <div class="list-group-item d-flex flex-wrap align-items-center justify-content-between">
                    <div>
                        <div class="fw-semibold">Ticket #{{ ticket.id }}</div>
                        <div class="small text-muted">Acheté le {{ ticket.dateAchat ? ticket.dateAchat|date('d M Y') : '-' }}</div>
                    </div>
                    <div class="text-muted small">
                        {{ evenement.titre }} · {{ evenement.prixTicket }} DT
                    </div>
                    <div>
                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('app_ticket_qr', { id: ticket.id }) }}" target="_blank" rel="noopener">
                            <i class="bi bi-qr-code"></i>
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <!-- Section Localisation (pleine largeur) -->
    {% if evenement.galerie %}
    <div class="card card-body mt-4">
        <h5 class="mb-4">
            <i class="bi bi-geo-alt me-2"></i>Localisation de l'événement
        </h5>
        <div class="row">
            <div class="col-md-4 mb-3 mb-md-0">
                <h6 class="mb-3">{{ evenement.galerie.nom }}</h6>
                <dl class="mb-0">
                    <dt class="text-muted mb-2"><i class="bi bi-map me-2"></i>Adresse</dt>
                    <dd class="mb-3">{{ evenement.galerie.adresse }}</dd>
                    
                    <dt class="text-muted mb-2"><i class="bi bi-geo-alt me-2"></i>Ville</dt>
                    <dd class="mb-3">{{ evenement.galerie.localisation }}</dd>
                    
                    <dt class="text-muted mb-2"><i class="bi bi-people me-2"></i>Capacité de la galerie</dt>
                    <dd class="mb-3">{{ evenement.galerie.capaciteMax }} personnes</dd>
                    
                    {% if evenement.galerie.description %}
                    <dt class="text-muted mb-2"><i class="bi bi-info-circle me-2"></i>Description</dt>
                    <dd class="mb-0">{{ evenement.galerie.description }}</dd>
                    {% endif %}
                </dl>
            </div>
            <!-- Le conteneur pour la carte -->
<div id="map" class="w-100 rounded" style="height: 300px; border: 1px solid #ddd;"></div>

<script>
  // Initialiser la carte
  function initMap() {
    // Lire les coordonnées depuis le champ localisation (format: latitude,longitude)
    let location = { lat: 40.7408, lng: -74.0045 }; // Défaut si vide
    
    {% if evenement.galerie.localisation %}
      const coords = "{{ evenement.galerie.localisation }}".trim().split(',');
      if (coords.length === 2) {
        location = {
          lat: parseFloat(coords[0].trim()),
          lng: parseFloat(coords[1].trim())
        };
      }
    {% endif %}
    
    // Créer la carte
    const map = new google.maps.Map(document.getElementById('map'), {
      zoom: 15,
      center: location,
      mapTypeControl: true,
      fullscreenControl: true,
      zoomControl: true,
    });
    
    // Ajouter un marqueur
    new google.maps.Marker({
      position: location,
      map: map,
      title: '{{ evenement.galerie.nom }}',
      icon: 'http://maps.google.com/mapfiles/ms/icons/red-dot.png'
    });
  }
  
  // Appeler la fonction quand la page charge
  window.addEventListener('load', initMap);
</script>

<!-- Charger l'API Google Maps (remplacez YOUR_API_KEY par votre clé) -->
<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAIOZpPn6OSdFZty2bTORmAkjvwQ9GFMOQ"></script>
        </div>
    </div>
    {% endif %}
{% endblock %}
