<script>
document.getElementById('generateAiBtn').addEventListener('click', async function () {

    const button = document.getElementById('generateAiBtn');
    const alertContainer = document.getElementById('aiAlertContainer');
    const pdfInput = document.querySelector('#addLivreFormFront input[name="fichier_pdf"]');

    // Reset alerts
    alertContainer.innerHTML = '';

    // 🔵 Disable button + show spinner
    button.disabled = true;
    button.innerHTML = `
        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
        Génération en cours...
    `;

    // ❌ If no PDF
    if (!pdfInput || !pdfInput.files.length) {
        alertContainer.innerHTML = `
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                Veuillez ajouter le fichier PDF du livre avant de générer.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        `;
        resetButton();
        return;
    }

    const formData = new FormData();
    formData.append('fichier_pdf', pdfInput.files[0]);

    try {
        const response = await fetch("{{ path('ai_generate_book') }}", {
            method: "POST",
            body: formData
        });

        if (!response.ok) {
            const errText = await response.text();
            throw new Error('Server error: ' + response.status + ' - ' + errText);
        }

        const contentType = (response.headers.get('content-type') || '').toLowerCase();
        let data;
        if (contentType.includes('application/json')) {
            data = await response.json();
        } else {
            const txt = await response.text();
            throw new Error('Invalid response (not JSON): ' + txt);
        }

        if (data.error) {
            alertContainer.innerHTML = `
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    ${data.error}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            `;
            resetButton();
            return;
        }

        // ✅ Autofill fields
        document.querySelector('#addLivreFormFront input[name="titre"]').value = data.titre || '';
        document.querySelector('#addLivreFormFront textarea[name="description"]').value = data.description || '';
        document.querySelector('#addLivreFormFront input[name="categorie"]').value = data.categorie || '';
        document.querySelector('#addLivreFormFront input[name="prix_location"]').value = data.prix || '';

        alertContainer.innerHTML = `
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                Contenu généré automatiquement avec succès.
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        `;

        // 🔄 Optional: scroll to form or alert
        alertContainer.scrollIntoView({ behavior: 'smooth', block: 'center' });

    } catch (error) {
        const msg = (error && error.message) ? error.message : 'Erreur lors de la génération automatique.';
        alertContainer.innerHTML = `
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                ${msg}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        `;
        console.error(error);
    }

    // 🔵 Restore button
    resetButton();

    function resetButton() {
        button.disabled = false;
        button.innerHTML = '✨ Générer automatiquement';
    }

});
</script>
