<!DOCTYPE html>

<title>Reclamation</title>

{% block body %}
    <h1>Reclamation</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ reclamation.id }}</td>
            </tr>
            <tr>
                <th>Texte</th>
                <td>{{ reclamation.texte }}</td>
            </tr>
            <tr>
                <th>Date_creation</th>
                <td>{{ reclamation.dateCreation ? reclamation.dateCreation|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>Statut</th>
                <td>{{ reclamation.statut }}</td>
            </tr>
            <tr>
                <th>Type</th>
                <td>{{ reclamation.type }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_reclamation_admin_index') }}">back to list</a>

    <a href="{{ path('app_reclamation_admin_edit', {'id': reclamation.id}) }}">edit</a>

    {{ include('reclamation_admin/_delete_form.html.twig') }}
{% endblock %}
