<div
	class="card">
	<!-- Cover image -->
	<div class="h-200px rounded-top" style="background-image:url({{ asset('assetsfront/images/bg/05.jpg') }}); background-position: center; background-size: cover; background-repeat: no-repeat;"></div>
	<!-- Card body START -->
	<div class="card-body py-0">
		<div class="d-sm-flex align-items-start text-center text-sm-start">
			<div>
				<!-- Avatar -->
				   <div class="avatar avatar-xxl mt-n5 mb-3">
					   {% if app.user and app.user.photoProfil %}
						   <img class="avatar-img rounded-circle border border-white border-3" src="{{ asset('uploads/' ~ app.user.photoProfil) }}" alt="Avatar">
					   {% else %}
						   <span class="avatar-img rounded-circle border border-white border-3 d-flex align-items-center justify-content-center bg-light text-secondary-emphasis position-relative" style="width:120px;height:120px;">
							   <i class="bi bi-person fs-1 position-absolute top-50 start-50 translate-middle" style="opacity:0.5;"></i>
							   <span class="position-absolute bottom-0 start-50 translate-middle-x mb-2" style="font-size:0.95rem;opacity:0.7;"></span>
						   </span>
					   {% endif %}
				   </div>
			</div>
			<div
				class="ms-sm-4 mt-sm-3">
				<!-- Info -->
				<h1 class="mb-0 h5">{{ app.user.prenom ~ ' ' ~ app.user.nom }}
					<i class="bi bi-patch-check-fill text-success small"></i>
				</h1>
				<p>{{ app.user.connections is defined ? app.user.connections ~ ' connections' : '' }}</p>
			</div>
			<!-- Button -->
			<div class="d-flex mt-3 justify-content-center ms-sm-auto">
				   <button class="btn btn-danger-soft me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasProfile">
					   <i class="bi bi-pencil-fill pe-1"></i>
					   Edit profile
				   </button>
		   {# Inclusion discrète de l'offcanvas d'édition de profil juste après le bouton #}
		   {% if profile_form is defined and profile_form is not null %}
			   {% include 'Front Office/Partials/offcanvas_profile.html.twig' with {
				   user: app.user,
				   form: profile_form,
				   offcanvas_id: 'offcanvasProfile',
				   title: 'Modifier profil',
				   subtitle: 'Mettez à jour vos informations personnelles',
				   profile_form_action: '#',
				   password_form_action: '#',
				   show_password_form: true
			   } %}
		   {% endif %}

			</div>
		</div>
		<!-- List profile -->
		<ul class="list-inline mb-0 text-center text-sm-start mt-3 mt-sm-0">
			<li class="list-inline-item">
				<i class="bi bi-briefcase me-1"></i>
				{{ app.user.specialite is defined and app.user.specialite ? app.user.specialite.value : 'Artiste' }}
			</li>
			<li class="list-inline-item">
				<i class="bi bi-geo-alt me-1"></i>
				{{ app.user.ville }}
			</li>
			<li class="list-inline-item">
				<i class="bi bi-calendar2-plus me-1"></i>
				Inscrit le
				{{ app.user.dateInscription is defined and app.user.dateInscription ? app.user.dateInscription|date('M d, Y') : '' }}
			</li>
		</ul>
	</div>
	<!-- Card body END -->
	<div
		class="card-footer mt-3 pt-2 pb-0">
		<!-- Nav profile pages -->
		{% set current_route = app.request.attributes.get('_route') %}
		<ul class="nav nav-bottom-line align-items-center justify-content-center justify-content-md-start mb-0 border-0 profile-nav">
			{% set specialite = app.user.specialite is defined and app.user.specialite ? app.user.specialite.value|lower : '' %}
		{% if specialite == 'musicien' or current_route in ['app_musiqueartiste', 'app_collections_front'] %}
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_collections_front' ? 'active' : '' }}" href="{{ path('app_collections_front') }}">
					Collections
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_musiqueartiste' ? 'active' : '' }}" href="{{ path('app_musiqueartiste') }}">
					Musiques
				</a>
			</li>
		{% elseif specialite == 'auteur' %}
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_collections_front' ? 'active' : '' }}" href="{{ path('app_collections_front') }}">
					Collections
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_bibliothequeartiste' ? 'active' : '' }}" href="{{ path('app_bibliothequeartiste') }}">
					Biobliothèque
				</a>
			</li>
		{% elseif specialite in ['peintre', 'sculpteur', 'photographe'] %}
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_collections_front' ? 'active' : '' }}" href="{{ path('app_collections_front') }}">
					Collections
				</a>
			</li>
			<li class="nav-item">
				<a class="nav-link {{ current_route == 'app_oeuvre_front' ? 'active' : '' }}" href="{{ path('app_oeuvre_front') }}">
					Mes Oeuvres
				</a>
			</li>
		{% endif %}
		<li class="nav-item">
			<a class="nav-link {{ current_route == 'app_eventsartiste' ? 'active' : '' }}" href="{{ path('app_eventsartiste') }}">
				Evenements
			</a>
		</li>
		<li class="nav-item">
			<a class="nav-link {{ current_route == 'app_reclamationsartiste' ? 'active' : '' }}" href="{{ path('app_reclamationsartiste') }}">
				Réclamations
			</a>
		</li>
		<li class="nav-item">
			<a class="nav-link {{ current_route == 'app_statistiquesartiste' ? 'active' : '' }}" href="{{ path('app_statistiquesartiste') }}">
				Statistiques
			</a>
		</li>
	</ul>
</div></div><!-- My profile END -->

