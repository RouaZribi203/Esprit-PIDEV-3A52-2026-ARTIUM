<!DOCTYPE html>

<title>Collections index</title>

{% block body %}
    <h1>Collections index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Titre</th>
                <th>Description</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for collection in collections %}
            <tr>
                <td>{{ collection.id }}</td>
                <td>{{ collection.titre }}</td>
                <td>{{ collection.description }}</td>
                <td>
                    <a href="{{ path('app_collections_show', {'id': collection.id}) }}">show</a>
                    <a href="{{ path('app_collections_edit', {'id': collection.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_collections_new') }}">Create new</a>
{% endblock %}
