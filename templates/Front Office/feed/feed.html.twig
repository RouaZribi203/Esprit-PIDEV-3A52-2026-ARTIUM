    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Handle Turbo form submissions
        function handleTurboFormSubmit(e) {
            const form = e.target;
            if (!form || form.tagName !== 'FORM' || !form.dataset.turboFrame) {
                return;
            }
            
            const frameName = form.dataset.turboFrame;
            const frameEl = document.getElementById(frameName);
            
            if (!frameEl) {
                return;
            }
            
            e.preventDefault();
            
            const formData = new FormData(form);
            const fetchInit = {
                method: form.method || 'GET',
                headers: {
                    'Turbo-Frame': frameName,
                    'X-Requested-With': 'XMLHttpRequest'
                }
            };
            
            if (form.method.toUpperCase() === 'POST') {
                fetchInit.body = formData;
            }
            
            fetch(form.action, fetchInit)
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newFrame = doc.querySelector(`turbo-frame[id="${frameName}"]`);
                    
                    // Check if this is an add comment form (not edit)
                    const isAddCommentForm = form.action.includes('/oeuvre/') && form.action.includes('/commentaire') && !form.id;
                    
                    if (newFrame && frameEl) {
                        const card = frameEl.closest('.card');
                        const oeuvreId = card?.id?.replace('oeuvre-', '');
                        frameEl.replaceWith(newFrame);
                        
                        // Sync footer on the NEW frame
                        syncCommentsFooter(newFrame);
                        
                        // Update comment count
                        const commentCount = newFrame.querySelectorAll('.comment-item').length;
                        if (oeuvreId) {
                            const countElement = document.querySelector(`.comment-count[data-oeuvre-id="${oeuvreId}"]`);
                            if (countElement) {
                                countElement.textContent = commentCount;
                            }
                        }
                        
                        // Clear textarea on the ORIGINAL add comment form (not inside frame)
                        if (isAddCommentForm && card) {
                            const addCommentForm = card.querySelector('form[action*="/commentaire"]');
                            if (addCommentForm) {
                                const textarea = addCommentForm.querySelector('textarea[name="contenu"]');
                                if (textarea) {
                                    textarea.value = '';
                                }
                            }
                        }
                        
                        // Dispatch event on document so global listener catches it
                        const event = new CustomEvent('turbo:submit-end', {
                            detail: { success: true }
                        });
                        document.dispatchEvent(event);
                    }
                })
                .catch(error => {
                    console.error('Turbo frame update error:', error);
                });
        }
        
        const loadMoreBtn = document.getElementById('load-more-btn');
        const feedContainer = document.getElementById('feed-container');
        const itemsPerLoad = 3;

        const initialHiddenOeuvres = document.querySelectorAll('.hidden-oeuvre');
        if (loadMoreBtn && initialHiddenOeuvres.length > 0) {
            loadMoreBtn.addEventListener('click', function() {
                // Show spinner
                this.querySelector('.load-text').style.display = 'none';
                this.querySelector('.load-icon').style.display = 'inline-block';

                // Simulate loading delay
                setTimeout(() => {
                    // Re-query fresh list of currently hidden oeuvres
                    const hiddenOeuvres = document.querySelectorAll('.hidden-oeuvre');
                    const stillHidden = Array.from(hiddenOeuvres).filter(el => el.style.display !== 'block');
                    
                    // Show next batch
                    const endIndex = Math.min(itemsPerLoad, stillHidden.length);
                    
                    // Move items from hidden to visible
                    for (let i = 0; i < endIndex; i++) {
                        feedContainer.appendChild(stillHidden[i]);
                        stillHidden[i].style.display = 'block';
                        
                        // Sync comment footers
                        stillHidden[i].querySelectorAll('turbo-frame[id^="comments-"]')
                            .forEach(syncCommentsFooter);
                        
                        // Bind Turbo form submissions for appended cards
                        stillHidden[i].querySelectorAll('form[data-turbo-frame]').forEach(form => {
                            form.removeEventListener('submit', handleTurboFormSubmit);
                            form.addEventListener('submit', handleTurboFormSubmit);
                        });
                    }

                    // Hide button if no more items
                    const remainingHidden = document.querySelectorAll('.hidden-oeuvre');
                    const stillMoreHidden = Array.from(remainingHidden).filter(el => el.style.display !== 'block');
                    if (stillMoreHidden.length === 0) {
                        this.style.display = 'none';
                    }

                    // Reset button state
                    this.querySelector('.load-text').style.display = 'inline';
                    this.querySelector('.load-icon').style.display = 'none';
                }, 500);
            });
        }

        function syncCommentsFooter(frame) {
            if (!frame) {
                return;
            }

            const card = frame.closest('.card');
            if (!card) {
                return;
            }

            const footer = card.querySelector('.card-footer');
            if (!footer) {
                return;
            }

            if (card.dataset.commentsExpanded === 'true') {
                frame.querySelectorAll('.comment-item.hidden-comment.d-none').forEach((item) => {
                    item.classList.remove('d-none');
                });
            }

            const totalComments = frame.querySelectorAll('.comment-item').length;
            if (totalComments <= 3) {
                delete card.dataset.commentsExpanded;
                footer.style.display = 'none';
                return;
            }

            const remainingHidden = frame.querySelectorAll('.comment-item.hidden-comment.d-none').length;
            footer.style.display = remainingHidden > 0 ? '' : 'none';
        }

        document.querySelectorAll('turbo-frame[id^="comments-"]').forEach(syncCommentsFooter);

        document.addEventListener('turbo:frame-load', function(e) {
            const frame = e.target;
            if (frame && frame.id && frame.id.startsWith('comments-')) {
                syncCommentsFooter(frame);
                
                // Update comment count
                const card = frame.closest('.card');
                const oeuvreId = card?.id?.replace('oeuvre-', '');
                const commentCount = frame.querySelectorAll('.comment-item').length;
                if (oeuvreId) {
                    const countElement = document.querySelector(`.comment-count[data-oeuvre-id="${oeuvreId}"]`);
                    if (countElement) {
                        countElement.textContent = commentCount;
                    }
                }
            }
        });

        document.addEventListener('turbo:submit-end', function(e) {
            const form = e.target;
            if (!form || form.tagName !== 'FORM') {
                return;
            }

            if (form.dataset.turboFrame && form.action.includes('/commentaire') && e.detail.success) {
                const textarea = form.querySelector('textarea[name="contenu"]');
                if (textarea) {
                    textarea.value = '';
                }
            }
        });

        document.addEventListener('keydown', function(e) {
            if (e.defaultPrevented) {
                return;
            }
            const textarea = e.target;
            if (!textarea || textarea.tagName !== 'TEXTAREA') {
                return;
            }

            if (textarea.name !== 'contenu') {
                return;
            }

            if (e.key === 'Enter' && !e.shiftKey) {
                const form = textarea.closest('form');
                if (form) {
                    e.preventDefault();
                    form.requestSubmit();
                }
            }
        });

        // Load more comments per post
        document.addEventListener('click', function(e) {
            const commentsBtn = e.target.closest('.comments-load-more');
            if (!commentsBtn) {
                return;
            }

            e.preventDefault();

            const card = commentsBtn.closest('.card');
            if (!card) {
                return;
            }

            const loadText = commentsBtn.querySelector('.comments-load-text');
            const loader = commentsBtn.querySelector('.comments-loader');

            if (loadText) {
                loadText.style.display = 'none';
            }
            if (loader) {
                loader.style.display = 'inline-flex';
            }

            setTimeout(() => {
                const hiddenComments = card.querySelectorAll('.comment-item.hidden-comment.d-none');
                const revealCount = Math.min(3, hiddenComments.length);

                for (let i = 0; i < revealCount; i++) {
                    hiddenComments[i].classList.remove('d-none');
                }

                if (loadText) {
                    loadText.style.display = 'inline';
                }
                if (loader) {
                    loader.style.display = 'none';
                }

                const remaining = card.querySelectorAll('.comment-item.hidden-comment.d-none').length;
                if (remaining === 0) {
                    const footer = commentsBtn.closest('.card-footer');
                    if (footer) {
                        footer.style.display = 'none';
                    }
                }

                if (!card.dataset.commentsExpanded) {
                    card.dataset.commentsExpanded = 'true';
                }
            }, 400);
        });

        // Inline comment edit toggle
        document.addEventListener('click', function(e) {
            const editToggle = e.target.closest('.comment-edit-toggle');
            if (editToggle) {
                const editId = editToggle.dataset.editId;
                const viewId = editToggle.dataset.viewId;
                const editForm = document.getElementById(editId);
                const textView = document.getElementById(viewId);

                if (editForm && textView) {
                    textView.classList.add('d-none');
                    editForm.classList.remove('d-none');
                    const textarea = editForm.querySelector('textarea[name="contenu"]');
                    if (textarea) {
                        textarea.focus();
                        textarea.selectionStart = textarea.value.length;
                    }
                }
            }

            const cancelToggle = e.target.closest('.comment-edit-cancel');
            if (cancelToggle) {
                const editId = cancelToggle.dataset.editId;
                const viewId = cancelToggle.dataset.viewId;
                const editForm = document.getElementById(editId);
                const textView = document.getElementById(viewId);

                if (editForm && textView) {
                    editForm.classList.add('d-none');
                    textView.classList.remove('d-none');
                }
            }
        });

        // Favorite toggle functionality
        function updateFavoriteVisualState(link, favorited) {
            const icon = link.querySelector('.favorite-icon') || link.querySelector('i');
            const text = link.querySelector('.favorite-text');

            if (!icon) {
                return;
            }

            if (favorited) {
                icon.classList.remove('bi-star', 'text-secondary');
                icon.classList.add('bi-star-fill', 'text-warning');
                if (text) {
                    text.textContent = 'Retirer des favoris';
                }
                link.dataset.favorited = 'true';
            } else {
                icon.classList.remove('bi-star-fill', 'text-warning');
                icon.classList.add('bi-star', 'text-secondary');
                if (text) {
                    text.textContent = 'Ajouter aux Favoris';
                }
                link.dataset.favorited = 'false';
            }
        }

        function syncFavoriteState(oeuvreId, favorited, favoriteCount = null) {
            const favoriteLinks = document.querySelectorAll(`.favorite-toggle[data-oeuvre-id="${oeuvreId}"]`);
            favoriteLinks.forEach((favoriteLink) => updateFavoriteVisualState(favoriteLink, favorited));

            if (favoriteCount !== null) {
                const favoriteCounts = document.querySelectorAll(`.favorite-count[data-oeuvre-id="${oeuvreId}"]`);
                favoriteCounts.forEach((favoriteCountElement) => {
                    favoriteCountElement.textContent = favoriteCount;
                });
            }
        }

        document.addEventListener('click', function(e) {
            if (e.target.closest('.favorite-toggle')) {
                e.preventDefault();
                const link = e.target.closest('.favorite-toggle');
                const oeuvreId = link.dataset.oeuvreId;

                // Send AJAX request
                fetch(`/oeuvre/${oeuvreId}/favorite-ajax`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        syncFavoriteState(oeuvreId, data.favorited, data.favoriteCount ?? null);
                    }
                })
                .catch(error => {
                    console.error('Error toggling favorite:', error);
                });
            }
        });

        // Like toggle functionality
        document.addEventListener('click', function(e) {
            if (e.target.closest('.like-toggle')) {
                e.preventDefault();
                const link = e.target.closest('.like-toggle');
                const oeuvreId = link.dataset.oeuvreId;
                const isLiked = link.dataset.liked === 'true';
                const icon = link.querySelector('i');
                const countSpan = link.querySelector('.like-count');

                // Send AJAX request
                fetch(`/oeuvre/${oeuvreId}/like-ajax`, {
                    method: 'POST',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Toggle visual state
                        if (data.liked) {
                            icon.classList.add('bi-heart-fill', 'text-danger');
                            icon.classList.remove('bi-heart');
                            link.dataset.liked = 'true';
                        } else {
                            icon.classList.remove('bi-heart-fill', 'text-danger');
                            icon.classList.add('bi-heart');
                            link.dataset.liked = 'false';
                        }
                        // Update count
                        countSpan.textContent = data.likeCount;
                    }
                })
                .catch(error => {
                    console.error('Error toggling like:', error);
                });
            }
        });
    });
    </script>

