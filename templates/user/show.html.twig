{% extends 'base_admin.html.twig' %}

{% block title %}{{ user.nom }} {{ user.prenom }}{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-lg-12">
        <div class="border-bottom pb-3 mb-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="mb-0 h2 fw-bold">Profil de {{ user.nom }} {{ user.prenom }}</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="{{ path('app_admin') }}">Tableau de bord</a></li>
                            <li class="breadcrumb-item"><a href="{{ path('app_user_index') }}">Utilisateurs</a></li>
                            <li class="breadcrumb-item active">{{ user.nom }} {{ user.prenom }}</li>
                        </ol>
                    </nav>
                </div>
                <div class="d-flex gap-2">
                    <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="btn btn-primary">
                        <i class="fe fe-edit me-2"></i>Modifier
                    </a>
                    <a href="{{ path('app_user_index') }}" class="btn btn-outline-secondary">
                        <i class="fe fe-arrow-left me-2"></i>Retour
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Left Column - Photo et infos rapides -->
    <div class="col-lg-4">
        <div class="card mb-4">
            <div class="card-body text-center">
                <img src="{{ asset('assetsback/images/photodeprofil.png') }}" 
                     class="rounded-circle avatar-xxl mb-3" alt="{{ user.nom }}" style="width: 150px; height: 150px;" />
                <h3 class="mb-1">{{ user.nom }} {{ user.prenom }}</h3>
                <p class="text-muted mb-3">{{ user.email }}</p>
                
                {% if user.role %}
                    {% if user.role.value == 'ROLE_ARTISTE' %}
                        <span class="badge bg-primary fs-6">Artiste</span>
                    {% elseif user.role.value == 'ROLE_AMATEUR' %}
                        <span class="badge bg-info fs-6">Amateur</span>
                    {% else %}
                        <span class="badge bg-secondary fs-6">{{ user.role.value }}</span>
                    {% endif %}
                {% endif %}
                
                {% if user.statut %}
                    {% if user.statut.name == 'ACTIVE' %}
                        <span class="badge bg-success fs-6 ms-2">{{ user.statut.value }}</span>
                    {% else %}
                        <span class="badge bg-warning fs-6 ms-2">{{ user.statut.value }}</span>
                    {% endif %}
                {% endif %}
            </div>
        </div>

        <!-- Card Contact -->
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">Informations de contact</h4>
            </div>
            <div class="card-body">
                <ul class="list-unstyled mb-0">
                    <li class="mb-3">
                        <i class="fe fe-mail me-2 text-primary"></i>
                        <strong>Email:</strong><br>
                        <span class="ms-4">{{ user.email }}</span>
                    </li>
                    <li class="mb-3">
                        <i class="fe fe-phone me-2 text-primary"></i>
                        <strong>Téléphone:</strong><br>
                        <span class="ms-4">{{ user.numTel ?? 'Non renseigné' }}</span>
                    </li>
                    <li class="mb-0">
                        <i class="fe fe-map-pin me-2 text-primary"></i>
                        <strong>Ville:</strong><br>
                        <span class="ms-4">{{ user.ville ?? 'Non renseignée' }}</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Right Column - Détails complets -->
    <div class="col-lg-8">
        <!-- Informations personnelles -->
        <div class="card mb-4">
            <div class="card-header">
                <h4 class="mb-0">Informations personnelles</h4>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border-bottom pb-2">
                            <small class="text-muted d-block">Nom</small>
                            <strong>{{ user.nom }}</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-bottom pb-2">
                            <small class="text-muted d-block">Prénom</small>
                            <strong>{{ user.prenom }}</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-bottom pb-2">
                            <small class="text-muted d-block">Date de naissance</small>
                            <strong>{{ user.dateNaissance ? user.dateNaissance|date('d/m/Y') : 'Non renseignée' }}</strong>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-bottom pb-2">
                            <small class="text-muted d-block">Date d'inscription</small>
                            <strong>{{ user.dateInscription ? user.dateInscription|date('d/m/Y à H:i') : 'Non disponible' }}</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Spécialité et centres d'intérêt -->
        {% if user.specialite or user.centreInteret %}
        <div class="card mb-4">
            <div class="card-header">
                <h4 class="mb-0">Compétences et intérêts</h4>
            </div>
            <div class="card-body">
                {% if user.specialite %}
                <div class="mb-3">
                    <h5 class="mb-2"><i class="fe fe-award me-2 text-warning"></i>Spécialité</h5>
                    <p class="ms-4">{{ user.specialite.value }}</p>
                </div>
                {% endif %}
                
                {% if user.centreInteret %}
                <div>
                    <h5 class="mb-2"><i class="fe fe-heart me-2 text-danger"></i>Centres d'intérêt</h5>
                    <p class="ms-4">
                        {% for centre in user.centreInteret %}
                            <span class="badge bg-info me-2">{{ centre.value }}</span>
                        {% endfor %}
                    </p>
                </div>
                {% endif %}
            </div>
        </div>
        {% endif %}

        <!-- Biographie -->
        {% if user.biographie %}
        <div class="card">
            <div class="card-header">
                <h4 class="mb-0">Biographie</h4>
            </div>
            <div class="card-body">
                <p class="mb-0">{{ user.biographie }}</p>
            </div>
        </div>
        {% endif %}
    </div>
</div>

<!-- Delete Form -->
<div class="mt-4">
    {{ include('user/_delete_form.html.twig') }}
</div>
{% endblock %}