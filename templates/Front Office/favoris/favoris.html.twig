<style>
	.glightbox-container .gslide-inner-content {
		max-width: 1100px;
		width: 90vw;
		max-height: 85vh;
		margin: 0 auto;
	}

	.glightbox-container .gslide-media {
		max-height: 85vh;
		max-width: 60vw;
	}

	.glightbox-container .gslide-image img {
		max-height: 85vh;
		max-width: 60vw;
		width: auto;
		height: auto;
		object-fit: contain;
	}

	.glightbox-container .gdesc-inner,
	.glightbox-container .glightbox-desc {
		max-height: 85vh;
		overflow-y: auto;
	}

	@media (max-width: 991px) {
		.glightbox-container .gslide-media,
		.glightbox-container .gslide-image img {
			max-width: 90vw;
		}
	}
</style>
