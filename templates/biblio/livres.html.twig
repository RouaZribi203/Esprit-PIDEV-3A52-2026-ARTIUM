                      <h5 class="modal-title" id="livreDetailsLabel">Détails du livre</h5>
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                      <div class="row g-3">
                        <div class="col-12 col-md-7">
                          <div class="card mb-3">
                            <div class="card-body">
                              <h5 class="card-title" id="detail-titre">—</h5>
                              <p class="text-muted mb-1"><strong>ID:</strong> <span id="detail-id">—</span></p>
                              <p class="text-muted mb-1"><strong>Date de création:</strong> <span id="detail-date-creation">—</span></p>
                              <p id="detail-description">—</p>
                              <p id="detail-pdf">—</p>
                            </div>
                          </div>
                          <div class="card">
                            <div class="card-body" id="rental-section">
                              <h6>Informations de location <span id="rental-badge"></span></h6>
                              <p class="mb-1"><strong>ID location:</strong> <span id="detail-location-id">-</span></p>
                              <p class="mb-1"><strong>Date début:</strong> <span id="detail-location-date">-</span></p>
                              <p class="mb-1"><strong>Date d'expiration:</strong> <span id="detail-location-expiration">-</span></p>
                            </div>
                          </div>
                        </div>
                        <div class="col-12 col-md-5">
                          <div class="card mb-3">
                            <div class="card-body text-center">
                              <img id="detail-image" src="" alt="" class="img-fluid mb-2" style="max-height:200px;" />
                              <div class="small text-muted">Fichier PDF: <span id="detail-pdf-label">—</span></div>
                            </div>
                          </div>
                          <div class="card">
                            <div class="card-body">
                              <h6>Statistiques</h6>
                              <p class="mb-1"><strong>Nombre d’emprunts:</strong> <span id="stat-count">0</span></p>
                              <p class="mb-1"><strong>Budget total généré:</strong> <span id="stat-total">0.00</span> </p>
