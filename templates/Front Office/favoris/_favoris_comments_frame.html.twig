<turbo-frame id="comments-fav-{{ oeuvre.id }}">
{% if oeuvre.commentaires and oeuvre.commentaires|length > 0 %}
	<div class="fav-comments-container">
		<ul class="comment-wrap list-unstyled mb-0">
			{% for commentaire in oeuvre.commentaires %}
				<li class="comment-item{% if loop.index > 3 %} hidden-comment d-none{% endif %}">
					<div class="d-flex">
						<div class="avatar avatar-xs">
							<a href="#!"><img class="avatar-img rounded-circle" src="{{ asset('assetsfront/images/avatar/default.jpg') }}" alt=""></a>
						</div>
						<div class="ms-2 w-100">
							<div class="bg-light rounded-start-top-0 p-3 rounded">
								<div class="d-flex justify-content-between">
									<h6 class="mb-1"><a href="#!">{{ commentaire.user ? (commentaire.user.nom ~ ' ' ~ commentaire.user.prenom) : 'Utilisateur' }}</a></h6>
									<div class="d-flex align-items-center">
										<small class="ms-2">{{ commentaire.dateCommentaire ? commentaire.dateCommentaire|date('d F Y') : '' }}</small>
										{% if commentaire.user and app.user and commentaire.user.id == app.user.id %}
											<div class="dropdown ms-2">
												<a href="#" class="text-secondary btn btn-sm btn-link p-0" id="commentActionFavModal{{ oeuvre.id }}{{ commentaire.id }}" data-bs-toggle="dropdown" data-turbo="false" aria-expanded="false">
													<i class="bi bi-three-dots"></i>
												</a>
												<ul class="dropdown-menu dropdown-menu-end shadow-sm" aria-labelledby="commentActionFavModal{{ oeuvre.id }}{{ commentaire.id }}">
													<li>
														<button type="button" class="dropdown-item comment-edit-toggle" data-edit-id="favModalEditComment{{ oeuvre.id }}{{ commentaire.id }}" data-view-id="favModalCommentText{{ oeuvre.id }}{{ commentaire.id }}">
															<i class="bi bi-pencil-square text-primary pe-2"></i>Modifier
														</button>
													</li>
													<li><hr class="dropdown-divider"></li>
													<li>
													<form method="post" action="{{ path('favoris_commentaire_delete', {'id': commentaire.id}) }}" class="m-0" data-turbo-frame="comments-fav-{{ oeuvre.id }}">
														<input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ commentaire.id) }}">
															<input type="hidden" name="oeuvre_id" value="{{ oeuvre.id }}">
															<button type="submit" class="dropdown-item text-danger">
																<i class="bi bi-trash3 pe-2"></i>Supprimer
															</button>
														</form>
													</li>
												</ul>
											</div>
										{% endif %}
									</div>
								</div>
								<div id="favModalCommentText{{ oeuvre.id }}{{ commentaire.id }}" class="small mb-0 comment-text">{{ commentaire.texte }}</div>
								{% if commentaire.user and app.user and commentaire.user.id == app.user.id %}
								<form method="post" action="{{ path('favoris_commentaire_edit', {'id': commentaire.id}) }}" class="d-none" id="favModalEditComment{{ oeuvre.id }}{{ commentaire.id }}" data-turbo-frame="comments-fav-{{ oeuvre.id }}">
									<div class="position-relative">
										<textarea name="contenu" class="form-control bg-white" rows="2">{{ commentaire.texte }}</textarea>
										<input type="hidden" name="_token" value="{{ csrf_token('edit_comment_' ~ commentaire.id) }}">
											<input type="hidden" name="oeuvre_id" value="{{ oeuvre.id }}">
											<div class="d-flex gap-2 mt-2">
												<button type="submit" class="btn btn-sm btn-primary">
													<i class="bi bi-check2"></i>Enregistrer
												</button>
												<button type="button" class="btn btn-sm btn-outline-secondary comment-edit-cancel" data-edit-id="favModalEditComment{{ oeuvre.id }}{{ commentaire.id }}" data-view-id="favModalCommentText{{ oeuvre.id }}{{ commentaire.id }}">
													<i class="bi bi-x-lg"></i>Annuler
												</button>
											</div>
										</div>
									</form>
								{% endif %}
							</div>
						</div>
					</div>
				</li>
			{% endfor %}
		</ul>
		<div class="pt-2" style="display: {{ oeuvre.commentaires|length > 3 ? 'block' : 'none' }};">
			<a href="#" role="button" data-turbo="false" class="btn btn-link btn-link-loader btn-sm text-secondary d-flex align-items-center fav-comments-load-more">
				<div class="spinner-dots me-2 comments-loader" style="display: none;">
					<span class="spinner-dot"></span>
					<span class="spinner-dot"></span>
					<span class="spinner-dot"></span>
				</div>
				<span class="comments-load-text">Voir plus de commentaires</span>
			</a>
		</div>
	</div>
{% else %}
	<ul class="comment-wrap list-unstyled mb-0"></ul>
{% endif %}
</turbo-frame>
