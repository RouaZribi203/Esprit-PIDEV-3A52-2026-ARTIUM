{% set offcanvas_id = offcanvas_id|default('offcanvasProfile') %}
{% set title = title|default('Modifier profil') %}
{% set subtitle = subtitle|default('Mettez a jour vos informations personnelles') %}
{% set profile_form_action = profile_form_action|default('#') %}
{% set password_form_action = password_form_action|default('#') %}
{% set show_password_form = show_password_form|default(true) %}

{% embed 'Front Office/Partials/offcanvas_base.html.twig' with {
	offcanvas_id: offcanvas_id,
	title: title,
	subtitle: subtitle
} %}
	{% block offcanvas_body %}
		<div class="card shadow-sm border-0">
			<div class="card-body">
				   {{ form_start(form, {'attr': {'class': 'row g-3', 'enctype': 'multipart/form-data'}, 'action': profile_form_action}) }}
					   <div class="col-12">
						   <div class="d-flex align-items-center gap-3">
							   <div class="avatar avatar-xl">
								{% if user.photoProfil %}
								    <img class="avatar-img rounded-circle" src="{{ asset('uploads/' ~ user.photoProfil) }}" alt="">
								{% else %}
								    <span class="avatar-img rounded-circle bg-light d-inline-block border border-secondary" style="width:80px;height:80px;display:flex;align-items:center;justify-content:center;">
									    
								    </span>
								{% endif %}
							   </div>
							   <div>
								   {{ form_row(form.photoProfil) }}
							   </div>
						   </div>
					   </div>
					   <div class="col-md-6">
						   {{ form_row(form.nom) }}
					   </div>
					   <div class="col-md-6">
						   {{ form_row(form.prenom) }}
					   </div>
					   <div class="col-md-6">
						   {{ form_row(form.email) }}
					   </div>
					   <div class="col-md-6">
						   {{ form_row(form.numTel) }}
					   </div>
					   <div class="col-md-6">
						   {{ form_row(form.ville) }}
					   </div>
					   <div class="col-md-6">
						   {{ form_row(form.dateNaissance) }}
					   </div>
					   <div class="col-12">
						   {{ form_row(form.biographie) }}
					   </div>


					   {# Affichage strictement conditionnel selon le rôle #}
					   <div class="col-12" id="specialite-field" style="display: {% if user and user.role is defined and user.role.value == 'ARTISTE' %}block{% else %}none{% endif %};">
						   
						   {{ form_row(form.specialite) }}
					   </div>
					   <div class="col-12" id="centreInteret-field" style="display: {% if user and user.role is defined and user.role.value == 'AMATEUR' %}block{% else %}none{% endif %};">
						  
						   {{ form_row(form.centreInteret) }}
					   </div>

					   <script>
					   document.addEventListener('DOMContentLoaded', function() {
						   var roleSelect = document.getElementById('user_role');
						   var specialiteDiv = document.getElementById('specialite-field');
						   var centreInteretDiv = document.getElementById('centreInteret-field');
						   function updateFields() {
							   if (!roleSelect) return;
							   var role = roleSelect.value ? roleSelect.value.toUpperCase() : '';
							   if (role.includes('AMATEUR')) {
								   specialiteDiv.style.display = 'none';
								   centreInteretDiv.style.display = 'block';
							   } else if (role.includes('ARTISTE')) {
								   specialiteDiv.style.display = 'block';
								   centreInteretDiv.style.display = 'none';
							   } else {
								   specialiteDiv.style.display = 'none';
								   centreInteretDiv.style.display = 'none';
							   }
						   }
						   if (roleSelect) {
							   roleSelect.addEventListener('change', updateFields);
							   setTimeout(updateFields, 100); 
						   }
					   });
					   </script>

					   
					   <div class="col-12"></div>
					   <div class="col-md-6">
						   {{ form_row(form.role) }}
					   </div>
					   <div class="col-md-6">
						   {{ form_row(form.statut) }}
					   </div>
					   <div class="col-12 d-flex justify-content-end mt-4">
						   <button class="btn btn-primary px-4 py-2" type="submit">Enregistrer</button>
					   </div>
				   {{ form_end(form) }}
			</div>
		</div>

		{% if show_password_form %}
			<div class="card shadow-sm border-0 mt-4">
				<div class="card-body">
					<h5 class="mb-3">Modifier le mot de passe</h5>
					<div class="alert alert-warning" role="alert">
						<i class="fe fe-alert-triangle me-2"></i>
						En modifiant votre mot de passe, vous serez automatiquement déconnecté(e) de la session en cours. Vous devrez vous reconnecter avec le nouveau mot de passe.
					</div>
					<form class="row g-3" action="{{ path('app_changer_mot_de_passe') }}" method="post">
						<div class="col-12">
							<label class="form-label" for="currentPassword">Mot de passe actuel</label>
							<input class="form-control" type="password" id="currentPassword" name="currentPassword" placeholder="********">
						</div>
						<div class="col-md-6">
							<label class="form-label" for="newPassword">Nouveau mot de passe</label>
							<input class="form-control" type="password" id="newPassword" name="newPassword" placeholder="********">
						</div>
						<div class="col-md-6">
							<label class="form-label" for="confirmPassword">Confirmer</label>
							<input class="form-control" type="password" id="confirmPassword" name="confirmPassword" placeholder="********">
						</div>
						<div class="col-12 d-flex justify-content-end">
							<button class="btn btn-outline-primary" type="submit">Mettre a jour</button>
						</div>
					</form>
				</div>
			</div>
		{% endif %}
	{% endblock %}
{% endembed %}